@code {
    private const string CatalogGroupStorageKey = "catalog";

    private bool CatalogExpanded { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var persistedState = await JS.InvokeAsync<string>("agtTheme.getStoredNavSectionState", CatalogGroupStorageKey, "collapsed");
        CatalogExpanded = string.Equals(persistedState, "expanded", StringComparison.OrdinalIgnoreCase);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCatalogGroupClick(MenuItemEventArgs _)
    {
        CatalogExpanded = !CatalogExpanded;
        var state = CatalogExpanded ? "expanded" : "collapsed";
        await JS.InvokeVoidAsync("agtTheme.setStoredNavSectionState", CatalogGroupStorageKey, state);
    }
}
