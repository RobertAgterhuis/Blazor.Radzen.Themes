    private static readonly IReadOnlyList<CatalogCategory> CatalogCategories = BuildCatalogCategories();

    private const string CatalogCategoryStoragePrefix = "agt-ui-catalog-category-";
    private const string CatalogCategoryValuePrefix = "catalog-category:";

    private string FilterText { get; set; } = string.Empty;
    private string CurrentRoute { get; set; } = string.Empty;
    private ElementReference _filterInputRef;
    private ElementReference _menuRootRef;
    private bool _catalogStateLoaded;
    private readonly Dictionary<string, bool> _catalogExpandedState = new(StringComparer.OrdinalIgnoreCase);

    private bool HasFilter => !string.IsNullOrWhiteSpace(FilterText);

    private List<NavEntry> FilteredGettingStarted => FilterEntries(GettingStartedItems);

    private List<NavSection> FilteredAgtSections =>
        [.. AgtSections
            .Select(section => new NavSection(section.Title, FilterEntries(section.Items)))
            .Where(section => section.Items.Count > 0)];

    private List<CatalogCategoryView> FilteredCatalogCategories => FilterCatalogCategories();

    private bool HasAgtItems => FilteredAgtSections.Count > 0;

    private bool HasAnyVisibleItems => FilteredGettingStarted.Count > 0 || HasAgtItems || FilteredCatalogCategories.Count > 0;

    protected override void OnInitialized()
    {
        UpdateCurrentRoute();
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreCatalogCategoryStateAsync();
            await InvokeAsync(StateHasChanged);
        }

        await JS.InvokeVoidAsync("agtTheme.applyNavItemTitles", _menuRootRef);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        UpdateCurrentRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnFilterInput(ChangeEventArgs args)
    {
        FilterText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task OnFilterKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            if (!HasFilter)
            {
                return;
            }

            FilterText = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(args.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.focusFirstNavItem", _menuRootRef);
        }
    }

    private async Task OnMenuKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.focusNavItem", _menuRootRef, "next");
            return;
        }

        if (string.Equals(args.Key, "ArrowUp", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.focusNavItem", _menuRootRef, "prev");
            return;
        }

        if (string.Equals(args.Key, "Home", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.focusNavItem", _menuRootRef, "first");
            return;
        }

        if (string.Equals(args.Key, "End", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.focusNavItem", _menuRootRef, "last");
            return;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("agtTheme.activateFocusedNavItem", _menuRootRef);
        }
    }

    private async Task ClearFilter()
    {
        if (!HasFilter)
        {
            return;
        }

        FilterText = string.Empty;
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("agtTheme.focusElement", _filterInputRef);
    }

    private async Task OnPanelMenuClick(MenuItemEventArgs args)
    {
        var rawValue = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(rawValue) || !rawValue.StartsWith(CatalogCategoryValuePrefix, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var key = rawValue[CatalogCategoryValuePrefix.Length..];
        var nextState = !_catalogExpandedState.TryGetValue(key, out var expanded) || !expanded;
        await PersistCatalogCategoryStateAsync(key, nextState);
        await InvokeAsync(StateHasChanged);
    }

    private List<NavEntry> FilterEntries(IEnumerable<NavEntry> entries)
    {
        if (!HasFilter)
        {
            return [.. entries];
        }

        return [.. entries.Where(entry => entry.Text.Contains(FilterText, StringComparison.OrdinalIgnoreCase))];
    }

    private List<CatalogCategoryView> FilterCatalogCategories()
    {
        if (!HasFilter)
        {
            return [.. CatalogCategories.Select(category => new CatalogCategoryView(category.Key, category.Text, category.Icon, category.OverviewPath, category.Items))];
        }

        var filter = FilterText.Trim();
        var result = new List<CatalogCategoryView>();
        foreach (var category in CatalogCategories)
        {
            var filteredItems = category.Items
                .Where(item => item.Text.Contains(filter, StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (filteredItems.Count > 0 || category.Text.Contains(filter, StringComparison.OrdinalIgnoreCase) || "Overzicht".Contains(filter, StringComparison.OrdinalIgnoreCase))
            {
                result.Add(new CatalogCategoryView(category.Key, category.Text, category.Icon, category.OverviewPath, filteredItems));
            }
        }

        return result;
    }

    private bool IsCatalogCategoryExpanded(CatalogCategoryView category)
    {
        if (HasFilter)
        {
            return true;
        }

        if (category.Items.Any(item => IsCurrentRoute(item.Path)) || IsCurrentRoute(category.OverviewPath))
        {
            return true;
        }

        return _catalogExpandedState.TryGetValue(category.Key, out var expanded) && expanded;
    }

    private bool IsCurrentRoute(string path)
    {
        var target = path.TrimStart('/');
        return string.Equals(CurrentRoute, target, StringComparison.OrdinalIgnoreCase);
    }

    private string CatalogCategoryValue(string key) => $"{CatalogCategoryValuePrefix}{key}";

    private async Task RestoreCatalogCategoryStateAsync()
    {
        if (_catalogStateLoaded)
        {
            return;
        }

        foreach (var category in CatalogCategories)
        {
            var key = BuildCatalogStorageKey(category.Key);
            var value = await JS.InvokeAsync<string>("agtTheme.getStoredValue", key, "collapsed");
            _catalogExpandedState[category.Key] = string.Equals(value, "expanded", StringComparison.OrdinalIgnoreCase);
        }

        _catalogStateLoaded = true;
    }

    private ValueTask PersistCatalogCategoryStateAsync(string key, bool expanded)
    {
        _catalogExpandedState[key] = expanded;
        var value = expanded ? "expanded" : "collapsed";
        return JS.InvokeVoidAsync("agtTheme.setStoredValue", BuildCatalogStorageKey(key), value);
    }

    private static string BuildCatalogStorageKey(string key) => $"{CatalogCategoryStoragePrefix}{key}";

    private void UpdateCurrentRoute()
    {
        CurrentRoute = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('?', '#')[0].ToLowerInvariant();
    }

    private static IReadOnlyList<CatalogCategory> BuildCatalogCategories()
    {
        var orderedCategories = new List<CatalogCategory>
        {
            new("datagrid", "DataGrid", "table_rows", "/catalog/data" , []),
            new("data", "Data", "dataset", "/catalog/data", []),
            new("forms", "Forms", "dynamic_form", "/catalog/forms-advanced", []),
            new("validators", "Validators", "verified", "/catalog/validators", []),
            new("navigation", "Navigation", "alt_route", "/catalog/navigation", []),
            new("layout", "Layout", "grid_view", "/catalog/layout", []),
            new("overlays", "Overlays", "layers", "/catalog/overlays", []),
            new("feedback", "Feedback", "notification_important", "/catalog/feedback", []),
            new("data-visualization", "Data Visualization", "monitoring", "/catalog/charts", []),
            new("display", "Display", "slideshow", "/catalog/display", [])
        };

        var grouped = orderedCategories.ToDictionary(
            category => category.Key,
            _ => new List<NavEntry>(),
            StringComparer.OrdinalIgnoreCase);

        foreach (var raw in RawCatalogItems)
        {
            var slug = CatalogSlug(raw.Path);
            if (IsCategoryIndexSlug(slug) || IsChildRouteSlug(slug))
            {
                continue;
            }

            var categoryKey = ResolveCatalogCategoryKey(slug);
            if (!grouped.TryGetValue(categoryKey, out var bucket))
            {
                continue;
            }

            var text = NormalizeCatalogLabel(raw.Text);
            if (string.IsNullOrWhiteSpace(text))
            {
                continue;
            }

            if (bucket.Any(item => string.Equals(item.Path, raw.Path, StringComparison.OrdinalIgnoreCase)))
            {
                continue;
            }

            bucket.Add(new NavEntry(text, raw.Icon, raw.Path, raw.Match));
        }

        var result = new List<CatalogCategory>(orderedCategories.Count);
        foreach (var category in orderedCategories)
        {
            if (!grouped.TryGetValue(category.Key, out var items) || items.Count == 0)
            {
                continue;
            }

            result.Add(category with { Items = [.. items.OrderBy(item => item.Text, StringComparer.OrdinalIgnoreCase)] });
        }

        return result;
    }

    private static string NormalizeCatalogLabel(string text)
    {
        var withoutSuffix = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"\s*\(Radzen(?:\s+component)?\)\s*$",
            string.Empty,
            System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.CultureInvariant);

        var cleaned = System.Text.RegularExpressions.Regex.Replace(
            withoutSuffix,
            @"[^\p{L}\p{Nd}\s\-\&\+\./]",
            string.Empty,
            System.Text.RegularExpressions.RegexOptions.CultureInvariant);

        return System.Text.RegularExpressions.Regex.Replace(cleaned, @"\s+", " ", System.Text.RegularExpressions.RegexOptions.CultureInvariant).Trim();
    }

    private static string CatalogSlug(string path)
    {
        var slug = path.Replace("/catalog/", string.Empty, StringComparison.OrdinalIgnoreCase).Trim('/');
        return slug.ToLowerInvariant();
    }

    private static bool IsCategoryIndexSlug(string slug)
    {
        return slug switch
        {
            "" or
            "buttons" or
            "text-inputs" or
            "selection-inputs" or
            "pickers" or
            "forms" or
            "forms-advanced" or
            "validators" or
            "data" or
            "data-advanced" or
            "scheduling" or
            "navigation" or
            "overlays" or
            "overlays-advanced" or
            "layout" or
            "layout-advanced" or
            "feedback" or
            "charts" or
            "charts-advanced" or
            "gauges" or
            "display" or
            "embed" or
            "all-components" => true,
            _ => false
        };
    }

    private static bool IsChildRouteSlug(string slug)
    {
        return slug switch
        {
            "body" or
            "column-options" or
            "data-filter-item" or
            "data-filter-property" or
            "data-list-row" or
            "footer" or
            "grid-row" or
            "header" or
            "layout-component" or
            "radio-button-list-item" or
            "splitter-pane" => true,
            _ => false
        };
    }

    private static string ResolveCatalogCategoryKey(string slug)
    {
        if (slug == "data-grid")
        {
            return "datagrid";
        }

        if (slug.Contains("validator", StringComparison.OrdinalIgnoreCase))
        {
            return "validators";
        }

        if (slug.Contains("series", StringComparison.OrdinalIgnoreCase) ||
            slug is "chart" or "sparkline" or "sankey-diagram" or "spider-chart" or "treemap" or "arc-gauge" or "linear-gauge" or "radial-gauge")
        {
            return "data-visualization";
        }

        if (slug.StartsWith("data-", StringComparison.OrdinalIgnoreCase) ||
            slug is "scheduler" or "dropdown-data-grid" or "pager" or "tree" or "table")
        {
            return "data";
        }

        if (slug is "textbox" or "autocomplete" or "dropdown" or "checkbox" or "checkbox-list" or "chip" or "chip-list" or "password" or "textarea" or "fieldset" or "form-field" or "datepicker" or "mask" or "numeric" or "color-picker" or "list-box" or "rating" or "slider" or "time-span-picker" or "template-form" or "select-bar" or "pick-list" or "security-code" or "switch" or "file-input" or "upload" or "text")
        {
            return "forms";
        }

        if (slug is "breadcrumb" or "button" or "split-button" or "radio-button-list" or "profile-menu" or "context-menu" or "link" or "fab" or "fab-menu" or "toggle-button" or "speech-to-text-button" or "menu" or "panel-menu" or "accordion" or "tabs" or "steps")
        {
            return "navigation";
        }

        if (slug is "row" or "panel" or "carousel" or "card-group" or "card" or "image" or "markdown" or "html-editor" or "sidebar" or "sidebar-toggle" or "splitter" or "stack" or "tile-layout" or "toc" or "media-query" or "appearance-toggle")
        {
            return "layout";
        }

        if (slug is "dialog" or "notification" or "popup" or "login" or "chat" or "aichat")
        {
            return "overlays";
        }

        if (slug is "alert" or "progress-bar" or "progress-bar-circular" or "skeleton" or "badge")
        {
            return "feedback";
        }

        if (slug is "icon" or "gravatar" or "qr-code" or "barcode" or "google-map" or "signature-pad")
        {
            return "display";
        }

        return "display";
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
