@inherits LayoutComponentBase

<CascadingValue Value="ThemeState" IsFixed="true">
<CascadingValue Value="DensityState" IsFixed="true">
    <div class="demo-theme-root" data-agt-theme="@ThemeState.Theme" data-agt-density="@DensityState.Density" data-agt-motion="@MotionMode" data-agt-ambient="@AmbientMode">
        @if (ShowAmbient)
        {
            <div class="demo-shell-ambient demo-shell-ambient--@ThemeState.ActiveTheme.Name" aria-hidden="true"></div>
        }

        <AgtSkipLink Text="Naar hoofdinhoud" TargetId="main" />

        <RadzenLayout class="demo-layout">
            <RadzenHeader class="demo-topbar" role="banner">
                <div class="demo-topbar-inner">
                    <div class="demo-topbar__menu-toggle-host" @ref="_sidebarToggleRef">
                        <RadzenSidebarToggle class="demo-topbar__menu-toggle"
                                             Icon="menu"
                                             aria-controls="demo-shell-sidebar"
                                             aria-expanded="@SidebarExpanded.ToString().ToLowerInvariant()"
                                             ToggleAriaLabel="Menu verbergen/tonen"
                                             Click="OnSidebarToggleClicked" />
                    </div>
                    <div class="demo-topbar-brand">ICT365 · Agterhuis.Ui</div>
                    <div class="demo-topbar-actions">
                        <AgtCommandPalette />
                        <AgtDensityToggle />
                        <AgtThemeSwitcher />
                    </div>
                </div>
            </RadzenHeader>

            @if (IsMobileDrawerOpen)
            {
                <button type="button"
                        class="demo-sidebar-backdrop"
                        aria-label="Menu sluiten"
                        @onclick="OnSidebarBackdropClick"></button>
            }

            <RadzenSidebar id="demo-shell-sidebar"
                           class="@SidebarCssClass"
                           Style="@SidebarInlineStyle"
                           @bind-Expanded="SidebarExpanded"
                           Responsive="false"
                           FullHeight="true"
                           Position="SidebarPosition.Left"
                           role="navigation"
                           aria-label="Hoofdnavigatie">
                <div class="demo-sidebar__surface"
                     @ref="_sidebarSurfaceRef"
                     tabindex="-1"
                     role="@(IsMobileDrawerOpen ? "dialog" : null)"
                     aria-modal="@(IsMobileDrawerOpen ? "true" : null)"
                     aria-label="@(IsMobileDrawerOpen ? "Hoofdnavigatie" : null)">
                    <nav aria-label="Hoofdnavigatie">
                        <NavMenu />
                    </nav>
                </div>
            </RadzenSidebar>

            <RadzenBody Expanded="false" class="@BodyCssClass">
                <div class="@BodyContentCssClass">
                    <main id="main" class="demo-main" tabindex="-1">
                        @if (ShowWrapperToCatalogLink)
                        {
                            <p class="demo-page-context-link demo-page-context-link--wrapper" data-role="page-context-link">
                                Bekijk de rauwe Radzen-variant in het theme
                                <a href="@WrapperToCatalogLink" aria-label="Bekijk de rauwe Radzen-variant in het theme">→</a>
                            </p>
                        }

                        @if (IsCatalogRoute)
                        {
                            <p class="demo-page-context-link demo-page-context-link--catalog" data-role="page-context-link">
                                Voor gebruik in applicaties: zie de Agt-wrappers
                                @if (CatalogHasWrapperLink)
                                {
                                    <a href="@CatalogToWrapperLink" aria-label="Ga naar de Agt-wrappers">→</a>
                                }
                                else
                                {
                                    <span class="demo-page-context-link__note">(voor deze cataloguspagina is nog geen specifieke wrapperpagina beschikbaar)</span>
                                }
                            </p>
                        }

                        @Body
                    </main>
                    <footer class="demo-footer" role="contentinfo">
                        <span>Agterhuis.Ui demo</span>
                    </footer>
                </div>
            </RadzenBody>
        </RadzenLayout>

        <RadzenComponents />
    </div>
</CascadingValue>
</CascadingValue>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
