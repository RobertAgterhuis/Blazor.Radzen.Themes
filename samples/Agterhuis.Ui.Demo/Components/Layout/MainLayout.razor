@inherits LayoutComponentBase

<CascadingValue Value="ThemeState" IsFixed="true">
    <div class="demo-theme-root" data-agt-theme="@ThemeState.Theme" data-agt-motion="@MotionMode" data-agt-ambient="@AmbientMode">
        @if (ShowAmbient)
        {
            <div class="demo-shell-ambient demo-shell-ambient--@ThemeState.ActiveTheme.Name" aria-hidden="true"></div>
        }

        <AgtSkipLink Text="Naar hoofdinhoud" TargetId="main" />

        <RadzenLayout class="demo-layout">
            <RadzenHeader class="demo-topbar" role="banner">
                <div class="demo-topbar-inner">
                    <RadzenSidebarToggle Icon="menu" Click="@OnSidebarToggle" ToggleAriaLabel="Navigatie in- of uitklappen" />
                    <div class="demo-topbar-brand">ICT365 · Agterhuis.Ui</div>
                    <AgtThemeSwitcher />
                </div>
            </RadzenHeader>

            <RadzenSidebar class="demo-sidebar"
                           @bind-Expanded="SidebarExpanded"
                           Responsive="true"
                           FullHeight="true"
                           Position="SidebarPosition.Left"
                           ResponsiveMaxWidth="900px"
                           role="navigation"
                           aria-label="Hoofdnavigatie">
                <nav aria-label="Hoofdnavigatie">
                    <NavMenu />
                </nav>
            </RadzenSidebar>

            <RadzenBody Expanded="@SidebarExpanded" class="demo-body">
                <main id="main" class="demo-main" tabindex="-1">
                    @if (ShowWrapperToCatalogLink)
                    {
                        <p class="demo-link-banner demo-link-banner--wrapper">
                            Bekijk de rauwe Radzen-variant in het theme
                            <a href="@WrapperToCatalogLink">-&gt;</a>
                        </p>
                    }

                    @if (IsCatalogRoute)
                    {
                        <p class="demo-link-banner demo-link-banner--catalog">
                            Dit is de theme-QA-weergave. Voor gebruik in applicaties: zie de Agt-wrappers
                            @if (CatalogHasWrapperLink)
                            {
                                <a href="@CatalogToWrapperLink">-&gt;</a>
                            }
                            else
                            {
                                <span class="demo-link-banner__note">(voor deze cataloguspagina is nog geen specifieke wrapperpagina beschikbaar)</span>
                            }
                        </p>
                    }

                    @Body
                </main>
                <footer class="demo-footer" role="contentinfo">
                    <span>Agterhuis.Ui demo</span>
                </footer>
            </RadzenBody>
        </RadzenLayout>

        <RadzenComponents />
    </div>
</CascadingValue>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
