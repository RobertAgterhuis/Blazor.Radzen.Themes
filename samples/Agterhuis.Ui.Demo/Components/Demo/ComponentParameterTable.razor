@using Agterhuis.Ui.Designer.Introspection
@using Agterhuis.Ui.Designer.Registry

<section class="demo-api" aria-labelledby="@_headingId">
    <h3 id="@_headingId">API</h3>

    @if (_rows.Count == 0)
    {
        <p>Geen parameters gevonden.</p>
    }
    else
    {
        <div class="demo-api__table-wrap">
            <table class="demo-api__table">
                <thead>
                    <tr>
                        <th scope="col">Naam</th>
                        <th scope="col">Type</th>
                        <th scope="col">Standaard</th>
                        <th scope="col">Beschrijving</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.Name</td>
                            <td>@row.TypeName</td>
                            <td>@row.DefaultValue</td>
                            <td>@row.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public Type ComponentType { get; set; } = typeof(object);

    private IReadOnlyList<Agterhuis.Ui.Designer.Registry.ComponentParameterDescriptor> _rows = Array.Empty<Agterhuis.Ui.Designer.Registry.ComponentParameterDescriptor>();
    private readonly string _headingId = $"demo-api-{Guid.NewGuid():N}";

    protected override void OnParametersSet()
    {
        _rows = ComponentParameterIntrospector.Describe(ComponentType)
            .Select(parameter => new Agterhuis.Ui.Designer.Registry.ComponentParameterDescriptor(
                parameter.Name,
                parameter.TypeName,
                parameter.ParameterType,
                parameter.DefaultValue,
                parameter.Description,
                parameter.IsBindable,
                parameter.IsEditorRequired,
                parameter.IsEventCallback,
                parameter.IsRenderFragment,
                parameter.IsTemplatedRenderFragment))
            .ToArray();
    }
}
