@page "/catalog/layout"

<PageTitle>Layout (Radzen)</PageTitle>

<div class="catalog-page">
    <h1>Layout (Radzen)</h1>

    <RadzenCard>
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard>Column A</RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenCard>Column B</RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    <RadzenPanel Text="Panel title">Panel body</RadzenPanel>

    <RadzenFieldset Text="Fieldset">Fieldset body</RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem">
        <RadzenCard>Card 1</RadzenCard>
        <RadzenCard>Card 2</RadzenCard>
    </RadzenStack>

    <RadzenCarousel>
        <Items>
            <RadzenCarouselItem>Slide 1</RadzenCarouselItem>
            <RadzenCarouselItem>Slide 2</RadzenCarouselItem>
        </Items>
    </RadzenCarousel>
</div>
