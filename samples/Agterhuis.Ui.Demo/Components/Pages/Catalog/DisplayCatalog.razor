@page "/catalog/display"

<PageTitle>Display (Radzen)</PageTitle>

<div class="catalog-page">
    <h1>Display (Radzen)</h1>

    <RadzenTimeline>
        <RadzenTimelineItem Text="Created" Date="@DateTime.Today.AddDays(-2)" />
        <RadzenTimelineItem Text="Reviewed" Date="@DateTime.Today.AddDays(-1)" />
    </RadzenTimeline>

    <RadzenImage Path="https://placehold.co/320x160" AlternateText="Sample image" />
    <RadzenGravatar Email="someone@example.com" />
    <RadzenIcon Icon="palette" />

    <RadzenMarkdown Value="### Markdown\n**Brand typography** sample." />

    <RadzenHtmlEditor @bind-Value="HtmlValue" Style="height: 200px;" />

</div>

@code {
    private string HtmlValue { get; set; } = "<p>Editor content</p>";
}
