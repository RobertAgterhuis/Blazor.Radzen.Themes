@page "/catalog/spider-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.SpiderSeries

<PageTitle>SpiderSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="SpiderSeries"
               Introduction="Spider series voor radiale lijnvergelijkingen."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor SpiderSeries."
                 ExampleComponentType="typeof(SpiderSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/SpiderSeries/SpiderSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
