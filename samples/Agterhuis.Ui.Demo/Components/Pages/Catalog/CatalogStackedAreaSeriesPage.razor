@page "/catalog/stacked-area-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.StackedAreaSeries

<PageTitle>StackedAreaSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="StackedAreaSeries"
               Introduction="Gestapelde area-series voor proportievergelijking per categorie."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor StackedAreaSeries."
                 ExampleComponentType="typeof(StackedAreaSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedAreaSeries/StackedAreaSeriesBasicExample.razor" />

    <DemoExample Title="Uitgebreid"
                 Description="Uitgebreider scenario voor StackedAreaSeries."
                 ExampleComponentType="typeof(StackedAreaSeriesAdvancedExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedAreaSeries/StackedAreaSeriesAdvancedExample.razor" />

    <DemoExample Title="Compact"
                 Description="Compact scenario voor StackedAreaSeries."
                 ExampleComponentType="typeof(StackedAreaSeriesCompactExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedAreaSeries/StackedAreaSeriesCompactExample.razor" />
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
