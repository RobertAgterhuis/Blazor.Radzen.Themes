<RadzenTemplateForm TItem="ValueModel" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="0.75rem">
        <RadzenNumeric Name="value" TValue="int" @bind-Value="_model.Value" />
        <RadzenCustomValidator Component="value" Text="Waarde moet even zijn" Validator="ValidateEven" Popup="false" />
        <RadzenButton Text="Check" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly ValueModel _model = new() { Value = 3 };

    private void OnSubmit(ValueModel _) { }

    private bool ValidateEven() => _model.Value % 2 == 0;

    private sealed class ValueModel
    {
        public int Value { get; set; }
    }
}
