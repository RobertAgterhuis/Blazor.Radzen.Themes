<RadzenTemplateForm TItem="CustomModel" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="0.75rem">
        <RadzenTextBox Name="ticket" @bind-Value="_model.Ticket" Placeholder="Ticketcode" />
        <RadzenCustomValidator Component="ticket" Text="Code moet starten met WO-" Validator="ValidateTicket" Popup="false" />
        <RadzenButton Text="Valideren" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly CustomModel _model = new();

    private void OnSubmit(CustomModel _) { }

    private bool ValidateTicket() => _model.Ticket?.StartsWith("WO-") == true;

    private sealed class CustomModel
    {
        public string? Ticket { get; set; }
    }
}
