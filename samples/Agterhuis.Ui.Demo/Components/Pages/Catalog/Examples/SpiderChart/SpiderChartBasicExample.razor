<RadzenSpiderChart GridShape="SpiderChartGridShape.Circular" ShowMarkers="true" ShowTooltip="true">
    <RadzenSpiderSeries Data="TeamA" CategoryProperty="Metric" ValueProperty="Value" Title="Team A" />
    <RadzenSpiderColumnSeries Data="TeamB" CategoryProperty="Metric" ValueProperty="Value" Title="Team B" />
</RadzenSpiderChart>

@code {
    private static readonly IReadOnlyList<SpiderRow> TeamA =
    [
        new("Snelheid", 7),
        new("Kwaliteit", 8),
        new("Betrouwbaarheid", 6),
        new("Samenwerking", 9)
    ];

    private static readonly IReadOnlyList<SpiderRow> TeamB =
    [
        new("Snelheid", 6),
        new("Kwaliteit", 7),
        new("Betrouwbaarheid", 8),
        new("Samenwerking", 7)
    ];

    private sealed record SpiderRow(string Metric, double Value);
}
