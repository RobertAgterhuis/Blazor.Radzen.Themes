<RadzenSelectBar TValue="string"
                 Data="_options"
                 TextProperty="Text"
                 ValueProperty="Value"
                 @bind-Value="_value" />

@code {
    private string _value = "open";

    private static readonly IReadOnlyList<SelectItem> _options =
    [
        new("Open", "open"),
        new("In uitvoering", "progress"),
        new("Afgerond", "done")
    ];

    private sealed record SelectItem(string Text, string Value);
}
