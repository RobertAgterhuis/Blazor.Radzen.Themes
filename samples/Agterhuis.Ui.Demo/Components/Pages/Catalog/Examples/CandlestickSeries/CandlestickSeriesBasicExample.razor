<RadzenChart Style="height: 18rem;">
    <RadzenCandlestickSeries Data="Rows"
                             CategoryProperty="Label"
                             OpenProperty="Open"
                             HighProperty="High"
                             LowProperty="Low"
                             CloseProperty="Close" />
</RadzenChart>

@code {
    private static readonly IReadOnlyList<SeriesRow> Rows =
    [
        new("Week 1", 128, 141, 122, 137),
        new("Week 2", 137, 149, 133, 136),
        new("Week 3", 136, 145, 130, 142),
        new("Week 4", 142, 154, 139, 150)
    ];

    private sealed record SeriesRow(string Label, double Open, double High, double Low, double Close);
}

