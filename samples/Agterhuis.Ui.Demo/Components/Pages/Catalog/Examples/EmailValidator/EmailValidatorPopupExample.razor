<RadzenTemplateForm TItem="EmailModel" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="0.75rem">
        <RadzenTextBox Name="email-popup" @bind-Value="_model.Email" Placeholder="email" />
        <RadzenEmailValidator Component="email-popup" Text="Voer geldig mailadres in" Popup="true" />
        <RadzenButton Text="Controle" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly EmailModel _model = new() { Email = "invalid" };

    private void OnSubmit(EmailModel _) { }

    private sealed class EmailModel
    {
        public string? Email { get; set; }
    }
}
