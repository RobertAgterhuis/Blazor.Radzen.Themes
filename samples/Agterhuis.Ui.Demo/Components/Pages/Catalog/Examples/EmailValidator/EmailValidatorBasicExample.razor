<RadzenTemplateForm TItem="EmailModel" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="0.75rem">
        <RadzenTextBox Name="email" @bind-Value="_model.Email" Placeholder="name@example.local" />
        <RadzenEmailValidator Component="email" Text="Ongeldig e-mailadres" Popup="false" />
        <RadzenButton Text="Valideren" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly EmailModel _model = new();

    private void OnSubmit(EmailModel _) { }

    private sealed class EmailModel
    {
        public string? Email { get; set; }
    }
}
