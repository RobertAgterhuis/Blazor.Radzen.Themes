<div style="max-width:480px;">
    @if (HasApiKey)
    {
        <RadzenGoogleMap ApiKey="@ApiKey" Zoom="6" />
    }
    else
    {
        <div class="agt-stack demo-example-gap-sm" role="status" aria-live="polite">
            <RadzenIcon Icon="public" />
            <span>Compacte kaart-placeholder actief. Stel `AGT_GOOGLE_MAPS_API_KEY` in voor live kaarttegels.</span>
        </div>
    }
</div>

@code {
    private static readonly string ApiKey = Environment.GetEnvironmentVariable("AGT_GOOGLE_MAPS_API_KEY") ?? string.Empty;

    private static bool HasApiKey => !string.IsNullOrWhiteSpace(ApiKey);
}
