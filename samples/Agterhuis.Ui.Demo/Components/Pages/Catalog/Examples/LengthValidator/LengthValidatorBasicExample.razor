<RadzenTemplateForm TItem="LengthModel" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="0.75rem">
        <RadzenTextBox Name="ticket" @bind-Value="_model.Ticket" Placeholder="Ticket" />
        <RadzenLengthValidator Component="ticket" Min="4" Text="Minimaal 4 tekens" Popup="false" />
        <RadzenButton Text="Valideren" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    private readonly LengthModel _model = new();

    private void OnSubmit(LengthModel _) { }

    private sealed class LengthModel
    {
        public string? Ticket { get; set; }
    }
}
