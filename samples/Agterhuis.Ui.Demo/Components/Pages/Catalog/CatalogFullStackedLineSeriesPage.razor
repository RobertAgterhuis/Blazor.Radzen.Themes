@page "/catalog/full-stacked-line-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.FullStackedLineSeries

<PageTitle>FullStackedLineSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="FullStackedLineSeries"
               Introduction="100% gestapelde lijnseries voor share-over-time patronen."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor FullStackedLineSeries."
                 ExampleComponentType="typeof(FullStackedLineSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/FullStackedLineSeries/FullStackedLineSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
