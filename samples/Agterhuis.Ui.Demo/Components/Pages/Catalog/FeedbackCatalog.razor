@page "/catalog/feedback"

<PageTitle>Feedback (Radzen)</PageTitle>

<div class="catalog-page">
    <h1>Feedback (Radzen)</h1>

    <RadzenStack Gap="0.75rem">
        <RadzenAlert AlertStyle="AlertStyle.Primary">Primary alert</RadzenAlert>
        <RadzenAlert AlertStyle="AlertStyle.Success">Success alert</RadzenAlert>
        <RadzenAlert AlertStyle="AlertStyle.Warning">Warning alert</RadzenAlert>
        <RadzenAlert AlertStyle="AlertStyle.Danger">Danger alert</RadzenAlert>

        <RadzenBadge Text="Badge" BadgeStyle="BadgeStyle.Primary" />

        <RadzenProgressBar Value="45" ShowValue="true" />
        <RadzenProgressBarCircular Value="65" ShowValue="true" />

        <RadzenSkeleton Variant="SkeletonVariant.Text" Style="width: 12rem;" />
        <RadzenSkeleton Variant="SkeletonVariant.Circular" Style="height: 5rem; width: 5rem;" />
    </RadzenStack>
</div>
