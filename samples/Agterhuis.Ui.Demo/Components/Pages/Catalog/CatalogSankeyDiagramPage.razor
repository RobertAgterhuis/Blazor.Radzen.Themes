@page "/catalog/sankey-diagram"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.SankeyDiagram

<PageTitle>SankeyDiagram (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="SankeyDiagram"
               Introduction="Sankey-diagram voor flow tussen knooppunten."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor SankeyDiagram."
                 ExampleComponentType="typeof(SankeyDiagramBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/SankeyDiagram/SankeyDiagramBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
