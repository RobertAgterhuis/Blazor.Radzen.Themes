@page "/catalog/splitter"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Splitter

<PageTitle>Splitter (Radzen)</PageTitle>

<ComponentPage Kicker="Layout & Display"
               Title="Splitter"
               Introduction="Resizable paneellayout voor master-detail en workspace-indelingen."
               RadzenDocumentationUrl="https://blazor.radzen.com/splitter">
    <DemoExample Title="Basis"
                 Description="Twee panelen met verplaatsbare scheiding."
                 ExampleComponentType="typeof(SplitterBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Splitter/SplitterBasicExample.razor" />

    <DemoExample Title="Drie panelen"
                 Description="Indeling met drie afzonderlijke panes."
                 ExampleComponentType="typeof(SplitterThreePanesExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Splitter/SplitterThreePanesExample.razor" />

    <DemoExample Title="Met content"
                 Description="Kaartinhoud in beide splitterdelen."
                 ExampleComponentType="typeof(SplitterVerticalContentExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Splitter/SplitterVerticalContentExample.razor" />
</ComponentPage>
