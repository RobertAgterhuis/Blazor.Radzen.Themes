@page "/catalog/compare-validator"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.CompareValidator

<PageTitle>CompareValidator (Radzen)</PageTitle>

<ComponentPage Kicker="Validators"
               Title="CompareValidator"
               Introduction="Vergelijkt de waarde van een invoerveld met een referentiewaarde."
               RadzenDocumentationUrl="https://blazor.radzen.com/comparevalidator">
    <DemoExample Title="Wachtwoorden"
                 Description="Confirm password validatie."
                 ExampleComponentType="typeof(CompareValidatorBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/CompareValidator/CompareValidatorBasicExample.razor" />

    <DemoExample Title="Codes"
                 Description="Twee tekstvelden moeten overeenkomen."
                 ExampleComponentType="typeof(CompareValidatorCodeExample)"
                 SourcePath="Components/Pages/Catalog/Examples/CompareValidator/CompareValidatorCodeExample.razor" />

    <DemoExample Title="Numeriek"
                 Description="Vergelijking van twee numerieke velden."
                 ExampleComponentType="typeof(CompareValidatorNumericExample)"
                 SourcePath="Components/Pages/Catalog/Examples/CompareValidator/CompareValidatorNumericExample.razor" />
</ComponentPage>
