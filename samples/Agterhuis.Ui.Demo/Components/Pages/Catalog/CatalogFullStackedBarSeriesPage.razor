@page "/catalog/full-stacked-bar-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.FullStackedBarSeries

<PageTitle>FullStackedBarSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="FullStackedBarSeries"
               Introduction="100%-gestapelde bar-series voor aandeelvergelijking."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor FullStackedBarSeries."
                 ExampleComponentType="typeof(FullStackedBarSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/FullStackedBarSeries/FullStackedBarSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}

