@page "/catalog/column-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.ColumnSeries

<PageTitle>ColumnSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="ColumnSeries"
               Introduction="Kolomseries voor categorische vergelijking."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor ColumnSeries."
                 ExampleComponentType="typeof(ColumnSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/ColumnSeries/ColumnSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}

