@page "/catalog/contour-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.ContourSeries

<PageTitle>ContourSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="ContourSeries"
               Introduction="Contourweergave voor intensiteitspatronen."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor ContourSeries."
                 ExampleComponentType="typeof(ContourSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/ContourSeries/ContourSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}

