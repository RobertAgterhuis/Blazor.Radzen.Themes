@page "/catalog/bullet-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.BulletSeries

<PageTitle>BulletSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="BulletSeries"
               Introduction="Bullet-chart weergave voor target vs actual."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor BulletSeries."
                 ExampleComponentType="typeof(BulletSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/BulletSeries/BulletSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}

