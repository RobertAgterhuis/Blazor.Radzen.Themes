    <DemoExample Title="Chipset"
                 Description="Meerdere chips in een compacte rij."
                 ExampleComponentType="typeof(ChipSetExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Chip/ChipSetExample.razor" />

    <DemoExample Title="Disabled"
                 Description="Read-only chip voor gesloten statussen."
