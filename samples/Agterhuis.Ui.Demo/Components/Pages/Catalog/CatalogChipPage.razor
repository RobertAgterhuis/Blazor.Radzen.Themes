@page "/catalog/chip"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Chip

<PageTitle>Chip (Radzen)</PageTitle>

<ComponentPage Kicker="Forms & Inputs"
               Title="Chip"
               Introduction="Compacte labels voor status, filters en metadata."
               RadzenDocumentationUrl="https://blazor.radzen.com/chip">
    <DemoExample Title="Basis"
                 Description="Enkelvoudige chip met tekstlabel."
                 ExampleComponentType="typeof(ChipBasicExample)"
