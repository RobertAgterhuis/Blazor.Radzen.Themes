@page "/catalog/spider-chart"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.SpiderChart

<PageTitle>SpiderChart (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="SpiderChart"
               Introduction="Spider chart voor multidimensionale vergelijkingen."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor SpiderChart."
                 ExampleComponentType="typeof(SpiderChartBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/SpiderChart/SpiderChartBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
