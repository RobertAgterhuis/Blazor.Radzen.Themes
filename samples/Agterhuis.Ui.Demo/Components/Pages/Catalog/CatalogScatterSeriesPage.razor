@page "/catalog/scatter-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.ScatterSeries

<PageTitle>ScatterSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="ScatterSeries"
               Introduction="Scatterseries voor correlatie tussen numerieke waarden."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor ScatterSeries."
                 ExampleComponentType="typeof(ScatterSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/ScatterSeries/ScatterSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
