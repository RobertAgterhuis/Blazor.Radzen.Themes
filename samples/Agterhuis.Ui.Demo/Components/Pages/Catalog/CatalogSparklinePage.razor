@page "/catalog/sparkline"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Sparkline

<PageTitle>Sparkline (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="Sparkline"
               Introduction="Sparkline voor compacte trendweergave."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor Sparkline."
                 ExampleComponentType="typeof(SparklineBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Sparkline/SparklineBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
