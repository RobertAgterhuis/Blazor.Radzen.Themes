@page "/catalog/heatmap-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.HeatmapSeries

<PageTitle>HeatmapSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="HeatmapSeries"
               Introduction="Heatmap weergave voor intensiteit per cel."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor HeatmapSeries."
                 ExampleComponentType="typeof(HeatmapSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/HeatmapSeries/HeatmapSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
