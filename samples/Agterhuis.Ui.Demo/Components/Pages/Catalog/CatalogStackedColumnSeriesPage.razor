@page "/catalog/stacked-column-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.StackedColumnSeries

<PageTitle>StackedColumnSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="StackedColumnSeries"
               Introduction="Gestapelde kolomseries voor segmentvergelijking."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor StackedColumnSeries."
                 ExampleComponentType="typeof(StackedColumnSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedColumnSeries/StackedColumnSeriesBasicExample.razor" />

    <DemoExample Title="Uitgebreid"
                 Description="Uitgebreider scenario voor StackedColumnSeries."
                 ExampleComponentType="typeof(StackedColumnSeriesAdvancedExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedColumnSeries/StackedColumnSeriesAdvancedExample.razor" />

    <DemoExample Title="Compact"
                 Description="Compact scenario voor StackedColumnSeries."
                 ExampleComponentType="typeof(StackedColumnSeriesCompactExample)"
                 SourcePath="Components/Pages/Catalog/Examples/StackedColumnSeries/StackedColumnSeriesCompactExample.razor" />
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
