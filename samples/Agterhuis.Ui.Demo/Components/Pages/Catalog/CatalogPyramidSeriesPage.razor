@page "/catalog/pyramid-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.PyramidSeries

<PageTitle>PyramidSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="PyramidSeries"
               Introduction="Pyramideseries voor aflopende funnel-varianten."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor PyramidSeries."
                 ExampleComponentType="typeof(PyramidSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/PyramidSeries/PyramidSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
