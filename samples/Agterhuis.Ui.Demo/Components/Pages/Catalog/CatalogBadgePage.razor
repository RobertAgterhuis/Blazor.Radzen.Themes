@page "/catalog/badge"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Badge

<PageTitle>Badge (Radzen)</PageTitle>

<ComponentPage Kicker="Feedback & Overlays"
               Title="Badge"
               Introduction="Compacte statusindicatoren voor labels, counters en urgentie."
               RadzenDocumentationUrl="https://blazor.radzen.com/badge">
    <DemoExample Title="Basis"
                 Description="Eenvoudige badge met tekstlabel."
                 ExampleComponentType="typeof(BadgeBasicExample)"
