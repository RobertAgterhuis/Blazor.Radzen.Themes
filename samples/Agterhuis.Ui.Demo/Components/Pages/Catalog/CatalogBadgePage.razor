    <DemoExample Title="Varianten"
                 Description="Info, success en warning stijlen naast elkaar."
                 ExampleComponentType="typeof(BadgeVariantExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Badge/BadgeVariantExample.razor" />

    <DemoExample Title="Numeriek"
                 Description="Badge als compacte tellerweergave."
                 ExampleComponentType="typeof(BadgeNumberExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Badge/BadgeNumberExample.razor" />
</ComponentPage>
