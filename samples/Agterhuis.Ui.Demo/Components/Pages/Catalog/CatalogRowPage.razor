@page "/catalog/row"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Row

<PageTitle>Row (Radzen)</PageTitle>

<ComponentPage Kicker="Layout & Display"
               Title="Row"
               Introduction="Grid-rijen met responsieve kolomverdeling."
