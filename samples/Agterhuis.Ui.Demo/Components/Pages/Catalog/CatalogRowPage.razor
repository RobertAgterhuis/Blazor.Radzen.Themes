    <DemoExample Title="Twee kolommen"
                 Description="Basisverdeling met twee kolommen."
                 ExampleComponentType="typeof(RowBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Row/RowBasicExample.razor" />

    <DemoExample Title="Drie kolommen"
                 Description="Compacte verdeling in drie gelijke kolommen."
