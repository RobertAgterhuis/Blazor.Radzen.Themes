@page "/catalog/candlestick-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.CandlestickSeries

<PageTitle>CandlestickSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="CandlestickSeries"
               Introduction="OHLC-stijl visualisatie voor trendgegevens."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor CandlestickSeries."
                 ExampleComponentType="typeof(CandlestickSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/CandlestickSeries/CandlestickSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}

