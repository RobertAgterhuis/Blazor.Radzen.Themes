@page "/catalog/password"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.Password

<PageTitle>Password (Radzen)</PageTitle>

<ComponentPage Kicker="Forms & Inputs"
               Title="Password"
               Introduction="Password-invoer met basisveld, binding en disabled state."
               RadzenDocumentationUrl="https://blazor.radzen.com/password">
    <DemoExample Title="Basis"
                 Description="Standaard passwordveld."
                 ExampleComponentType="typeof(PasswordBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Password/PasswordBasicExample.razor" />

    <DemoExample Title="Gebonden waarde"
                 Description="Two-way binding inclusief lengte-indicatie."
                 ExampleComponentType="typeof(PasswordBoundExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Password/PasswordBoundExample.razor" />

    <DemoExample Title="Uitgeschakeld"
                 Description="Readonly-achtige weergave met disabled state."
                 ExampleComponentType="typeof(PasswordDisabledExample)"
                 SourcePath="Components/Pages/Catalog/Examples/Password/PasswordDisabledExample.razor" />
</ComponentPage>
