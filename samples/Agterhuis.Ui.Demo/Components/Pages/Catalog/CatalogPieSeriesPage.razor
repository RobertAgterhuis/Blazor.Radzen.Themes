@page "/catalog/pie-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.PieSeries

<PageTitle>PieSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="PieSeries"
               Introduction="Pieseries voor verdelingen en compositie."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor PieSeries."
                 ExampleComponentType="typeof(PieSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/PieSeries/PieSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
