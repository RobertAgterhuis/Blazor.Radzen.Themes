@page "/catalog/charts-advanced"

<PageTitle>Charts Advanced (Radzen)</PageTitle>

<div class="catalog-page">
    <h1>Charts Advanced (Radzen)</h1>

    <p class="agt-muted">Deze categoriepagina toont een compacte preview. Voor worked examples met live demo + code gebruik je de componentpagina's hieronder.</p>

    <ul>
        <li><RadzenLink Path="/catalog/area-series" Text="AreaSeries" /></li>
        <li><RadzenLink Path="/catalog/bar-series" Text="BarSeries" /></li>
        <li><RadzenLink Path="/catalog/box-plot-series" Text="BoxPlotSeries" /></li>
        <li><RadzenLink Path="/catalog/bubble-series" Text="BubbleSeries" /></li>
        <li><RadzenLink Path="/catalog/bullet-series" Text="BulletSeries" /></li>
        <li><RadzenLink Path="/catalog/candlestick-series" Text="CandlestickSeries" /></li>
        <li><RadzenLink Path="/catalog/chart" Text="Chart" /></li>
        <li><RadzenLink Path="/catalog/column-series" Text="ColumnSeries" /></li>
        <li><RadzenLink Path="/catalog/contour-series" Text="ContourSeries" /></li>
        <li><RadzenLink Path="/catalog/donut-series" Text="DonutSeries" /></li>
        <li><RadzenLink Path="/catalog/full-stacked-area-series" Text="FullStackedAreaSeries" /></li>
        <li><RadzenLink Path="/catalog/full-stacked-bar-series" Text="FullStackedBarSeries" /></li>
        <li><RadzenLink Path="/catalog/full-stacked-column-series" Text="FullStackedColumnSeries" /></li>
        <li><RadzenLink Path="/catalog/full-stacked-line-series" Text="FullStackedLineSeries" /></li>
        <li><RadzenLink Path="/catalog/funnel-series" Text="FunnelSeries" /></li>
        <li><RadzenLink Path="/catalog/heatmap-series" Text="HeatmapSeries" /></li>
        <li><RadzenLink Path="/catalog/high-low-series" Text="HighLowSeries" /></li>
        <li><RadzenLink Path="/catalog/horizontal-waterfall-series" Text="HorizontalWaterfallSeries" /></li>
        <li><RadzenLink Path="/catalog/line-series" Text="LineSeries" /></li>
        <li><RadzenLink Path="/catalog/stacked-area-series" Text="StackedAreaSeries" /></li>
        <li><RadzenLink Path="/catalog/stacked-bar-series" Text="StackedBarSeries" /></li>
        <li><RadzenLink Path="/catalog/stacked-column-series" Text="StackedColumnSeries" /></li>
        <li><RadzenLink Path="/catalog/stacked-line-series" Text="StackedLineSeries" /></li>
        <li><RadzenLink Path="/catalog/ohlc-series" Text="OhlcSeries" /></li>
        <li><RadzenLink Path="/catalog/pie-series" Text="PieSeries" /></li>
        <li><RadzenLink Path="/catalog/pyramid-series" Text="PyramidSeries" /></li>
        <li><RadzenLink Path="/catalog/range-area-series" Text="RangeAreaSeries" /></li>
        <li><RadzenLink Path="/catalog/range-bar-series" Text="RangeBarSeries" /></li>
        <li><RadzenLink Path="/catalog/range-column-series" Text="RangeColumnSeries" /></li>
        <li><RadzenLink Path="/catalog/sankey-diagram" Text="SankeyDiagram" /></li>
        <li><RadzenLink Path="/catalog/scatter-series" Text="ScatterSeries" /></li>
        <li><RadzenLink Path="/catalog/sparkline" Text="Sparkline" /></li>
        <li><RadzenLink Path="/catalog/spider-chart" Text="SpiderChart" /></li>
        <li><RadzenLink Path="/catalog/spider-column-series" Text="SpiderColumnSeries" /></li>
        <li><RadzenLink Path="/catalog/spider-series" Text="SpiderSeries" /></li>
        <li><RadzenLink Path="/catalog/timeline" Text="Timeline" /></li>
        <li><RadzenLink Path="/catalog/waterfall-series" Text="WaterfallSeries" /></li>
    </ul>

    @if (PreviewOnly)
    {
        <RadzenCard>Charts advanced preview (interactive rendering disabled).</RadzenCard>
    }
    else
    {
        <RadzenChart>
            <RadzenAreaSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueA" />
            <RadzenBarSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueB" />
            <RadzenColumnSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueC" />
            <RadzenLineSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueD" />
            <RadzenPieSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueA" />
            <RadzenDonutSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueB" />
            <RadzenScatterSeries Data="ScatterData" CategoryProperty="X" ValueProperty="Y" />
            <RadzenBubbleSeries Data="BubbleData" CategoryProperty="X" ValueProperty="Y" SizeProperty="R" />
            <RadzenStackedColumnSeries Data="ChartData" CategoryProperty="Label" ValueProperty="ValueA" />
            <RadzenSparkline Data="SparkData" />
        </RadzenChart>

        <RadzenSankeyDiagram Data="SankeyData" SourceProperty="Source" TargetProperty="Target" ValueProperty="Value" />
    }
</div>

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }

    private static readonly IReadOnlyList<ChartItem> ChartData =
    [
        new("Jan", 10, 8, 12, 6),
        new("Feb", 14, 11, 10, 8),
        new("Mar", 12, 13, 9, 11)
    ];

    private static readonly IReadOnlyList<ScatterItem> ScatterData =
    [
        new(1, 12),
        new(2, 18),
        new(3, 15)
    ];

    private static readonly IReadOnlyList<BubbleItem> BubbleData =
    [
        new(1, 10, 8),
        new(2, 16, 12),
        new(3, 13, 10)
    ];

    private static readonly IReadOnlyList<double> SparkData = [8, 10, 12, 11, 13, 14, 12];

    private static readonly IReadOnlyList<SankeyItem> SankeyData =
    [
        new("Lead", "Sales", 18),
        new("Sales", "Delivery", 12),
        new("Delivery", "Support", 8)
    ];

    private sealed record ChartItem(string Label, double ValueA, double ValueB, double ValueC, double ValueD);
    private sealed record ScatterItem(double X, double Y);
    private sealed record BubbleItem(double X, double Y, double R);
    private sealed record SankeyItem(string Source, string Target, double Value);
}
