@page "/catalog/line-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.LineSeries

<PageTitle>LineSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="LineSeries"
               Introduction="Line series voor klassieke trendvisualisatie."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor LineSeries."
                 ExampleComponentType="typeof(LineSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/LineSeries/LineSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
