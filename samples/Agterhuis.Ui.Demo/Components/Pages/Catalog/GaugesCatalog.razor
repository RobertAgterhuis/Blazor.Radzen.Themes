@page "/catalog/gauges"

<PageTitle>Gauges (Radzen)</PageTitle>

<div class="catalog-page">
    <h1>Gauges (Radzen)</h1>

    <p class="agt-muted">Deze categoriepagina toont een compacte preview. Voor worked examples met live demo + code gebruik je de componentpagina's hieronder.</p>

    <ul>
        <li><RadzenLink Path="/catalog/arc-gauge" Text="ArcGauge" /></li>
        <li><RadzenLink Path="/catalog/linear-gauge" Text="LinearGauge" /></li>
        <li><RadzenLink Path="/catalog/radial-gauge" Text="RadialGauge" /></li>
    </ul>

    @if (PreviewOnly)
    {
        <RadzenCard>Gauge preview (interactive rendering disabled).</RadzenCard>
    }
    else
    {
        <RadzenArcGauge>
            <RadzenArcGaugeScale Min="0" Max="100">
                <RadzenArcGaugeScaleValue Value="64" />
            </RadzenArcGaugeScale>
        </RadzenArcGauge>

        <RadzenRadialGauge Min="0" Max="100" Value="42" />
        <RadzenLinearGauge Min="0" Max="100" Value="78" />
    }
</div>

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
