@page "/catalog/spider-column-series"
@using Agterhuis.Ui.Demo.Components.Pages.Catalog.Examples.SpiderColumnSeries

<PageTitle>SpiderColumnSeries (Radzen)</PageTitle>

@if (PreviewOnly)
{
    <RadzenCard>Chart preview (interactive rendering disabled).</RadzenCard>
}
else
{
<ComponentPage Kicker="Data Visualization"
               Title="SpiderColumnSeries"
               Introduction="Spider column series voor radiale kolomvergelijkingen."
               RadzenDocumentationUrl="https://blazor.radzen.com/chart">
    <DemoExample Title="Basis"
                 Description="Basisscenario voor SpiderColumnSeries."
                 ExampleComponentType="typeof(SpiderColumnSeriesBasicExample)"
                 SourcePath="Components/Pages/Catalog/Examples/SpiderColumnSeries/SpiderColumnSeriesBasicExample.razor" />

    

    
</ComponentPage>
}

@code {
    [Parameter]
    public bool PreviewOnly { get; set; }
}
