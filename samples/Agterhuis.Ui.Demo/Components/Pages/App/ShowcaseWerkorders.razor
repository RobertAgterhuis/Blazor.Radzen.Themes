    private async Task ExportCsv(MouseEventArgs _)
    {
        var lines = new List<string> { "nummer,klant,status,bedrag" };
        lines.AddRange(FilteredOrders.Select(item => $"{item.Number},{item.CustomerName},{item.StatusLabel},{item.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)}"));
        await JS.InvokeVoidAsync("agtTheme.downloadCsv", "werkorders-export.csv", string.Join("\r\n", lines));
    }

    private async Task ExportExcel(MouseEventArgs _)
    {
        var lines = new List<string> { "nummer\tklant\tstatus\tbedrag" };
        lines.AddRange(FilteredOrders.Select(item => $"{item.Number}\t{item.CustomerName}\t{item.StatusLabel}\t{item.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)}"));
        await JS.InvokeVoidAsync("agtTheme.downloadCsv", "werkorders-export.xls", string.Join("\r\n", lines));
    }

    private string? FieldMessage(EditContext editContext, Expression<Func<object>> expression)
    {
        var fieldIdentifier = FieldIdentifier.Create(expression);
        return editContext.GetValidationMessages(fieldIdentifier).FirstOrDefault();
    }

    private IReadOnlyList<FilterChip> BuildActiveFilterChips()
    {
        var chips = new List<FilterChip>();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            chips.Add(new FilterChip("search", $"Zoek: {_searchText.Trim()}"));
        }

        if (_statusFilter.HasValue)
        {
            chips.Add(new FilterChip("status", $"Status: {StatusLabel(_statusFilter.Value)}"));
        }

        if (_priorityFilter.HasValue)
        {
            chips.Add(new FilterChip("priority", $"Prioriteit: {PriorityLabel(_priorityFilter.Value)}"));
        }

        return chips;
    }

    private async Task LoadViewsAsync()
    {
        var savedJson = await JS.InvokeAsync<string>("agtTheme.getStoredValue", ViewsStorageKey, string.Empty);
        if (string.IsNullOrWhiteSpace(savedJson))
        {
            _savedViews = [];
            return;
        }

        try
        {
            _savedViews = System.Text.Json.JsonSerializer.Deserialize<List<WorkOrderGridView>>(savedJson) ?? [];
        }
        catch
        {
            _savedViews = [];
        }
    }

    private async Task PersistViewsAsync()
    {
        var serialized = System.Text.Json.JsonSerializer.Serialize(_savedViews);
        await JS.InvokeVoidAsync("agtTheme.setStoredValue", ViewsStorageKey, serialized);
    }

    private async Task ApplyDefaultViewAsync()
    {
        var defaultViewName = await JS.InvokeAsync<string>("agtTheme.getStoredValue", DefaultViewStorageKey, string.Empty);
        if (string.IsNullOrWhiteSpace(defaultViewName))
        {
            return;
        }

        var view = _savedViews.FirstOrDefault(item => string.Equals(item.Name, defaultViewName, StringComparison.OrdinalIgnoreCase));
        if (view is null)
        {
            return;
        }

        _selectedViewName = view.Name;
        _viewNameDraft = view.Name;
        ApplyView(view);
    }

    private void ApplyView(WorkOrderGridView view)
    {
        _searchText = view.SearchText;
        _statusFilter = view.Status;
        _priorityFilter = view.Priority;
        _gridSettings = DeserializeGridSettings(view.GridSettingsJson);
    }

    private static string SerializeGridSettings(DataGridSettings? settings)
    {
        if (settings is null)
        {
            return string.Empty;
        }

        try
        {
            return System.Text.Json.JsonSerializer.Serialize(settings);
        }
        catch
        {
            return string.Empty;
        }
    }

    private static DataGridSettings? DeserializeGridSettings(string? settingsJson)
    {
        if (string.IsNullOrWhiteSpace(settingsJson))
        {
            return null;
        }

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(settingsJson);
        }
        catch
        {
            return null;
        }
    }

    private sealed record FilterChip(string Key, string Label);

    private sealed record WorkOrderGridView(string Name, string SearchText, ShowcaseWorkOrderStatus? Status, ShowcaseWorkOrderPriority? Priority)
    {
        public string GridSettingsJson { get; init; } = string.Empty;
    }
