@page "/app/instellingen"
@layout ShowcaseLayout
@implements IDisposable

@inject ShowcaseDataService DataService
@inject IServiceProvider Services

<PageTitle>Werkorders - Instellingen</PageTitle>

<AgtBreadcrumb CssClass="showcase-page__breadcrumbs" Items="Breadcrumbs" />
<AgtPageHeader Kicker="Werkorders" Title="Instellingen" Description="Sla het operationele profiel lokaal op in de in-memory service." />

<EditForm EditContext="@_editContext" class="showcase-settings">
    <DataAnnotationsValidator />

    <div class="showcase-settings__grid">
        <AgtCard CssClass="showcase-settings__card">
            <Header>Operatie</Header>
            <ChildContent>
                <div class="showcase-page__settings-grid showcase-settings__form-grid">
                    <AgtTextField Label="Contact e-mail" Value="@_draft.ContactEmail" ValueChanged="OnEmailChanged" ValueExpression="@(() => _draft.ContactEmail)" ValidationMessage="@FieldMessage(() => _draft.ContactEmail)" />
                    <AgtTextField Label="Regio" Value="@_draft.DefaultRegion" ValueChanged="OnRegionChanged" ValueExpression="@(() => _draft.DefaultRegion)" />
                    <AgtDropdown TValue="string" Label="Planningvenster" Data="@PlanningWindows" Value="@_draft.PlanningWindow" ValueChanged="OnPlanningWindowChanged" ValueExpression="@(() => _draft.PlanningWindow)" TextProperty="Label" ValueProperty="Value" />
                    <AgtSwitch Label="Automatisch monteurs toewijzen" Value="@_draft.AutoAssignTechnicians" ValueChanged="OnAutoAssignChanged" />
                    <AgtCheckbox Label="Sms-meldingen" Value="@_draft.SmsAlerts" ValueChanged="OnSmsChanged" />
                    <AgtCheckbox Label="Omzet excl. btw tonen" Value="@_draft.ShowRevenueExclVat" ValueChanged="OnVatChanged" />

                    <RadzenFormField Text="@TravelTimeLabel" Variant="Variant.Outlined" class="showcase-settings__field showcase-settings__field--full">
                        <RadzenSlider Min="10" Max="90" Step="5" @bind-Value="_draft.DefaultTravelMinutes" />
                    </RadzenFormField>

                    <div class="showcase-settings__density-row showcase-settings__field showcase-settings__field--full" role="group" aria-labelledby="showcase-density-label" aria-describedby="showcase-density-help">
                        <div class="showcase-settings__density-copy">
                            <strong id="showcase-density-label">Griddichtheid</strong>
                            <p id="showcase-density-help">Comfortabel voor overzicht, compact voor meer rijen in beeld.</p>
                        </div>
                        <AgtSwitch Label="Compacte modus" AriaLabel="Schakel griddichtheid tussen comfortabel en compact" Value="@DensityState.IsCompact" ValueChanged="OnDensityChanged" />
                    </div>
                </div>
            </ChildContent>
        </AgtCard>

        <AgtCard CssClass="showcase-settings__card">
            <Header>Beveiliging (demo)</Header>
            <ChildContent>
                <RadzenFieldset Text="Verificatie" class="showcase-settings__fieldset showcase-settings__fieldset--security">
                    <div class="showcase-settings__security-grid">
                        <AgtPassword Name="pwd"
                                     Label="Nieuw wachtwoord"
                                     AriaLabel="Nieuw wachtwoord"
                                     Placeholder="Nieuw wachtwoord"
                                     Value="@_password"
                                     ValueChanged="OnPasswordChanged" />

                        <AgtPassword Name="pwdRepeat"
                                     Label="Herhaal wachtwoord"
                                     AriaLabel="Herhaal wachtwoord"
                                     Placeholder="Herhaal wachtwoord"
                                     Value="@_passwordRepeat"
                                     ValueChanged="OnPasswordRepeatChanged" />

                        <RadzenCompareValidator Component="pwdRepeat" Value="@_password" Text="Wachtwoorden komen niet overeen" Popup="false" class="showcase-settings__password-validator" />

                        <div class="showcase-settings__security-code">
                            <label class="showcase-settings__security-code-label" for="twofa">Verificatiecode (demo)</label>
                            <p id="twofa-help" class="showcase-settings__security-code-help">Voer de 4-cijferige code in - demo, geen echte 2FA.</p>
                            <RadzenSecurityCode Name="twofa" Placeholder="0000" AriaLabel="Verificatiecode demo" />
                        </div>
                    </div>
                </RadzenFieldset>
            </ChildContent>
        </AgtCard>
    </div>

    <AgtFormActions CssClass="showcase-settings__form-actions" SaveText="Opslaan" CancelText="Herstellen" Save="Save" Cancel="Reset" />
</EditForm>

<AgtCard CssClass="showcase-settings__summary-card">
    <Header>Actieve instellingen</Header>
    <ChildContent>
        <dl class="showcase-settings__summary-list">
            <dt>Regio</dt>
            <dd>@DataService.Settings.DefaultRegion</dd>
            <dt>Contact</dt>
            <dd>@DataService.Settings.ContactEmail</dd>
            <dt>Planningvenster</dt>
            <dd>@DataService.Settings.PlanningWindow</dd>
            <dt>Auto toewijzen</dt>
            <dd>@(DataService.Settings.AutoAssignTechnicians ? "Ja" : "Nee")</dd>
            <dt>Griddichtheid</dt>
            <dd>@(DensityState.IsCompact ? "Compact" : "Comfortabel")</dd>
            <dt>Standaard reistijd</dt>
            <dd>@($"{_draft.DefaultTravelMinutes} min")</dd>
        </dl>
    </ChildContent>
</AgtCard>

@code {
    [CascadingParameter]
    public AgtDensityState DensityState { get; set; } = default!;

    private ShowcaseSettings _draft = default!;
    private EditContext _editContext = default!;
    private string _password = string.Empty;
    private string _passwordRepeat = string.Empty;

    private string TravelTimeLabel => $"Standaard reistijd ({_draft.DefaultTravelMinutes} min)";

    private IReadOnlyList<(string Text, string? Href)> Breadcrumbs =>
    [
        ("Instellingen", "/app/instellingen")
    ];

    private IReadOnlyList<object> PlanningWindows => new[]
    {
        new PlanningWindowOption("Hele dag", "Hele dag"),
        new PlanningWindowOption("Ochtend", "Ochtend"),
        new PlanningWindowOption("Middag", "Middag"),
        new PlanningWindowOption("Avond", "Avond")
    }.Cast<object>().ToList();

    protected override void OnInitialized()
    {
        DensityState ??= Services.GetRequiredService<AgtDensityState>();
        _draft = Clone(DataService.Settings);
        _draft.CompactGridDensity = DensityState.IsCompact;
        _editContext = new EditContext(_draft);
        DensityState.DensityChanged += HandleDensityChanged;
    }

    private Task OnEmailChanged(string? value)
    {
        _draft.ContactEmail = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnRegionChanged(string? value)
    {
        _draft.DefaultRegion = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnPlanningWindowChanged(string value)
    {
        _draft.PlanningWindow = value;
        return Task.CompletedTask;
    }

    private Task OnAutoAssignChanged(bool value)
    {
        _draft.AutoAssignTechnicians = value;
        return Task.CompletedTask;
    }

    private Task OnSmsChanged(bool value)
    {
        _draft.SmsAlerts = value;
        return Task.CompletedTask;
    }

    private Task OnVatChanged(bool value)
    {
        _draft.ShowRevenueExclVat = value;
        return Task.CompletedTask;
    }

    private Task OnPasswordChanged(string? value)
    {
        _password = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnPasswordRepeatChanged(string? value)
    {
        _passwordRepeat = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnDensityChanged(bool isCompact)
    {
        DensityState.SetDensity(isCompact ? AgtDensityState.Compact : AgtDensityState.Comfortable);
        _draft.CompactGridDensity = DensityState.IsCompact;
        return Task.CompletedTask;
    }

    private Task Save(MouseEventArgs _)
    {
        if (!_editContext.Validate())
        {
            return Task.CompletedTask;
        }

        _draft.CompactGridDensity = DensityState.IsCompact;
        DataService.UpdateSettings(Clone(_draft));
        return Task.CompletedTask;
    }

    private Task Reset(MouseEventArgs _)
    {
        _draft = Clone(DataService.Settings);
        DensityState.SetDensity(_draft.CompactGridDensity ? AgtDensityState.Compact : AgtDensityState.Comfortable);
        _draft.CompactGridDensity = DensityState.IsCompact;
        _editContext = new EditContext(_draft);
        return Task.CompletedTask;
    }

    private void HandleDensityChanged()
    {
        _ = InvokeAsync(() =>
        {
            _draft.CompactGridDensity = DensityState.IsCompact;
            StateHasChanged();
        });
    }

    private string? FieldMessage<TValue>(Expression<Func<TValue>> expression)
    {
        var fieldIdentifier = FieldIdentifier.Create(expression);
        return _editContext.GetValidationMessages(fieldIdentifier).FirstOrDefault();
    }

    private static ShowcaseSettings Clone(ShowcaseSettings source)
    {
        return new ShowcaseSettings
        {
            DefaultRegion = source.DefaultRegion,
            PlanningWindow = source.PlanningWindow,
            ContactEmail = source.ContactEmail,
            AutoAssignTechnicians = source.AutoAssignTechnicians,
            SmsAlerts = source.SmsAlerts,
            ShowRevenueExclVat = source.ShowRevenueExclVat,
            DefaultTravelMinutes = source.DefaultTravelMinutes,
            CompactGridDensity = source.CompactGridDensity
        };
    }

    public void Dispose()
    {
        DensityState?.DensityChanged -= HandleDensityChanged;
    }

    private sealed record PlanningWindowOption(string Value, string Label);
}