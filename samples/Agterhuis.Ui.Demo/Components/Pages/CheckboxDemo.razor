@page "/components/forms/checkbox"

<PageTitle>Checkbox</PageTitle>

<div class="agt-page agt-stack">
    <AgtPageHeader Title="AgtCheckbox" Description="Checkbox wrapper met verplichte, klikbare labeltekst." />

    <AgtCard>
        <ChildContent>
            <AgtCheckbox @bind-Value="_isChecked" Label="Ik ga akkoord" />
            <p>Status: @(_isChecked ? "aangevinkt" : "niet aangevinkt")</p>
        </ChildContent>
    </AgtCard>
</div>

@code {
    private bool _isChecked;
}
