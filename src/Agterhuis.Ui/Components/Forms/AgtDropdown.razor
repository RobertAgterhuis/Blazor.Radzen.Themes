@typeparam TValue

<div class="agt-field-wrapper @CssClass"
    role="group"
    aria-describedby="@ResolvedDescribedBy"
    aria-invalid="@(!string.IsNullOrWhiteSpace(ValidationMessage))">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <RadzenLabel Text="@Label" Component="@ResolvedName" class="agt-field-wrapper__label" />
    }
    else if (!string.IsNullOrWhiteSpace(AriaLabel))
    {
        <label class="agt-sr-only" for="@ResolvedName">@AriaLabel</label>
    }

    <RadzenDropDown TValue="TValue"
                    Data="@Data"
                    Value="@Value"
                    ValueChanged="@ValueChanged"
                    Change="@Change"
                    Open="@Open"
                    Close="@Close"
                    ValueExpression="@ValueExpression"
                    Name="@ResolvedName"
                    TextProperty="@TextProperty"
                    ValueProperty="@ValueProperty"
                    Placeholder="@Placeholder"
                    Disabled="@Disabled"
                    AllowClear="@AllowClear"
                    AriaLabel="@AriaLabel"
                    class="@CombinedClass"
                    Style="@Style" />

    @if (!string.IsNullOrWhiteSpace(ValidationMessage))
    {
        <p id="@MessageId" class="agt-field-wrapper__message" role="status" aria-live="polite">@ValidationMessage</p>
    }
</div>

@code {
    [Parameter]
    public IEnumerable<object>? Data { get; set; }

    [Parameter]
    public TValue Value { get; set; } = default!;

    [Parameter]
    public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<object?> Change { get; set; }

    [Parameter]
    public EventCallback Open { get; set; }

    [Parameter]
    public EventCallback Close { get; set; }

    [Parameter]
    public Expression<Func<TValue>>? ValueExpression { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public string? TextProperty { get; set; }

    [Parameter]
    public string? ValueProperty { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool AllowClear { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? ValidationMessage { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private readonly string _fallbackName = $"agt-dropdown-{Guid.NewGuid():N}";
    private readonly string _messageId = $"agt-dropdown-msg-{Guid.NewGuid():N}";

    private string ResolvedName => string.IsNullOrWhiteSpace(Name) ? _fallbackName : Name;

    private string MessageId => _messageId;

    private string? ResolvedDescribedBy => string.IsNullOrWhiteSpace(ValidationMessage) ? null : MessageId;

    private string CombinedClass => "agt-dropdown";

    protected override void OnParametersSet()
    {
        System.Diagnostics.Debug.Assert(
            !string.IsNullOrWhiteSpace(Label) || !string.IsNullOrWhiteSpace(AriaLabel),
            "AgtDropdown requires Label or AriaLabel for accessibility.");
    }
}
