<div class="agt-field-wrapper @CssClass" role="group">
    <label class="agt-switch">
        <span class="agt-switch__label" @onclick="OnLabelClicked" @onclick:stopPropagation="true">@ResolvedLabel</span>
        <RadzenSwitch TValue="bool"
                      Name="@ResolvedName"
                      Value="@Value"
                      ValueChanged="OnSwitchChanged"
                      Change="OnSwitchChanged"
                      Disabled="@Disabled"
                      InputAttributes="@ResolvedInputAttributes" />
        <span class="agt-switch__state" @onclick="OnLabelClicked" @onclick:stopPropagation="true" aria-live="polite">@(Value ? OnText : OffText)</span>
    </label>
</div>

@code {
    [Parameter]
    public bool Value { get; set; }

    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public string OnText { get; set; } = "Aan";

    [Parameter]
    public string OffText { get; set; } = "Uit";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    private readonly string _fallbackName = $"agt-switch-{Guid.NewGuid():N}";

    private string ResolvedName => string.IsNullOrWhiteSpace(Name) ? _fallbackName : Name;

    private string ResolvedLabel => string.IsNullOrWhiteSpace(Label) ? AriaLabel ?? string.Empty : Label;

    private IReadOnlyDictionary<string, object> ResolvedInputAttributes =>
        string.IsNullOrWhiteSpace(AriaLabel)
            ? new Dictionary<string, object>()
            : new Dictionary<string, object> { ["aria-label"] = AriaLabel! };

    protected override void OnParametersSet()
    {
        System.Diagnostics.Debug.Assert(
            !string.IsNullOrWhiteSpace(Label) || !string.IsNullOrWhiteSpace(AriaLabel),
            "AgtSwitch requires Label or AriaLabel for accessibility.");
    }

    private async Task OnLabelClicked()
    {
        if (Disabled)
        {
            return;
        }

        await ValueChanged.InvokeAsync(!Value);
    }

    private Task OnSwitchChanged(bool value)
        => ValueChanged.InvokeAsync(value);
}
