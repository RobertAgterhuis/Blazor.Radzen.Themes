<div class="agt-field-wrapper @CssClass"
     role="group"
     aria-describedby="@ResolvedDescribedBy"
     aria-invalid="@(!string.IsNullOrWhiteSpace(ValidationMessage))">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <RadzenLabel Text="@Label" Component="@ResolvedName" class="agt-field-wrapper__label" />
    }
    else if (!string.IsNullOrWhiteSpace(AriaLabel))
    {
        <label class="agt-sr-only" for="@ResolvedName">@AriaLabel</label>
    }

    <div class="agt-password__input-wrap">
        @if (IsVisible)
        {
            <input id="@ResolvedName"
                   name="@ResolvedName"
                   type="text"
                   value="@Value"
                   placeholder="@Placeholder"
                   class="agt-password__text-input"
                   aria-label="@AriaLabel"
                   disabled="@Disabled"
                   readonly="@ReadOnly"
                   @oninput="OnVisibleInput" />
        }
        else
        {
            <RadzenPassword Value="@Value"
                            ValueChanged="@ValueChanged"
                            ValueExpression="@ValueExpression"
                            Name="@ResolvedName"
                            Placeholder="@Placeholder"
                            Disabled="@Disabled"
                            ReadOnly="@ReadOnly"
                            AriaLabel="@AriaLabel"
                            class="agt-password"
                            Style="@Style" />
        }

        <button type="button"
                class="agt-password__toggle"
                aria-label="@(IsVisible ? HideButtonLabel : ShowButtonLabel)"
                aria-pressed="@IsVisible"
                disabled="@Disabled"
                @onclick="ToggleVisibility">
            @(IsVisible ? "visibility_off" : "visibility")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(ValidationMessage))
    {
        <p id="@MessageId" class="agt-field-wrapper__message" role="status" aria-live="polite">@ValidationMessage</p>
    }
</div>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public string ShowButtonLabel { get; set; } = "Toon wachtwoord";

    [Parameter]
    public string HideButtonLabel { get; set; } = "Verberg wachtwoord";

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? ValidationMessage { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private readonly string _fallbackName = $"agt-password-{Guid.NewGuid():N}";
    private readonly string _messageId = $"agt-password-msg-{Guid.NewGuid():N}";

    private bool IsVisible { get; set; }

    private string ResolvedName => string.IsNullOrWhiteSpace(Name) ? _fallbackName : Name;

    private string MessageId => _messageId;

    private string? ResolvedDescribedBy => string.IsNullOrWhiteSpace(ValidationMessage) ? null : MessageId;

    protected override void OnParametersSet()
    {
        System.Diagnostics.Debug.Assert(
            !string.IsNullOrWhiteSpace(Label) || !string.IsNullOrWhiteSpace(AriaLabel),
            "AgtPassword requires Label or AriaLabel for accessibility.");
    }

    private Task ToggleVisibility()
    {
        IsVisible = !IsVisible;
        return Task.CompletedTask;
    }

    private async Task OnVisibleInput(ChangeEventArgs args)
    {
        var nextValue = args.Value?.ToString();
        await ValueChanged.InvokeAsync(nextValue);
    }
}
