@using Agterhuis.Ui.Designer.Model

<section class="designer-startscreen" aria-label="Designer startscherm">
    <header class="designer-startscreen__hero">
        <h1>Wat wil je ontwerpen?</h1>
        <p>Kies een doelgericht startpunt en bouw daarna verder in de editor.</p>
    </header>

    <section class="designer-startscreen__templates" aria-label="Templates">
        <section class="designer-startscreen__group" aria-label="Basis">
            <h2 class="designer-startscreen__group-title">Basis</h2>
            <div class="designer-startscreen__group-grid">
                @foreach (var option in BasicOptions)
                {
                    <button type="button" class="designer-template-card" @onclick="() => OnTemplateSelected.InvokeAsync(option.Kind)">
                        <div class="designer-template-card__head">
                            <RadzenIcon Icon="@option.Icon" />
                            <h3>@option.Title</h3>
                            @if (option.IsPopular)
                            {
                                <span class="designer-template-card__badge">Populair</span>
                            }
                        </div>
                        <div class="designer-template-card__label">
                            <p>@option.Description</p>
                        </div>
                        <div class="designer-template-card__preview">
                            <DesignRenderer Page="@option.PreviewPage" Registry="Registry" />
                        </div>
                    </button>
                }
            </div>
        </section>

        @if (AppPatternOptions.Count > 0)
        {
            <section class="designer-startscreen__group" aria-label="App-patronen">
                <h2 class="designer-startscreen__group-title">App-patronen</h2>
                <div class="designer-startscreen__group-grid">
                    @foreach (var option in AppPatternOptions)
                    {
                        <button type="button" class="designer-template-card" @onclick="() => OnTemplateSelected.InvokeAsync(option.Kind)">
                            <div class="designer-template-card__head">
                                <RadzenIcon Icon="@option.Icon" />
                                <h3>@option.Title</h3>
                                @if (option.IsPopular)
                                {
                                    <span class="designer-template-card__badge">Populair</span>
                                }
                            </div>
                            <div class="designer-template-card__label">
                                <p>@option.Description</p>
                            </div>
                            <div class="designer-template-card__preview">
                                <DesignRenderer Page="@option.PreviewPage" Registry="Registry" />
                            </div>
                        </button>
                    }
                </div>
            </section>
        }
    </section>

    <section class="designer-startscreen__recent" aria-label="Recente ontwerpen">
        <h2>Recente ontwerpen</h2>
        @if (RecentDocuments.Count == 0)
        {
            <p>Er zijn nog geen opgeslagen ontwerpen.</p>
        }
        else
        {
            <ul>
                @foreach (var document in RecentDocuments.OrderByDescending(static item => item.LastModified).Take(8))
                {
                    <li>
                        <div>
                            <strong>@document.Name</strong>
                            <span>@document.LastModified.ToLocalTime().ToString("g")</span>
                        </div>
                        <RadzenButton Text="Open" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="() => OnDocumentSelected.InvokeAsync(document.Name)" />
                    </li>
                }
            </ul>
        }
    </section>

    <section class="designer-startscreen__import" aria-label="Importeren">
        <h2>Bestand importeren</h2>
        <p>Importeer een bestaand .agtdesign-bestand.</p>
        <label class="designer-startscreen__import-button">
            <span>Bestand importeren</span>
            <InputFile class="designer-file-input" accept=".agtdesign,.json,application/json" OnChange="OnImportRequested" />
        </label>
    </section>
</section>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<DesignDocumentTemplates.TemplateDefinition> TemplateOptions { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<DesignListItem> RecentDocuments { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<DesignDocumentTemplateKind> OnTemplateSelected { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnDocumentSelected { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<InputFileChangeEventArgs> OnImportRequested { get; set; }

    [Parameter]
    public Agterhuis.Ui.Designer.Registry.DesignerComponentRegistry? Registry { get; set; }

    private IReadOnlyList<TemplateOption> ResolvedOptions => TemplateOptions
        .OrderBy(static definition => definition.Kind switch
        {
            DesignDocumentTemplateKind.Blank or DesignDocumentTemplateKind.FormPage or DesignDocumentTemplateKind.ListCrud => 0,
            DesignDocumentTemplateKind.MasterDetail or DesignDocumentTemplateKind.Wizard or DesignDocumentTemplateKind.Dashboard => 1,
            DesignDocumentTemplateKind.SidebarApp or DesignDocumentTemplateKind.SettingsPage or DesignDocumentTemplateKind.DetailPage => 2,
            DesignDocumentTemplateKind.KanbanBoard or DesignDocumentTemplateKind.LoginPage or DesignDocumentTemplateKind.TableWithFilters => 3,
            _ => 4
        })
        .Select(static definition =>
        {
            var previewDocument = DesignDocumentTemplates.Create(definition.Kind, "Preview");
            return new TemplateOption(
                definition.Kind,
                GetIcon(definition.Kind),
                GetTitle(definition.Kind),
                GetDescription(definition.Kind, definition.Description),
                IsPopular(definition.Kind),
                previewDocument.Pages.First());
        })
        .ToArray();

    private static readonly DesignDocumentTemplateKind[] BasicKinds =
    [
        DesignDocumentTemplateKind.Blank,
        DesignDocumentTemplateKind.FormPage,
        DesignDocumentTemplateKind.ListCrud,
        DesignDocumentTemplateKind.Dashboard
    ];

    private IReadOnlyList<TemplateOption> BasicOptions => ResolvedOptions
        .Where(static option => BasicKinds.Contains(option.Kind))
        .ToArray();

    private IReadOnlyList<TemplateOption> AppPatternOptions => ResolvedOptions
        .Where(static option => !BasicKinds.Contains(option.Kind))
        .ToArray();

    private static string GetIcon(DesignDocumentTemplateKind kind) => kind switch
    {
        DesignDocumentTemplateKind.Blank => "draft",
        DesignDocumentTemplateKind.FormPage => "edit_note",
        DesignDocumentTemplateKind.ListCrud => "table_rows",
        DesignDocumentTemplateKind.MasterDetail => "view_sidebar",
        DesignDocumentTemplateKind.Wizard => "assistant",
        DesignDocumentTemplateKind.Dashboard => "dashboard",
        DesignDocumentTemplateKind.SidebarApp => "web",
        DesignDocumentTemplateKind.SettingsPage => "settings",
        DesignDocumentTemplateKind.DetailPage => "description",
        DesignDocumentTemplateKind.KanbanBoard => "view_kanban",
        DesignDocumentTemplateKind.LoginPage => "login",
        DesignDocumentTemplateKind.TableWithFilters => "filter_list",
        _ => "widgets"
    };

    private static string GetTitle(DesignDocumentTemplateKind kind) => kind switch
    {
        DesignDocumentTemplateKind.Blank => "Leeg canvas",
        DesignDocumentTemplateKind.FormPage => "Invulformulier",
        DesignDocumentTemplateKind.ListCrud => "Overzichtstabel",
        DesignDocumentTemplateKind.MasterDetail => "Overzicht + detail",
        DesignDocumentTemplateKind.Wizard => "Stappenwizard",
        DesignDocumentTemplateKind.Dashboard => "Dashboard",
        DesignDocumentTemplateKind.SidebarApp => "Sidebar app",
        DesignDocumentTemplateKind.SettingsPage => "Instellingen",
        DesignDocumentTemplateKind.DetailPage => "Detailpagina",
        DesignDocumentTemplateKind.KanbanBoard => "Kanbanbord",
        DesignDocumentTemplateKind.LoginPage => "Loginpagina",
        DesignDocumentTemplateKind.TableWithFilters => "Tabel met filters",
        _ => "Template"
    };

    private static string GetDescription(DesignDocumentTemplateKind kind, string fallback) => kind switch
    {
        DesignDocumentTemplateKind.Blank => "Begin met een leeg canvas.",
        DesignDocumentTemplateKind.FormPage => "Invoerformulier met velden en acties.",
        DesignDocumentTemplateKind.ListCrud => "Overzichtstabel met zoek- en filteropties.",
        DesignDocumentTemplateKind.MasterDetail => "Lijst links, detail rechts.",
        DesignDocumentTemplateKind.Wizard => "Stap-voor-stap wizard met voortgang.",
        DesignDocumentTemplateKind.Dashboard => "KPI-kaarten en data-overzichten.",
        DesignDocumentTemplateKind.SidebarApp => "Volledige app met zijmenu-navigatie.",
        DesignDocumentTemplateKind.SettingsPage => "Instellingenpagina met secties.",
        DesignDocumentTemplateKind.DetailPage => "Detailweergave met context en samenvatting.",
        DesignDocumentTemplateKind.KanbanBoard => "Kanban-overzicht met kolommen per status.",
        DesignDocumentTemplateKind.LoginPage => "Inlogpagina met branding en call-to-action.",
        DesignDocumentTemplateKind.TableWithFilters => "Gefilterde tabel met zoekbalk.",
        _ => fallback
    };

    private static bool IsPopular(DesignDocumentTemplateKind kind)
        => kind is DesignDocumentTemplateKind.SidebarApp or DesignDocumentTemplateKind.Dashboard;

    private sealed record TemplateOption(
        DesignDocumentTemplateKind Kind,
        string Icon,
        string Title,
        string Description,
        bool IsPopular,
        DesignPage PreviewPage);
}
