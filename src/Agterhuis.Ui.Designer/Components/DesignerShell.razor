<div class="designer-page" @onkeydown="OnPageKeyDown" tabindex="0">
    <div class="designer-screenreader-status" role="status" aria-live="polite">@_liveAnnouncement</div>

    @if (_showOnboardingOverlay)
    {
        <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Welkom in de designer">
            <div class="designer-modal">
                <h3>Welkom in de designer</h3>
                <ol class="designer-onboarding-list">
                    <li>Kies een template of begin leeg.</li>
                    <li>Sleep of klik componenten uit het palet naar de canvas.</li>
                    <li>Pas eigenschappen aan in het rechterpaneel.</li>
                </ol>
                <div class="designer-modal__actions">
                    <RadzenButton Text="Begrepen" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="DismissOnboardingAsync" />
                </div>
            </div>
        </div>
    }

    @if (_showStartScreen)
    {
        <DesignerStartScreen TemplateOptions="TemplateOptions"
                             RecentDocuments="_savedDocuments"
                             OnTemplateSelected="OnTemplateStartSelected"
                             OnDocumentSelected="OpenSavedFromStartAsync"
                             OnImportRequested="OnStartScreenImportRequested"
                             Registry="Registry" />
    }
    else
    {
        @if (_showDraftRecoveryChoice)
        {
            <div class="designer-recovery-banner" role="status" aria-live="polite">
                Er is een lokale conceptversie gevonden die nieuwer is dan de serverversie.
                <span class="designer-toolbar__group">
                    <RadzenButton Text="Lokale draft gebruiken" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="UseLocalDraftAsync" />
                    <RadzenButton Text="Serverversie laden" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="UseServerVersionAsync" />
                </span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_offlineWarning))
        {
            <div class="designer-recovery-banner" role="status" aria-live="polite">
                @_offlineWarning
            </div>
        }

        @if (_hasRecoveredDraft)
        {
            <div class="designer-recovery-banner" role="status" aria-live="polite">
                Hersteld werk uit localStorage gevonden. Sla het bestand op om het definitief te bewaren.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_uiFeedback))
        {
            <div class="designer-feedback" role="status" aria-live="polite">@_uiFeedback</div>
        }

        @if (_fileMenuOpen || _settingsMenuOpen || _pageMenuIndex is not null)
        {
            <div class="designer-menu-backdrop" @onclick="CloseAllMenus"></div>
        }

        <header class="designer-toolbar" aria-label="Designer toolbar">
            <div class="designer-toolbar__group">
                <button type="button" class="designer-menu-toggle" aria-expanded="@_fileMenuOpen" @onclick="ToggleFileMenu">Bestand</button>
                @if (_fileMenuOpen)
                {
                    <div class="designer-menu" role="menu" aria-label="Bestand">
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OpenNewDocumentDialog">Nieuw</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnOpenDocument">Openen (bestand)</button>
                        <label class="designer-menu__item designer-menu__item--file" role="menuitem">
                            Importeren
                            <InputFile class="designer-file-input" accept=".agtdesign,.json,application/json" OnChange="OnDesignFileChanged" />
                        </label>
                        <div class="designer-menu__row">
                            <label for="designer-saved-docs">Open opgeslagen</label>
                            <RadzenDropDown id="designer-saved-docs" TValue="string" Data="SavedDocumentNames" Value="@_selectedSavedName" Placeholder="Selecteer" Change="OnSavedSelectionChanged" />
                        </div>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnSaveDocument">Opslaan</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OpenVersionHistoryAsync">Versiegeschiedenis</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnExportDocument" disabled="@HasErrorIssues">Exporteren</button>
                    </div>
                }
            </div>

            <div class="designer-toolbar__group">
                <button type="button" class="designer-save-button" @onclick="OnSaveDocument">
                    <RadzenIcon Icon="save" />
                    <span>Opslaan</span>
                    @if (_commands.IsDirty)
                    {
                        <span class="designer-save-button__dirty-dot" aria-hidden="true"></span>
                    }
                </button>
                <RadzenButton Text="Undo" Icon="undo" Disabled="@(!_commands.CanUndo)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="OnUndo" />
                <RadzenButton Text="Redo" Icon="redo" Disabled="@(!_commands.CanRedo)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="OnRedo" />
            </div>

            <div class="designer-toolbar__group">
                <RadzenButton Text="@(_previewMode ? "Bewerken" : "Preview")" Icon="@(_previewMode ? "edit" : "visibility")" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="TogglePreviewMode" />

                <div class="designer-viewport-toggle" role="group" aria-label="Viewport">
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "mobile", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("mobile")' aria-label="Mobiel">
                        <RadzenIcon Icon="smartphone" />
                    </button>
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "tablet", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("tablet")' aria-label="Tablet">
                        <RadzenIcon Icon="tablet" />
                    </button>
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "desktop", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("desktop")' aria-label="Desktop">
                        <RadzenIcon Icon="desktop_windows" />
                    </button>
                </div>

                <button type="button" class="designer-menu-toggle" aria-expanded="@_settingsMenuOpen" @onclick="ToggleSettingsMenu" disabled="@_previewMode">Instellingen</button>
                @if (_settingsMenuOpen)
                {
                    <div class="designer-menu" role="menu" aria-label="Instellingen">
                        <div class="designer-menu__row">
                            <label for="designer-theme-picker">Theme</label>
                            <RadzenDropDown id="designer-theme-picker" TValue="string" Data="CanvasThemeOptions" Value="@_canvasTheme" Change="OnCanvasThemeChanged" />
                        </div>
                        <div class="designer-menu__row">
                            <AgtCommandPalette />
                        </div>
                    </div>
                }
            </div>
        </header>

        <section class="designer-page-tabs" aria-label="Pagina's">
            <div class="designer-page-tabs__scroll">
                @for (var pageIndex = 0; pageIndex < _commands.Document.Pages.Count; pageIndex++)
                {
                    var page = _commands.Document.Pages[pageIndex];
                    var isActive = pageIndex == ActivePageIndex;

                    @if (_previewMode)
                    {
                        <button type="button" class="designer-page-tab__button @(isActive ? "designer-page-tab--active" : null)" @onclick="() => SelectPage(pageIndex)">@GetPageLabel(page)</button>
                    }
                    else
                    {
                        <div class="designer-page-tab @(isActive ? "designer-page-tab--active" : null)"
                             draggable="true"
                             @ondragstart="() => OnPageDragStart(pageIndex)"
                             @ondragover="OnPageDragOver"
                             @ondrop="() => OnPageDropAsync(pageIndex)"
                             @ondragend="OnPageDragEnd">
                            <button type="button" class="designer-page-tab__button" @onclick="() => SelectPage(pageIndex)">@GetPageLabel(page)</button>
                            @if (_editingPageIndex == pageIndex)
                            {
                                <input class="designer-page-tab__rename"
                                       value="@_editingPageTitle"
                                       @oninput="args => _editingPageTitle = args.Value?.ToString()"
                                       @onkeydown="args => OnRenameKeyDown(args, pageIndex)"
                                       @onblur="() => SaveRenamePageAsync(pageIndex)" />
                            }
                            <div class="designer-page-tab__menu-wrap">
                                <button type="button" class="designer-page-tab__menu" aria-expanded="@(_pageMenuIndex == pageIndex)" aria-label="Pagina acties" @onclick="() => TogglePageMenu(pageIndex)">
                                    <RadzenIcon Icon="more_horiz" />
                                </button>
                                @if (_pageMenuIndex == pageIndex)
                                {
                                    <div class="designer-page-tab__menu-list" role="menu">
                                        <button type="button" class="designer-page-tab__action" role="menuitem" @onclick="() => BeginRenamePage(pageIndex)">Hernoemen</button>
                                        <button type="button" class="designer-page-tab__action" role="menuitem" @onclick="() => DuplicatePageAsync(pageIndex)">Dupliceren</button>
                                        <button type="button" class="designer-page-tab__action designer-page-tab__action--danger" role="menuitem" @onclick="() => RemovePageAsync(pageIndex)" disabled="@(_commands.Document.Pages.Count <= 1)">Verwijderen</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            @if (!_previewMode)
            {
                <RadzenButton class="designer-page-tabs__add" Text="+" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="OnAddPageAsync" />
            }
        </section>

        @if (!_previewMode)
        {
            <div class="designer-route-preview" title="Routes in export">Routes: @RoutePreview</div>
        }

        <div class="designer-grid">
            @if (_previewMode)
            {
                <section class="designer-panel designer-panel--canvas designer-panel--preview" aria-label="Preview canvas">
                    <div class="designer-canvas-frame" style="@CanvasFrameStyle">
                        <div class="designer-canvas" data-agt-theme="@_canvasTheme">
                            <DesignRenderer Page="@ActivePage" Registry="@Registry" />
                        </div>
                    </div>
                </section>
            }
            else
            {
                <aside class="designer-panel designer-panel--palette @(_paletteCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Componentenpalet">
                    <div class="designer-panel__header">
                        <h2>Palet</h2>
                        <button type="button" class="designer-panel__toggle" aria-expanded="@(!_paletteCollapsed)" @onclick="TogglePaletteCollapsed">
                            <RadzenIcon Icon="@(_paletteCollapsed ? "chevron_right" : "chevron_left")" />
                        </button>
                    </div>

                    @if (!_paletteCollapsed)
                    {
                        <input class="designer-filter" type="text" placeholder="Filter componenten..." value="@_paletteFilter" @oninput="OnPaletteFilterChanged" />
                        @foreach (var category in PaletteByCategory)
                        {
                            <section class="designer-category">
                                <h3>@category.Key</h3>
                                @foreach (var descriptor in category.Value)
                                {
                                        <button type="button"
                                            class="designer-palette-item"
                                            draggable="true"
                                            @ondragstart='args => OnPaletteDragStart(args, descriptor)'
                                            @ondragend="OnDragEnd"
                                            @onclick="() => OnPaletteItemClickedAsync(descriptor.ComponentType)"
                                            title="@($"{descriptor.DesignerDisplayName ?? descriptor.DisplayName} - {descriptor.DesignerDescription ?? "Component in de designer"} ({descriptor.ComponentType})")">
                                        <RadzenIcon Icon="@(descriptor.DesignerIcon ?? descriptor.Icon)" />
                                        <span>@(descriptor.DesignerDisplayName ?? descriptor.DisplayName)</span>
                                        <small class="designer-palette-item__meta">@descriptor.ComponentType</small>
                                    </button>
                                }
                            </section>
                        }
                    }
                </aside>

                @if (!_paletteCollapsed)
                {
                    <div class="designer-divider designer-divider--vertical" data-divider="palette-canvas" aria-label="Resize palette"></div>
                }

                <section class="designer-panel designer-panel--canvas" aria-label="Canvas">
                    <div class="designer-breadcrumb" aria-live="polite">@SelectionBreadcrumb</div>
                    <div class="designer-canvas-frame" style="@CanvasFrameStyle">
                        <div class="designer-canvas" data-agt-theme="@_canvasTheme" @ref="_canvasRef">
                            @if (ActivePage.Nodes.Count == 0)
                            {
                                <div class="designer-canvas--empty">
                                    <AgtEmptyState Title="Begin met ontwerpen" Description="Sleep een component hierheen of klik op een component in het palet links." Icon="widgets" />
                                </div>
                            }
                            else
                            {
                                <div class="@GetRootDropzoneClass(ActivePage.Nodes.Count)"
                                     @ondragenter='() => OnDropZoneDragEnter($"root-{ActivePage.Nodes.Count}")'
                                     @ondragleave='() => OnDropZoneDragLeave($"root-{ActivePage.Nodes.Count}")'
                                     @ondragover='args => OnDropZoneDragOver(args, $"root-{ActivePage.Nodes.Count}")'
                                     @ondrop='() => OnDropRequested(new DesignerDropTarget(DesignNodeLocation.Root(ActivePage.Nodes.Count)), $"root-{ActivePage.Nodes.Count}")'
                                     title="Drop op canvas"></div>
                                @for (var index = 0; index < ActivePage.Nodes.Count; index++)
                                {
                                    var node = ActivePage.Nodes[index];
                                    <DesignerCanvasNode Node="node"
                                                       Registry="@Registry"
                                                       SelectedNodeId="@_selectedNodeId"
                                                       SelectNode="OnSelectNode"
                                                       StartDrag="OnDragStart"
                                                       EndDrag="OnDragEnd"
                                                       DropNode="OnDropRequested"
                                                       AddNodeRequested="OnInlineAddRequested"
                                                       IsDragActive="IsDragActive"
                                                       HoverDropzoneId="@_hoverDropzoneId"
                                                       DropzoneDragEnter="OnDropZoneDragEnter"
                                                       DropzoneDragLeave="OnDropZoneDragLeave" />
                                    <div class="@GetRootDropzoneClass(index + 1)"
                                         @ondragenter='() => OnDropZoneDragEnter($"root-{index + 1}")'
                                         @ondragleave='() => OnDropZoneDragLeave($"root-{index + 1}")'
                                         @ondragover='args => OnDropZoneDragOver(args, $"root-{index + 1}")'
                                         @ondrop='() => OnDropRequested(new DesignerDropTarget(DesignNodeLocation.Root(index + 1)), $"root-{index + 1}")'
                                         title="Drop op canvas"></div>
                                }

                                <div class="designer-quick-layout">
                                    <label for="designer-layout-split">Voeg rij toe</label>
                                    <select id="designer-layout-split" value="@_selectedRowLayout" @onchange="OnRowLayoutChanged">
                                        <option value="12">1 kolom (12)</option>
                                        <option value="6+6">2 kolommen (6+6)</option>
                                        <option value="4+4+4">3 kolommen (4+4+4)</option>
                                        <option value="4+8">Zijbalk + hoofdpaneel (4+8)</option>
                                        <option value="8+4">Hoofdpaneel + zijbalk (8+4)</option>
                                    </select>
                                    <RadzenButton Text="Rij toevoegen" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="AddRowLayoutAsync" />
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <div class="designer-divider designer-divider--vertical" data-divider="canvas-property" aria-label="Resize properties"></div>

                <aside class="designer-panel designer-panel--properties" aria-label="Properties panel">
                    <PropertyPanel Page="@ActivePage"
                                   HasDuplicateRoute="@HasDuplicateActiveRoute"
                                   CanvasTheme="@_canvasTheme"
                                   ThemeOptions="CanvasThemeOptions"
                                   DataModel="@_commands.Document.DataModel"
                                   SelectedNode="SelectedNode"
                                   SelectedDescriptor="SelectedDescriptor"
                                   SetPageRoute="OnPageRouteChanged"
                                   SetPageTitle="OnPageTitleChanged"
                                   SetCanvasTheme="OnCanvasThemeChanged"
                                   SetNodeParameter="OnNodeParameterChanged"
                                   SetNodeLayoutSlot="OnNodeLayoutSlotChanged"
                                   AddColumnNode="OnAddColumnNode"
                                   RemoveColumnNode="OnRemoveColumnNode"
                                   SplitColumnNode="OnSplitColumnNode"
                                   UpsertColumnNodes="OnUpsertColumnNodes"
                                   SetDataGridPaging="OnSetDataGridPaging" />
                </aside>

                <aside class="designer-panel designer-panel--data @(_dataCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Data panel">
                    <div class="designer-panel__header">
                        <h2>Data</h2>
                        <button type="button" class="designer-panel__toggle" aria-expanded="@(!_dataCollapsed)" @onclick="ToggleDataCollapsed">
                            <RadzenIcon Icon="@(_dataCollapsed ? "chevron_left" : "chevron_right")" />
                        </button>
                    </div>
                    @if (!_dataCollapsed)
                    {
                        <DesignerDataPanel DataModel="@_commands.Document.DataModel" SelectedEntityName="@_selectedEntityName" SelectedEntityNameChanged="OnSelectedEntityChanged" GenerateFormRequested="OnGenerateFormRequested" ImportEntitiesRequested="OnImportEntitiesRequested" />
                    }
                </aside>

                <aside class="designer-panel designer-panel--tree @(_treeCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Structuurboom">
                    <div class="designer-panel__header">
                        <h2>Structuur</h2>
                        <button type="button" class="designer-panel__toggle" aria-expanded="@(!_treeCollapsed)" @onclick="ToggleTreeCollapsed">
                            <RadzenIcon Icon="@(_treeCollapsed ? "chevron_left" : "chevron_right")" />
                        </button>
                    </div>

                    @if (!_treeCollapsed)
                    {
                        <div class="designer-tree" aria-label="Structuurboom items">
                            @RenderTreeNodes(TreeRoots)
                        </div>

                        <section class="designer-issues" aria-label="Issues panel">
                            <button type="button" class="designer-issues__header" @onclick="() => _issuesExpanded = !_issuesExpanded" aria-expanded="@_issuesExpanded">
                                <span>Issues</span>
                                <span>@($"{ErrorCount} fouten · {WarningCount} waarschuwingen · {InfoCount} info")</span>
                            </button>

                            @if (_issuesExpanded)
                            {
                                <fieldset class="designer-issues__filters">
                                    <legend>Severity filters</legend>
                                    <label><input type="checkbox" checked="@_showErrorIssues" @onchange="args => _showErrorIssues = args.Value as bool? ?? false" /> Fouten</label>
                                    <label><input type="checkbox" checked="@_showWarningIssues" @onchange="args => _showWarningIssues = args.Value as bool? ?? false" /> Waarschuwingen</label>
                                    <label><input type="checkbox" checked="@_showInfoIssues" @onchange="args => _showInfoIssues = args.Value as bool? ?? false" /> Info</label>
                                </fieldset>

                                @if (FilteredIssues.Count == 0)
                                {
                                    <div class="designer-issues__empty">Geen issues voor de huidige filters.</div>
                                }
                                else
                                {
                                    <ul class="designer-issues__list">
                                        @foreach (var issue in FilteredIssues)
                                        {
                                            <li class="designer-issues__item designer-issues__item--@issue.Severity.ToString().ToLowerInvariant()">
                                                <button type="button" class="designer-issues__jump" @onclick="() => OnIssueClicked(issue)">
                                                    <RadzenIcon Icon="@GetIssueIcon(issue.Severity)" />
                                                    <span class="designer-issues__title">@issue.Code</span>
                                                    <span class="designer-issues__severity">@GetSeverityLabel(issue.Severity)</span>
                                                </button>
                                                <div class="designer-issues__location">@GetIssueLocation(issue)</div>
                                                <div class="designer-issues__message">@issue.Message</div>
                                                @if (CanAutoFix(issue))
                                                {
                                                    <div class="designer-issues__actions">
                                                        @if (issue.Code == "HardcodedColor")
                                                        {
                                                            <RadzenDropDown TValue="string" Data="HardcodedColorTokenOptions" TextProperty="Label" ValueProperty="Value" Value="@_hardcodedColorFixToken" Change="@(value => _hardcodedColorFixToken = value?.ToString() ?? _hardcodedColorFixToken)" />
                                                        }
                                                        <RadzenButton Text="Fix" Icon="build" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="() => ApplyIssueFixAsync(issue)" />
                                                    </div>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            }
                        </section>
                    }
                </aside>
            }
        </div>

        @if (!_previewMode)
        {
            @if (!_codeCollapsed)
            {
                <div class="designer-divider designer-divider--horizontal" data-divider="canvas-code" aria-label="Resize code panel"></div>
            }

            <section class="designer-panel designer-panel--code @(_codeCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Code en model">
                <div class="designer-panel__header">
                    <h2>Code</h2>
                    <button type="button" class="designer-panel__toggle" aria-expanded="@(!_codeCollapsed)" @onclick="ToggleCodeCollapsed">
                        <RadzenIcon Icon="@(_codeCollapsed ? "expand_less" : "expand_more")" />
                    </button>
                </div>

                @if (!_codeCollapsed)
                {
                    <DesignerCodePanel CurrentPage="@ActivePage" ActivePageIndex="@ActivePageIndex" Document="@_commands.Document" SelectedNodeId="@_selectedNodeId" OnDocumentChanged="OnDocumentChanged" />
                }
            </section>
        }

        @if (_showNewDocumentDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Nieuw document">
                <div class="designer-modal">
                    <h3>Nieuw document</h3>
                    <div class="designer-modal__content">
                        <label for="designer-template-kind">Template</label>
                        <RadzenDropDown id="designer-template-kind" TValue="DesignDocumentTemplateKind" Data="TemplateOptions" Value="@_selectedTemplateKind" Change="OnTemplateChanged" TextProperty="DisplayName" ValueProperty="Kind" />
                    </div>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Aanmaken" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="CreateNewDocumentFromDialogAsync" />
                        <RadzenButton Text="Annuleren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CloseNewDocumentDialog" />
                    </div>
                </div>
            </div>
        }

        @if (_showConflictDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Conflictdialoog">
                <div class="designer-modal">
                    <h3>Conflict gedetecteerd</h3>
                    <p>De serverversie is gewijzigd sinds je dit document hebt geladen.</p>
                    @if (_conflictServerEnvelope is not null)
                    {
                        <p>Laatst gewijzigd op server: @_conflictServerEnvelope.LastModified.ToLocalTime().ToString("g")</p>
                    }
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Mijn versie opslaan" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="SaveConflictMineAsync" />
                        <RadzenButton Text="Server-versie laden" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="LoadConflictServerAsync" />
                        <RadzenButton Text="Annuleren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CancelConflictDialog" />
                    </div>
                </div>
            </div>
        }

        @if (_showVersionHistory)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Versiegeschiedenis">
                <div class="designer-modal designer-modal--wide">
                    <h3>Versiegeschiedenis</h3>
                    @if (_versionHistory.Count == 0)
                    {
                        <p>Er zijn nog geen versies beschikbaar.</p>
                    }
                    else
                    {
                        <div class="designer-version-list">
                            @foreach (var version in _versionHistory)
                            {
                                <button type="button" class="designer-version-list__item" @onclick="() => PreviewVersionAsync(version.Version)">
                                    <span>Versie @version.Version</span>
                                    <span>@version.Created.ToLocalTime().ToString("g")</span>
                                    <span>@version.SizeBytes bytes</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_previewEnvelope is not null)
                    {
                        <div class="designer-version-preview">
                            <h4>Preview versie @_previewEnvelope.Version</h4>
                            <div class="designer-version-preview__canvas" data-agt-theme="@_canvasTheme">
                                <DesignRenderer Page="@_previewEnvelope.Document.Pages.FirstOrDefault()" Registry="@Registry" />
                            </div>
                            <RadzenButton Text="Herstellen" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="() => RestoreVersionAsync(_previewEnvelope.Version)" />
                        </div>
                    }

                    <div class="designer-modal__actions">
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="CloseVersionHistory" />
                    </div>
                </div>
            </div>
        }

        @if (_showExportDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Export dialoog">
                <div class="designer-modal designer-modal--wide">
                    <h3>Exporteer projectpakket</h3>
                    <div class="designer-export-summary">
                        <p><strong>Pagina's:</strong> @_commands.Document.Pages.Count</p>
                        <p><strong>Componenten:</strong> @TotalComponentCount</p>
                        <p><strong>Entiteiten:</strong> @(UsedEntities.Count == 0 ? "Geen" : string.Join(", ", UsedEntities))</p>
                        <p><strong>Thema:</strong> @_canvasTheme</p>
                        <p><strong>Issues:</strong> @ErrorCount fouten, @WarningCount waarschuwingen, @InfoCount info</p>
                    </div>
                    <p>Dit pakket bevat een Blazor-project met de ontworpen pagina's. Open het in Visual Studio of VS Code met <code>dotnet run</code>.</p>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Design spec (HTML)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="ExportDesignSpecAsync" />
                        <RadzenButton Text="Download projectpakket" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="ConfirmExportAsync" Disabled="@HasErrorIssues" />
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CloseExportDialog" />
                    </div>
                </div>
            </div>
        }
    }
</div>
