<div class="designer-page @DragStateCssClass @InteractionModeCssClass" @onkeydown="OnPageKeyDown" tabindex="0">
    <div class="designer-screenreader-status" role="status" aria-live="polite">@_liveAnnouncement</div>

    @if (_showOnboardingOverlay)
    {
        <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Welkom in de designer">
            <div class="designer-modal">
                <h3>Welkom in de designer</h3>
                <ol class="designer-onboarding-list">
                    <li>Kies een template of begin leeg.</li>
                    <li>Sleep of klik componenten uit het palet naar de canvas.</li>
                    <li>Pas eigenschappen aan in het rechterpaneel.</li>
                </ol>
                <div class="designer-modal__actions">
                    <RadzenButton Text="Begrepen" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="DismissOnboardingAsync" />
                </div>
            </div>
        </div>
    }

    @if (_showStartScreen)
    {
        <DesignerStartScreen TemplateOptions="TemplateOptions"
                             RecentDocuments="_savedDocuments"
                             OnTemplateSelected="OnTemplateStartSelected"
                             OnDocumentSelected="OpenSavedFromStartAsync"
                             OnImportRequested="OnStartScreenImportRequested"
                             Registry="Registry" />
    }
    else
    {
        @if (GetStatusMessage() is { } statusMessage)
        {
            <div class="designer-status-bar" role="status" aria-live="polite">
                <RadzenIcon Icon="@statusMessage.Icon" />
                <span>@statusMessage.Text</span>
                @if (statusMessage.Actions is not null)
                {
                    <div class="designer-status-bar__actions">
                        @statusMessage.Actions
                    </div>
                }
                @if (statusMessage.Dismissable)
                {
                    <button type="button" class="designer-status-bar__dismiss" @onclick="DismissStatusBar" aria-label="Sluiten">&times;</button>
                }
            </div>
        }

        @if (_fileMenuOpen || _settingsMenuOpen || _pageMenuIndex is not null || _pageAddMenuOpen)
        {
            <div class="designer-menu-backdrop" @onclick="CloseAllMenus"></div>
        }

        <header class="designer-toolbar" aria-label="Designer toolbar">
            <div class="designer-toolbar__group">
                <button type="button" class="designer-menu-toggle" aria-expanded="@_fileMenuOpen" @onclick="ToggleFileMenu">Bestand</button>
                @if (_fileMenuOpen)
                {
                    <div class="designer-menu" role="menu" aria-label="Bestand">
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OpenNewDocumentDialog">Nieuw</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnOpenDocument">Openen (bestand)</button>
                        <label class="designer-menu__item designer-menu__item--file" role="menuitem">
                            Importeren
                            <InputFile class="designer-file-input" accept=".agtdesign,.json,application/json" OnChange="OnDesignFileChanged" />
                        </label>
                        <div class="designer-menu__row">
                            <label for="designer-saved-docs">Open opgeslagen</label>
                            <RadzenDropDown id="designer-saved-docs" TValue="string" Data="SavedDocumentNames" @bind-Value="_selectedSavedName" Placeholder="Selecteer" Change="OnSavedDocumentDropdownChanged" />
                        </div>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnSaveDocument">Opslaan</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OpenVersionHistoryAsync">Versiegeschiedenis</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OnExportDocument" disabled="@HasErrorIssues">Exporteren</button>
                    </div>
                }

                <button type="button" class="designer-save-button" @onclick="OnSaveDocument">
                    <RadzenIcon Icon="save" />
                    <span>Opslaan</span>
                    @if (_commands.IsDirty)
                    {
                        <span class="designer-save-button__dirty-dot" aria-hidden="true"></span>
                    }
                </button>

                <RadzenButton Text="Undo" Icon="undo" Disabled="@(!_commands.CanUndo)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="OnUndo" />
                <RadzenButton Text="Redo" Icon="redo" Disabled="@(!_commands.CanRedo)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="OnRedo" />
            </div>

            <div class="designer-toolbar__center" title="Documentnaam">
                @if (_editingDocumentName)
                {
                    <input class="designer-toolbar__doc-input"
                           value="@_editingDocumentNameValue"
                           @oninput="args => _editingDocumentNameValue = args.Value?.ToString() ?? string.Empty"
                           @onkeydown="OnDocumentNameKeyDown"
                           @onblur="CommitDocumentNameAsync"
                           autofocus />
                }
                else
                {
                    <button type="button" class="designer-toolbar__doc-button" @onclick="BeginEditDocumentName">
                        <span>@_commands.Document.Name</span>
                        @if (_commands.IsDirty)
                        {
                            <span class="designer-toolbar__doc-dirty" aria-label="Niet opgeslagen">★</span>
                        }
                    </button>
                }
            </div>

            <div class="designer-toolbar__group">
                <RadzenButton Text="@(_previewMode ? "Bewerken" : "Preview")" Icon="@(_previewMode ? "edit" : "visibility")" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="TogglePreviewMode" />

                @if (!_previewMode)
                {
                    <RadzenButton Text="@(_interactionMode ? "Interactie uit" : "Interactie")"
                                  Icon="@(_interactionMode ? "pan_tool" : "touch_app")"
                                  ButtonStyle="ButtonStyle.Base"
                                  Variant="Variant.Flat"
                                  title="Schakel directe componentinteractie in de bewerkcanvas (Ctrl+I)"
                                  Click="ToggleInteractionMode" />

                    @if (_interactionMode)
                    {
                        <span class="designer-toolbar__state-badge" role="status" aria-live="polite">Interactie actief</span>
                    }
                }

                <div class="designer-viewport-toggle" role="group" aria-label="Viewport">
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "mobile", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("mobile")' aria-label="Mobiel">
                        <RadzenIcon Icon="smartphone" />
                    </button>
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "tablet", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("tablet")' aria-label="Tablet">
                        <RadzenIcon Icon="tablet" />
                    </button>
                    <button type="button" class="designer-icon-toggle @(string.Equals(_viewport, "desktop", StringComparison.Ordinal) ? "designer-icon-toggle--active" : null)" @onclick='() => SetViewport("desktop")' aria-label="Desktop">
                        <RadzenIcon Icon="desktop_windows" />
                    </button>
                </div>

                <div class="designer-toolbar__theme" role="group" aria-label="Thema">
                    <RadzenDropDown TValue="string"
                                    Data="CanvasThemeFamilyOptions"
                                    Value="@_canvasThemeFamily"
                                    ValueChanged="OnToolbarCanvasThemeFamilyValueChanged"
                                    Open="OnToolbarThemeDropdownOpened"
                                    Style="min-width: 150px;"
                                    Placeholder="Thema">
                        <Template Context="item">
                            @{
                                var familyId = item?.ToString() ?? "plum";
                            }
                            <div class="designer-theme-option">
                                <span class="designer-theme-swatch" style="background: @GetThemeSwatchColor(familyId);"></span>
                                <span>@FormatThemeFamilyName(familyId)</span>
                            </div>
                        </Template>
                    </RadzenDropDown>
                    <button type="button"
                            class="designer-toolbar__darkmode"
                            title="@(_isDarkMode ? "Licht thema" : "Donker thema")"
                            aria-label="@(_isDarkMode ? "Licht thema" : "Donker thema")"
                            @onclick="ToggleDarkLight">
                        <RadzenIcon Icon="@(_isDarkMode ? "light_mode" : "dark_mode")" />
                    </button>
                </div>

                <button type="button" class="designer-menu-toggle" aria-expanded="@_settingsMenuOpen" @onclick="ToggleSettingsMenu" disabled="@_previewMode">Instellingen</button>
                @if (_settingsMenuOpen)
                {
                    <div class="designer-menu" role="menu" aria-label="Instellingen">
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="ToggleShortcutsOverlay">Sneltoetsen</button>
                        <button type="button" class="designer-menu__item" role="menuitem" @onclick="OpenDesignerCommandPaletteAsync">Zoeken (Ctrl+K)</button>
                    </div>
                }

                <RadzenButton Text="Exporteren" Icon="inventory_2" Disabled="@HasErrorIssues" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="OnExportDocument" />
            </div>
        </header>

        <section class="designer-page-tabs" aria-label="Pagina's">
            <div class="designer-page-tabs__scroll">
                @for (var pageIndex = 0; pageIndex < _commands.Document.Pages.Count; pageIndex++)
                {
                    var page = _commands.Document.Pages[pageIndex];
                    var isActive = pageIndex == ActivePageIndex;

                    @if (_previewMode)
                    {
                        <button type="button" class="designer-page-tab__button @(isActive ? "designer-page-tab--active" : null)" @onclick="() => SelectPage(pageIndex)" title="@(page.Route)">@GetPageLabel(page)</button>
                    }
                    else
                    {
                            <div class="designer-page-tab @(isActive ? "designer-page-tab--active" : null) @(_pageDragOverIndex == pageIndex ? "designer-page-tab--drag-over" : null)"
                             draggable="true"
                             @ondragstart="() => OnPageDragStart(pageIndex)"
                                @ondragover="args => OnPageDragOver(pageIndex, args)"
                                @ondragover:preventDefault="true"
                                @ondragleave="() => OnPageDragLeave(pageIndex)"
                             @ondrop="() => OnPageDropAsync(pageIndex)"
                             @ondragend="OnPageDragEnd">
                                <button type="button" class="designer-page-tab__button" @onclick="() => SelectPage(pageIndex)" title="@(page.Route)">@GetPageLabel(page)</button>
                            @if (_editingPageIndex == pageIndex)
                            {
                                <input class="designer-page-tab__rename"
                                       value="@_editingPageTitle"
                                       @oninput="args => _editingPageTitle = args.Value?.ToString()"
                                       @onkeydown="args => OnRenameKeyDown(args, pageIndex)"
                                       @onblur="() => SaveRenamePageAsync(pageIndex)" />
                            }
                            <div class="designer-page-tab__menu-wrap">
                                <button type="button" class="designer-page-tab__menu" aria-expanded="@(_pageMenuIndex == pageIndex)" aria-label="Pagina acties" @onclick="() => TogglePageMenu(pageIndex)">
                                    <RadzenIcon Icon="more_horiz" />
                                </button>
                                @if (_pageMenuIndex == pageIndex)
                                {
                                    <div class="designer-page-tab__menu-list" role="menu">
                                        <button type="button" class="designer-page-tab__action" role="menuitem" @onclick="() => BeginRenamePage(pageIndex)">Hernoemen</button>
                                        <button type="button" class="designer-page-tab__action" role="menuitem" @onclick="() => DuplicatePageAsync(pageIndex)">Dupliceren</button>
                                        <button type="button" class="designer-page-tab__action designer-page-tab__action--danger" role="menuitem" @onclick="() => RemovePageAsync(pageIndex)" disabled="@(_commands.Document.Pages.Count <= 1)">Verwijderen</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            @if (!_previewMode)
            {
                <div class="designer-page-tabs__add-wrap">
                    <RadzenButton class="designer-page-tabs__add" Text="+" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="TogglePageAddMenu" />
                    @if (_pageAddMenuOpen)
                    {
                        <div class="designer-page-tabs__add-menu" role="menu" aria-label="Pagina toevoegen">
                            <button type="button" class="designer-page-tabs__add-item" role="menuitem" @onclick="OnAddPageAsync">Lege pagina</button>
                            @foreach (var template in AddPageTemplateOptions)
                            {
                                <button type="button" class="designer-page-tabs__add-item" role="menuitem" @onclick="() => OnAddPageFromTemplateAsync(template.Kind)">@template.DisplayName</button>
                            }
                        </div>
                    }
                </div>
            }
        </section>

        <div class="designer-grid">
            @if (_previewMode)
            {
                <section class="designer-panel designer-panel--canvas designer-panel--preview" aria-label="Preview canvas">
                    <div class="designer-canvas-frame @CanvasFrameClass" style="@CanvasFrameStyle">
                        <div class="designer-canvas designer-canvas-scope" data-agt-theme="@_canvasTheme">
                            <DesignPreviewRenderer Page="@ActivePage"
                                                   Registry="@Registry"
                                                   DataContext="@_designDataContext"
                                                   OnNavigate="OnPreviewNavigate" />
                        </div>
                    </div>
                </section>
            }
            else
            {
                <aside class="designer-panel designer-panel--left designer-panel--tree @(_leftPanelCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Palet en navigator">
                    <div class="designer-panel__header">
                        @if (!_leftPanelCollapsed)
                        {
                            <div class="designer-panel-tabs" role="tablist" aria-label="Linker paneel tabs">
                                <button type="button" role="tab" class="designer-panel-tab @(_leftTab == LeftPanelTab.Palette ? "designer-panel-tab--active" : string.Empty)" @onclick="() => _leftTab = LeftPanelTab.Palette">
                                    <RadzenIcon Icon="widgets" /> Palet
                                </button>
                                <button type="button" role="tab" class="designer-panel-tab @(_leftTab == LeftPanelTab.Navigator ? "designer-panel-tab--active" : string.Empty)" @onclick="() => _leftTab = LeftPanelTab.Navigator">
                                    <RadzenIcon Icon="account_tree" /> Navigator
                                </button>
                            </div>
                        }
                        <button type="button" class="designer-panel__toggle" aria-expanded="@(!_leftPanelCollapsed)" @onclick="ToggleLeftPanelCollapsed">
                            <RadzenIcon Icon="@(_leftPanelCollapsed ? "chevron_right" : "chevron_left")" />
                        </button>
                    </div>

                    @if (!_leftPanelCollapsed)
                    {
                        @if (_leftTab == LeftPanelTab.Palette)
                        {
                            <input class="designer-filter" type="text" placeholder="Zoek component..." value="@_paletteFilter" @oninput="OnPaletteFilterChanged" />
                            @foreach (var category in PaletteByCategory)
                            {
                                <section class="designer-category">
                                    <h3>@category.Key</h3>
                                    <div class="designer-palette-grid">
                                        @foreach (var descriptor in category.Value)
                                        {
                                            <button type="button"
                                                    class="@GetPaletteCardClass(descriptor.ComponentType)"
                                                    draggable="true"
                                                    @ondragstart='args => OnPaletteDragStart(args, descriptor)'
                                                    @ondragend="OnDragEnd"
                                                    @onclick="() => OnPaletteItemClickedAsync(descriptor.ComponentType)"
                                                    title="@(descriptor.DesignerDescription ?? descriptor.ComponentType)">
                                                <RadzenIcon Icon="@GetPaletteIcon(descriptor)" />
                                                <span class="designer-palette-card__name">@GetPaletteDisplayName(descriptor)</span>
                                            </button>
                                        }
                                    </div>
                                </section>
                            }
                        }
                        else
                        {
                            <div class="designer-tree" aria-label="Navigator">
                                @RenderTreeNodes(TreeRoots)
                            </div>

                            @if (_treeContextMenuNodeId is not null)
                            {
                                <div class="designer-tree-context-menu"
                                     role="menu"
                                     style="left: @_treeContextMenuXpx; top: @_treeContextMenuYpx;"
                                     @onclick:stopPropagation="true">
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextDuplicateAsync">Dupliceren</button>
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextDeleteAsync">Verwijderen</button>
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextMoveUpAsync">Omhoog</button>
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextMoveDownAsync">Omlaag</button>
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextWrapCardAsync">Wikkel in kaart</button>
                                    <button type="button" class="designer-tree-context-menu__item" role="menuitem" @onclick="OnTreeContextWrapRowAsync">Wikkel in rij</button>
                                </div>
                            }

                        }

                        <section class="designer-issues" aria-label="Issues panel">
                            <button type="button" class="designer-issues__header" @onclick="() => _issuesExpanded = !_issuesExpanded" aria-expanded="@_issuesExpanded">
                                <span>Issues</span>
                                <span>@($"{ErrorCount} fouten · {WarningCount} waarschuwingen · {InfoCount} info")</span>
                            </button>

                            @if (_issuesExpanded)
                            {
                                <fieldset class="designer-issues__filters">
                                    <legend>Severity filters</legend>
                                    <label><input type="checkbox" checked="@_showErrorIssues" @onchange="args => _showErrorIssues = args.Value as bool? ?? false" /> Fouten</label>
                                    <label><input type="checkbox" checked="@_showWarningIssues" @onchange="args => _showWarningIssues = args.Value as bool? ?? false" /> Waarschuwingen</label>
                                    <label><input type="checkbox" checked="@_showInfoIssues" @onchange="args => _showInfoIssues = args.Value as bool? ?? false" /> Info</label>
                                </fieldset>

                                @if (FilteredIssues.Count == 0)
                                {
                                    <div class="designer-issues__empty">Geen issues voor de huidige filters.</div>
                                }
                                else
                                {
                                    <ul class="designer-issues__list">
                                        @foreach (var issue in FilteredIssues)
                                        {
                                            <li class="designer-issues__item designer-issues__item--@issue.Severity.ToString().ToLowerInvariant()">
                                                <button type="button" class="designer-issues__jump" @onclick="() => OnIssueClicked(issue)">
                                                    <RadzenIcon Icon="@GetIssueIcon(issue.Severity)" />
                                                    <span class="designer-issues__title">@issue.Code</span>
                                                    <span class="designer-issues__severity">@GetSeverityLabel(issue.Severity)</span>
                                                </button>
                                                <div class="designer-issues__location">@GetIssueLocation(issue)</div>
                                                <div class="designer-issues__message">@issue.Message</div>
                                                @if (CanAutoFix(issue))
                                                {
                                                    <div class="designer-issues__actions">
                                                        @if (issue.Code == "HardcodedColor")
                                                        {
                                                            <RadzenDropDown TValue="string" Data="HardcodedColorTokenOptions" TextProperty="Label" ValueProperty="Value" @bind-Value="_hardcodedColorFixToken" />
                                                        }
                                                        <RadzenButton Text="Fix" Icon="build" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="() => ApplyIssueFixAsync(issue)" />
                                                    </div>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            }
                        </section>
                    }
                </aside>

                @if (_leftPanelCollapsed)
                {
                    <section class="designer-issues designer-issues--offscreen" aria-hidden="true">
                        <span>Issues</span>
                        <span>@($"{ErrorCount} fouten · {WarningCount} waarschuwingen · {InfoCount} info")</span>
                    </section>
                }

                @if (!_leftPanelCollapsed)
                {
                    <div class="designer-divider designer-divider--vertical" data-divider="palette-canvas" aria-label="Resize palette"></div>
                }

                <section class="designer-panel designer-panel--canvas" aria-label="Canvas">
                    <div class="designer-breadcrumb" aria-live="polite">
                        @if (SelectionBreadcrumbParts.Count == 0)
                        {
                            <span>Selecteer een node</span>
                        }
                        else
                        {
                            @for (var crumbIndex = 0; crumbIndex < SelectionBreadcrumbParts.Count; crumbIndex++)
                            {
                                var crumb = SelectionBreadcrumbParts[crumbIndex];
                                @if (crumb.IsSelectable && crumb.NodeId is not null)
                                {
                                    <button type="button" class="designer-breadcrumb__item" @onclick="() => OnSelectNode(crumb.NodeId)">@crumb.Label</button>
                                }
                                else
                                {
                                    <span class="designer-breadcrumb__item">@crumb.Label</span>
                                }
                                if (crumbIndex < SelectionBreadcrumbParts.Count - 1)
                                {
                                    <span class="designer-breadcrumb__sep">&gt;</span>
                                }
                            }
                        }
                    </div>
                    <div class="designer-canvas-workspace">
                        <div class="designer-canvas-frame @CanvasFrameClass" style="@CanvasFrameStyle">
                            <div class="designer-canvas designer-canvas-scope" data-agt-theme="@_canvasTheme" @ref="_canvasRef">
                                <CascadingValue Value="@_designDataContext" IsFixed="false">
                                    @if (ActivePage.Nodes.Count == 0)
                                    {
                                        <div class="designer-canvas-empty">
                                            <div class="designer-canvas-empty__hero">
                                                <RadzenIcon Icon="dashboard_customize" />
                                                <h2>Ontwerp je pagina</h2>
                                                <p>Kies een startpunt of sleep componenten uit het palet links.</p>
                                            </div>
                                            <div class="designer-canvas-empty__templates">
                                                <button type="button" class="designer-canvas-empty__template" @onclick='() => OnTemplateStartSelected(DesignDocumentTemplateKind.FormPage)'>
                                                    <div class="designer-canvas-empty__template-preview">
                                                        <div class="designer-canvas-empty__template-line" style="width:60%;"></div>
                                                        <div class="designer-canvas-empty__template-line" style="width:100%;"></div>
                                                        <div class="designer-canvas-empty__template-line" style="width:100%;"></div>
                                                        <div class="designer-canvas-empty__template-line designer-canvas-empty__template-line--button" style="width:30%;"></div>
                                                    </div>
                                                    <span>Formulier</span>
                                                </button>
                                                <button type="button" class="designer-canvas-empty__template" @onclick='() => OnTemplateStartSelected(DesignDocumentTemplateKind.Dashboard)'>
                                                    <div class="designer-canvas-empty__template-preview">
                                                        <div class="designer-canvas-empty__template-row">
                                                            <div class="designer-canvas-empty__template-card"></div>
                                                            <div class="designer-canvas-empty__template-card"></div>
                                                            <div class="designer-canvas-empty__template-card"></div>
                                                        </div>
                                                        <div class="designer-canvas-empty__template-chart"></div>
                                                    </div>
                                                    <span>Dashboard</span>
                                                </button>
                                                <button type="button" class="designer-canvas-empty__template" @onclick='() => OnTemplateStartSelected(DesignDocumentTemplateKind.Blank)'>
                                                    <div class="designer-canvas-empty__template-preview designer-canvas-empty__template-preview--blank">
                                                        <RadzenIcon Icon="add" />
                                                    </div>
                                                    <span>Leeg</span>
                                                </button>
                                            </div>
                                            <p class="designer-canvas-empty__hint">Of druk <kbd>Ctrl+K</kbd> om een component te zoeken</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="@GetRootDropzoneClass(ActivePage.Nodes.Count)"
                                             @ondragenter='() => OnDropZoneDragEnter($"root-{ActivePage.Nodes.Count}")'
                                             @ondragleave='() => OnDropZoneDragLeave($"root-{ActivePage.Nodes.Count}")'
                                             @ondragover='args => OnDropZoneDragOver(args, $"root-{ActivePage.Nodes.Count}")'
                                             @ondragover:preventDefault="true"
                                             @ondrop='() => OnDropRequested(new DesignerDropTarget(DesignNodeLocation.Root(ActivePage.Nodes.Count)), $"root-{ActivePage.Nodes.Count}")'
                                             title="Drop op canvas"></div>
                                        @for (var index = 0; index < ActivePage.Nodes.Count; index++)
                                        {
                                            var node = ActivePage.Nodes[index];
                                            <DesignerCanvasNode Node="node"
                                                               Registry="@Registry"
                                                               SelectedNodeId="@_selectedNodeId"
                                                               SelectedNodeIds="@_selectedNodeIds"
                                                               HoveredNodeId="@_hoveredNodeId"
                                                               HoverNodeChanged="OnTreeNodeHover"
                                                               SelectNode="OnSelectNode"
                                                               SelectNodeExtended="OnSelectNode"
                                                               StartDrag="OnDragStart"
                                                               EndDrag="OnDragEnd"
                                                               DropNode="OnDropRequested"
                                                               AddNodeRequested="OnInlineAddRequested"
                                                               MoveNodeUp="OnMoveNodeUp"
                                                               MoveNodeDown="OnMoveNodeDown"
                                                               DuplicateNode="OnDuplicateNode"
                                                               DeleteNode="OnDeleteNode"
                                                               InlineEditCommitted="OnInlineEditCommitted"
                                                               NodeQuickParameterChanged="OnInlineEditCommitted"
                                                               IsDragActive="IsDragActive"
                                                               HoverDropzoneId="@_hoverDropzoneId"
                                                               DropzoneDragEnter="OnDropZoneDragEnter"
                                                               DropzoneDragLeave="OnDropZoneDragLeave" />
                                            <div class="@GetRootDropzoneClass(index + 1)"
                                                 @ondragenter='() => OnDropZoneDragEnter($"root-{index + 1}")'
                                                 @ondragleave='() => OnDropZoneDragLeave($"root-{index + 1}")'
                                                 @ondragover='args => OnDropZoneDragOver(args, $"root-{index + 1}")'
                                                 @ondragover:preventDefault="true"
                                                 @ondrop='() => OnDropRequested(new DesignerDropTarget(DesignNodeLocation.Root(index + 1)), $"root-{index + 1}")'
                                                 title="Drop op canvas"></div>
                                        }

                                        <div class="designer-layout-presets">
                                            <span class="designer-layout-presets__label">Rij toevoegen</span>
                                            <div class="designer-layout-presets__grid">
                                                <button type="button" class="designer-layout-preset" title="1 kolom (12)" @onclick='() => AddRowLayoutPreset("12")'>
                                                    <div class="designer-layout-preset__preview">
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                    </div>
                                                    <span>1 kolom</span>
                                                </button>
                                                <button type="button" class="designer-layout-preset" title="2 kolommen (6+6)" @onclick='() => AddRowLayoutPreset("6+6")'>
                                                    <div class="designer-layout-preset__preview">
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                    </div>
                                                    <span>2 kolommen</span>
                                                </button>
                                                <button type="button" class="designer-layout-preset" title="3 kolommen (4+4+4)" @onclick='() => AddRowLayoutPreset("4+4+4")'>
                                                    <div class="designer-layout-preset__preview">
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                    </div>
                                                    <span>3 kolommen</span>
                                                </button>
                                                <button type="button" class="designer-layout-preset" title="Zijbalk + hoofd (4+8)" @onclick='() => AddRowLayoutPreset("4+8")'>
                                                    <div class="designer-layout-preset__preview">
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                        <div class="designer-layout-preset__col" style="flex:2;"></div>
                                                    </div>
                                                    <span>Zijbalk + hoofd</span>
                                                </button>
                                                <button type="button" class="designer-layout-preset" title="Hoofd + zijbalk (8+4)" @onclick='() => AddRowLayoutPreset("8+4")'>
                                                    <div class="designer-layout-preset__preview">
                                                        <div class="designer-layout-preset__col" style="flex:2;"></div>
                                                        <div class="designer-layout-preset__col" style="flex:1;"></div>
                                                    </div>
                                                    <span>Hoofd + zijbalk</span>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </CascadingValue>
                            </div>
                        </div>
                    </div>

                    @if (!_codeCollapsed)
                    {
                        <div class="designer-divider designer-divider--horizontal designer-divider--canvas-code" data-divider="canvas-code" aria-label="Resize code panel"></div>
                    }

                    <section class="designer-panel designer-panel--code designer-panel--code-inline @(_codeCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Code en model">
                        <div class="designer-panel__header">
                            <h2>Code</h2>
                            <button type="button" class="designer-panel__toggle" aria-expanded="@(!_codeCollapsed)" @onclick="ToggleCodeCollapsed">
                                <RadzenIcon Icon="@(_codeCollapsed ? "expand_less" : "expand_more")" />
                            </button>
                        </div>

                        @if (!_codeCollapsed)
                        {
                            <DesignerCodePanel CurrentPage="@ActivePage" ActivePageIndex="@ActivePageIndex" Document="@_commands.Document" SelectedNodeId="@_selectedNodeId" Registry="@Registry" OnDocumentChanged="OnDocumentChanged" />
                        }
                    </section>
                </section>

                <div class="designer-divider designer-divider--vertical" data-divider="canvas-property" aria-label="Resize properties"></div>

                <aside class="designer-panel designer-panel--right designer-panel--data @(_rightPanelCollapsed ? "designer-panel--collapsed" : string.Empty)" aria-label="Inspector">
                    <div class="designer-panel__header">
                        @if (!_rightPanelCollapsed)
                        {
                            <div class="designer-panel-tabs" role="tablist" aria-label="Inspector tabs">
                                <button type="button" role="tab" class="designer-panel-tab @(_rightTab == RightPanelTab.Properties ? "designer-panel-tab--active" : string.Empty)" @onclick="() => _rightTab = RightPanelTab.Properties">
                                    <RadzenIcon Icon="tune" /> Eigenschappen
                                </button>
                                <button type="button" role="tab" class="designer-panel-tab @(_rightTab == RightPanelTab.Data ? "designer-panel-tab--active" : string.Empty)" @onclick="() => _rightTab = RightPanelTab.Data">
                                    <RadzenIcon Icon="storage" /> Data
                                </button>
                            </div>
                        }
                        <button type="button" class="designer-panel__toggle" aria-expanded="@(!_rightPanelCollapsed)" @onclick="ToggleRightPanelCollapsed">
                            <RadzenIcon Icon="@(_rightPanelCollapsed ? "chevron_left" : "chevron_right")" />
                        </button>
                    </div>

                    @if (!_rightPanelCollapsed)
                    {
                        <div class="designer-properties-panel" style="@(_rightTab == RightPanelTab.Properties ? null : "display:none;")">
                            <PropertyPanel Page="@ActivePage"
                                           HasDuplicateRoute="@HasDuplicateActiveRoute"
                                           CanvasTheme="@_canvasTheme"
                                           ThemeOptions="CanvasThemeOptions"
                                           DataModel="@_commands.Document.DataModel"
                                           SelectedNode="SelectedNode"
                                           SelectedDescriptor="SelectedDescriptor"
                                           SetPageRoute="OnPageRouteChanged"
                                           SetPageTitle="OnPageTitleChanged"
                                           SetCanvasTheme="OnCanvasThemeChanged"
                                           SetNodeParameter="OnNodeParameterChanged"
                                           SetNodeLayoutSlot="OnNodeLayoutSlotChanged"
                                           AddColumnNode="OnAddColumnNode"
                                           RemoveColumnNode="OnRemoveColumnNode"
                                           SplitColumnNode="OnSplitColumnNode"
                                           UpsertColumnNodes="OnUpsertColumnNodes"
                                           SetDataGridPaging="OnSetDataGridPaging" />
                        </div>
                        <div class="designer-data-panel" style="@(_rightTab == RightPanelTab.Data ? null : "display:none;")">
                            <DesignerDataPanel DataModel="@_commands.Document.DataModel" SelectedEntityName="@_selectedEntityName" SelectedEntityNameChanged="OnSelectedEntityChanged" GenerateFormRequested="OnGenerateFormRequested" ImportEntitiesRequested="OnImportEntitiesRequested" />
                        </div>
                    }
                </aside>
            }
        </div>

        <div class="designer-toasts" aria-live="polite" aria-atomic="true">
            @foreach (var toast in _toasts)
            {
                <div class="designer-toast @(toast.IsExiting ? "designer-toast--exiting" : string.Empty) @GetToastClass(toast.Type)">
                    <span>@toast.Text</span>
                    <button type="button" class="designer-toast__dismiss" @onclick="() => DismissToast(toast)" aria-label="Sluiten">&times;</button>
                </div>
            }
        </div>

        @if (_showShortcutsOverlay)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Sneltoetsen">
                <div class="designer-modal designer-modal--wide">
                    <h3>Sneltoetsen</h3>
                    <table class="designer-shortcuts-table">
                        <thead>
                            <tr><th>Sneltoets</th><th>Actie</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>Ctrl+K</td><td>Quick Find / Command Palette</td></tr>
                            <tr><td>Ctrl+S</td><td>Opslaan</td></tr>
                            <tr><td>Ctrl+Z</td><td>Ongedaan maken</td></tr>
                            <tr><td>Ctrl+Y</td><td>Opnieuw</td></tr>
                            <tr><td>Ctrl+P</td><td>Preview toggelen</td></tr>
                            <tr><td>Ctrl+E</td><td>Exporteren</td></tr>
                            <tr><td>Delete</td><td>Geselecteerd component verwijderen</td></tr>
                            <tr><td>Ctrl+D</td><td>Geselecteerd component dupliceren</td></tr>
                            <tr><td>Ctrl+↑ / Ctrl+↓</td><td>Component omhoog/omlaag verplaatsen</td></tr>
                            <tr><td>Escape</td><td>Menu's sluiten / selectie opheffen</td></tr>
                            <tr><td>Ctrl+/</td><td>Dit overzicht tonen/verbergen</td></tr>
                        </tbody>
                    </table>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="ToggleShortcutsOverlay" />
                    </div>
                </div>
            </div>
        }

        @if (_showDesignerCommandPalette)
        {
            <div class="designer-overlay designer-overlay--transparent" role="dialog" aria-modal="true" aria-label="Quick Find" @onclick="CloseDesignerCommandPalette">
                <div class="designer-command-modal" @onclick:stopPropagation="true">
                    <input class="designer-command-search"
                           type="text"
                           placeholder="Zoek component, actie of eigenschap..."
                           value="@_commandSearchQuery"
                           @oninput="OnCommandSearchChanged"
                           @onkeydown="OnDesignerCommandSearchKeyDown"
                           autofocus />
                    <div class="designer-command-results">
                        @foreach (var group in FilteredCommandGroups)
                        {
                            <div class="designer-command-group">
                                <div class="designer-command-group__header">@group.Key</div>
                                @foreach (var item in group.Items)
                                {
                                    <button type="button"
                                            class="designer-command-item @(_commandSelectedIndex == item.Index ? "designer-command-item--active" : string.Empty)"
                                            @onclick="() => ExecuteCommandItemAsync(item)">
                                        <span>@item.Command.Title</span>
                                        @if (!string.IsNullOrWhiteSpace(item.Command.ShortcutHint))
                                        {
                                            <kbd>@item.Command.ShortcutHint</kbd>
                                        }
                                    </button>
                                }
                            </div>
                        }
                        @if (FilteredCommandGroups.Count == 0)
                        {
                            <div class="designer-command-empty">Geen resultaten voor "@_commandSearchQuery"</div>
                        }
                    </div>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="CloseDesignerCommandPalette" />
                    </div>
                </div>
            </div>
        }

        @if (_showNewDocumentDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Nieuw document">
                <div class="designer-modal">
                    <h3>Nieuw document</h3>
                    <div class="designer-modal__content">
                        <label for="designer-template-kind">Template</label>
                        <RadzenDropDown id="designer-template-kind"
                                        TValue="DesignDocumentTemplateKind"
                                        Data="TemplateOptions"
                                        Value="@_selectedTemplateKind"
                                        Open="OnNewDocumentTemplateDropdownOpened"
                                        Change="OnNewDocumentTemplateChanged"
                                        TextProperty="DisplayName"
                                        ValueProperty="Kind" />
                    </div>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Aanmaken" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="CreateNewDocumentFromDialogAsync" />
                        <RadzenButton Text="Annuleren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CloseNewDocumentDialog" />
                    </div>
                </div>
            </div>
        }

        @if (_showConflictDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Conflictdialoog">
                <div class="designer-modal">
                    <h3>Conflict gedetecteerd</h3>
                    <p>De serverversie is gewijzigd sinds je dit document hebt geladen.</p>
                    @if (_conflictServerEnvelope is not null)
                    {
                        <p>Laatst gewijzigd op server: @_conflictServerEnvelope.LastModified.ToLocalTime().ToString("g")</p>
                    }
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Mijn versie opslaan" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="SaveConflictMineAsync" />
                        <RadzenButton Text="Server-versie laden" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="LoadConflictServerAsync" />
                        <RadzenButton Text="Annuleren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CancelConflictDialog" />
                    </div>
                </div>
            </div>
        }

        @if (_showVersionHistory)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Versiegeschiedenis">
                <div class="designer-modal designer-modal--wide">
                    <h3>Versiegeschiedenis</h3>
                    @if (_versionHistory.Count == 0)
                    {
                        <p>Er zijn nog geen versies beschikbaar.</p>
                    }
                    else
                    {
                        <div class="designer-version-list">
                            @foreach (var version in _versionHistory)
                            {
                                <button type="button" class="designer-version-list__item" @onclick="() => PreviewVersionAsync(version.Version)">
                                    <span>Versie @version.Version</span>
                                    <span>@version.Created.ToLocalTime().ToString("g")</span>
                                    <span>@version.SizeBytes bytes</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_previewEnvelope is not null)
                    {
                        <div class="designer-version-preview">
                            <h4>Preview versie @_previewEnvelope.Version</h4>
                            <div class="designer-version-preview__canvas" data-agt-theme="@_canvasTheme">
                                <DesignRenderer Page="@_previewEnvelope.Document.Pages.FirstOrDefault()" Registry="@Registry" />
                            </div>
                            <RadzenButton Text="Herstellen" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="() => RestoreVersionAsync(_previewEnvelope.Version)" />
                        </div>
                    }

                    <div class="designer-modal__actions">
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="CloseVersionHistory" />
                    </div>
                </div>
            </div>
        }

        @if (_showExportDialog)
        {
            <div class="designer-overlay" role="dialog" aria-modal="true" aria-label="Export dialoog">
                <div class="designer-modal designer-modal--wide">
                    <h3>Exporteer projectpakket</h3>
                    <div class="designer-export-summary">
                        <p><strong>Pagina's:</strong> @_commands.Document.Pages.Count</p>
                        <p><strong>Componenten:</strong> @TotalComponentCount</p>
                        <p><strong>Entiteiten:</strong> @(UsedEntities.Count == 0 ? "Geen" : string.Join(", ", UsedEntities))</p>
                        <p><strong>Thema:</strong> @_canvasTheme</p>
                        <p><strong>Issues:</strong> @ErrorCount fouten, @WarningCount waarschuwingen, @InfoCount info</p>
                    </div>
                    <div class="designer-export-options">
                        <AgtSwitch Label="Voorbeelddata meegeven"
                                   Value="@_exportIncludeSeedData"
                                   ValueChanged="OnExportIncludeSeedDataChanged"
                                   AriaLabel="Voorbeelddata meegeven" />
                        <p class="designer-export__hint">
                            Het geexporteerde project bevat realistische voorbeelddata.
                            Schakel uit via <code>appsettings.json -> "UseSeedData": false</code>.
                        </p>
                    </div>
                    <p>Dit pakket bevat een Blazor-project met de ontworpen pagina's. Open het in Visual Studio of VS Code met <code>dotnet run</code>.</p>
                    <div class="designer-modal__actions">
                        <RadzenButton Text="Design spec (HTML)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="ExportDesignSpecAsync" />
                        <RadzenButton Text="Download projectpakket" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="ConfirmExportAsync" Disabled="@HasErrorIssues" />
                        <RadzenButton Text="Sluiten" ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" Click="CloseExportDialog" />
                    </div>
                </div>
            </div>
        }
    }
</div>
