@using System.Globalization
@using System.Text.Json
@using Agterhuis.Ui.Designer.Model
@using Agterhuis.Ui.Designer.Registry

@if (SelectedNode is null)
{
    <section class="designer-properties">
        <h2>Pagina-eigenschappen</h2>
        <AgtTextField Label="Route" AriaLabel="Pagina route" Value="@Page.Route" ValueChanged="OnRouteChanged" ValidationMessage="@RouteValidationMessage" />
        <AgtTextField Label="Titel" AriaLabel="Pagina titel" Value="@Page.Title" ValueChanged="OnTitleChanged" ValidationMessage="@_pageTitleValidation" />
        <AgtDropdown TValue="string" Label="Canvas-thema" AriaLabel="Canvas thema" Data="ThemeOptionItems" Value="CanvasTheme" ValueChanged="OnCanvasThemeChanged" TextProperty="Label" ValueProperty="Value" />
    </section>
}
else if (SelectedDescriptor is null)
{
    <section class="designer-properties">
        <h2>Eigenschappen</h2>
        <div class="designer-properties__readonly">Onbekend componenttype voor selectie.</div>
    </section>
}
else
{
    <section class="designer-properties">
        <div class="designer-properties__field-head">
            <h2>@(SelectedDescriptor.DesignerDisplayName ?? SelectedDescriptor.DisplayName) eigenschappen</h2>
            <AgtSwitch Label="Geavanceerd" AriaLabel="Geavanceerde eigenschappen" Value="@(!_simpleMode)" ValueChanged="OnAdvancedModeChanged" />
        </div>

        <div class="designer-inspector-tabs" role="tablist" aria-label="Inspector secties">
            <button type="button"
                    role="tab"
                    class="@TabClass(InspectorSection.Content)"
                    aria-selected="@(IsActiveSection(InspectorSection.Content))"
                    @onclick="() => SetActiveSection(InspectorSection.Content)">Inhoud</button>
            <button type="button"
                    role="tab"
                    class="@TabClass(InspectorSection.Interaction)"
                    aria-selected="@(IsActiveSection(InspectorSection.Interaction))"
                    @onclick="() => SetActiveSection(InspectorSection.Interaction)">Interactie</button>
            <button type="button"
                    role="tab"
                    class="@TabClass(InspectorSection.Appearance)"
                    aria-selected="@(IsActiveSection(InspectorSection.Appearance))"
                    @onclick="() => SetActiveSection(InspectorSection.Appearance)">Weergave</button>
        </div>

        <div class="designer-inspector-more-options">
            <AgtSwitch Label="Meer opties"
                       AriaLabel="Meer opties"
                       Value="@GetSectionAdvancedState()"
                       ValueChanged="OnSectionAdvancedChanged" />
        </div>
        
        @if (_activeSection == InspectorSection.Content && ContentSubcomponentPills.Count > 1)
        {
            <div class="designer-subcomponent-pills" role="group" aria-label="Subcomponenten">
                @foreach (var pill in ContentSubcomponentPills)
                {
                    <button type="button"
                            class="@(string.Equals(_activeSubcomponentFilter, pill, StringComparison.Ordinal) ? "designer-subcomponent-pill designer-subcomponent-pill--active" : "designer-subcomponent-pill")"
                            @onclick="() => ToggleSubcomponentFilter(pill)">@pill</button>
                }
            </div>
        }

        @if (_missingAccessibilityParameters.Count > 0)
        {
            <div class="designer-properties__a11y-warning" role="status" aria-live="polite">
                <strong>Toegankelijkheidswaarschuwing:</strong>
                <span>vul @string.Join(" en ", _missingAccessibilityParameters) in.</span>
            </div>
        }

        @if (_activeSection == InspectorSection.Appearance && (!_simpleMode || GetSectionAdvancedState()))
        {
        <section class="designer-properties__group">
            <h3>Layout</h3>
            <div class="designer-properties__layout-grid">
                <AgtNumericField Label="Rij" AriaLabel="Layout rij" Value="@ConvertToDecimal(LayoutRow)" ValueChanged="@(value => OnLayoutValueChanged(LayoutKey.Row, value))" Min="1" Step="1" />
                <AgtNumericField Label="Kolom" AriaLabel="Layout kolom" Value="@ConvertToDecimal(LayoutColumn)" ValueChanged="@(value => OnLayoutValueChanged(LayoutKey.Column, value))" Min="1" Step="1" />
                <AgtNumericField Label="Rijspan" AriaLabel="Layout rijspan" Value="@ConvertToDecimal(LayoutRowSpan)" ValueChanged="@(value => OnLayoutValueChanged(LayoutKey.RowSpan, value))" Min="1" Step="1" />
                <AgtNumericField Label="Kolomspan" AriaLabel="Layout kolomspan" Value="@ConvertToDecimal(LayoutColumnSpan)" ValueChanged="@(value => OnLayoutValueChanged(LayoutKey.ColumnSpan, value))" Min="1" Step="1" />
            </div>
        </section>
        }

        @if (IsDataGridNode && (_activeSection is InspectorSection.Content or InspectorSection.Appearance))
        {
            <section class="designer-properties__group" data-agt-designer-columns-editor="true">
                <div class="designer-properties__field-head">
                    <h3>Kolommen</h3>
                    <div>
                        <RadzenButton Text="Alle selecteren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="SelectAllColumnsAsync" />
                        <RadzenButton Text="Geen selecteren" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="ClearColumnsAsync" />
                    </div>
                </div>
                @if (BoundGridEntity is null)
                {
                    <div class="designer-properties__readonly">Koppel eerst Data aan een entiteit om kolommen te configureren.</div>
                }
                else
                {
                    <div class="designer-properties__layout-grid">
                        @foreach (var column in DataGridColumns.OrderBy(static item => item.Order))
                        {
                            <div class="designer-properties__field" data-agt-designer-column-field="@column.FieldName">
                                <div class="designer-properties__field-head">
                                    <AgtSwitch Label="@column.FieldName" AriaLabel="@column.FieldName" Value="@column.IsEnabled" ValueChanged="@(value => column.IsEnabled = value)" />
                                    <div>
                                        <RadzenButton Text="Omhoog" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="@(() => MoveColumn(column.FieldName, -1))" />
                                        <RadzenButton Text="Omlaag" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="@(() => MoveColumn(column.FieldName, 1))" />
                                    </div>
                                </div>
                                @if (column.IsEnabled)
                                {
                                    <AgtTextField Label="Titel" AriaLabel="Kolomtitel" Value="@column.Title" ValueChanged="@(value => column.Title = value ?? column.Title)" />
                                    <AgtDropdown TValue="string" Label="Formaat" AriaLabel="Kolomformaat" Data="ColumnFormatOptions" Value="@column.Format" ValueChanged="@(value => column.Format = value)" TextProperty="Label" ValueProperty="Value" />
                                    <AgtSwitch Label="Sorteerbaar" AriaLabel="Sorteerbaar" Value="@column.Sortable" ValueChanged="@(value => column.Sortable = value)" />
                                    <AgtSwitch Label="Filterbaar" AriaLabel="Filterbaar" Value="@column.Filterable" ValueChanged="@(value => column.Filterable = value)" />
                                    <AgtTextField Label="Breedte" AriaLabel="Breedte" Value="@column.Width" ValueChanged="@(value => column.Width = string.IsNullOrWhiteSpace(value) ? "auto" : value)" />
                                }
                            </div>
                        }
                    </div>

                    <div class="designer-properties__layout-grid">
                        <AgtSwitch Label="Paginering" AriaLabel="Paginering" Value="@PagingConfig.AllowPaging" ValueChanged="@(value => PagingConfig.AllowPaging = value)" />
                        <AgtDropdown TValue="int" Label="Pagina-grootte" AriaLabel="Pagina-grootte" Data="PageSizeOptions" Value="@PagingConfig.PageSize" ValueChanged="OnPageSizeChanged" TextProperty="Label" ValueProperty="Value" />
                    </div>

                    <div class="designer-modal__actions">
                        <RadzenButton Text="Kolommen toepassen" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="ApplyColumnsAsync" />
                    </div>
                }
            </section>
        }

        @if ((ColumnNodes.Count > 0 || SupportsColumnsSlot) && _activeSection == InspectorSection.Appearance)
        {
            <section class="designer-properties__group" data-agt-designer-columns-editor="true">
                <div class="designer-properties__field-head">
                    <h3>Kolommen (handmatig)</h3>
                    <RadzenButton Text="Kolom toevoegen" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="OnAddColumnRequested" />
                </div>
                @if (ColumnNodes.Count == 0)
                {
                    <div class="designer-properties__readonly">Nog geen kolommen gedefinieerd.</div>
                }
                else
                {
                    <div class="designer-properties__layout-grid">
                        @foreach (var columnNode in ColumnNodes)
                        {
                            <div class="designer-properties__field" data-agt-designer-column-node="@columnNode.Id">
                                <div class="designer-properties__field-head">
                                    <span class="designer-properties__field-label">@GetColumnLabel(columnNode)</span>
                                    <RadzenButton Text="Verwijderen" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="@(() => OnRemoveColumnRequested(columnNode.Id))" />
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        }

        @if (IsRadzenColumnNode && _activeSection == InspectorSection.Appearance)
        {
            <section class="designer-properties__group">
                <h3>Kolom</h3>
                <div class="designer-modal__actions">
                    <RadzenButton Text="Splits kolom" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="OnSplitColumnRequested" />
                </div>
            </section>
        }

        @foreach (var group in GroupedParameters)
        {
            <section class="designer-properties__group">
                <h3>@group.Key</h3>
                @foreach (var parameter in group.Value)
                {
                    var editorKind = GetEditorKind(parameter);
                    var uiState = GetUiState(parameter);
                    var hasCustomValue = HasCustomValue(parameter);
                    <div class="designer-properties__field" data-agt-designer-editor-kind="@editorKind" data-agt-designer-param="@parameter.Name">
                        <div class="designer-properties__field-head">
                            <span class="designer-properties__field-label">@GetParameterLabel(parameter.Name)</span>
                            @if (parameter.IsBindable)
                            {
                                <span class="designer-properties__modified" title="Kan aan demo-data worden gekoppeld">Bindbaar</span>
                            }
                            @if (hasCustomValue)
                            {
                                <span class="designer-properties__modified" title="Afwijkend van default">Gewijzigd</span>
                            }
                            <RadzenButton Text="Reset" Disabled="@(!hasCustomValue)" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Click="@(() => OnResetParameter(parameter))" />
                        </div>

                        @if (parameter.IsBindable)
                        {
                            <div class="designer-properties__layout-grid">
                                <AgtDropdown TValue="string"
                                             Label="Entiteit"
                                             AriaLabel="Bind entiteit"
                                             Data="BindableEntities"
                                             Value="@GetBindingEntity(parameter)"
                                             ValueChanged="@(value => OnBindingEntityChanged(parameter, value))"
                                             TextProperty="Label"
                                             ValueProperty="Value" />

                                @if (!IsCollectionBinding(parameter))
                                {
                                    <AgtDropdown TValue="string"
                                                 Label="Veld"
                                                 AriaLabel="Bind veld"
                                                 Data="GetBindableFields(parameter)"
                                                 Value="@GetBindingField(parameter)"
                                                 ValueChanged="@(value => OnBindingFieldChanged(parameter, value))"
                                                 TextProperty="Label"
                                                 ValueProperty="Value" />
                                }

                                <AgtSwitch Label="Vrije invoer" AriaLabel="Vrije invoer" Value="@IsManualBindingMode(parameter)" ValueChanged="@(value => ToggleManualMode(parameter, value))" />
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(uiState.ValidationMessage))
                        {
                            <div class="designer-properties__validation">@uiState.ValidationMessage</div>
                        }

                        @switch (editorKind)
                        {
                            case EditorKind.String:
                                @if (string.Equals(parameter.Name, "Icon", StringComparison.Ordinal))
                                {
                                    <DesignerIconPicker Value="@uiState.TextValue" ValueChanged="@(value => OnStringChanged(parameter, value))" />
                                }
                                else
                                {
                                    <AgtTextField Label="@GetParameterLabel(parameter.Name)" AriaLabel="@GetParameterLabel(parameter.Name)" Value="@uiState.TextValue" ValueChanged="@(value => OnStringChanged(parameter, value))" ValidationMessage="@uiState.ValidationMessage" />
                                }
                                break;
                            case EditorKind.Numeric:
                                <AgtNumericField Label="@GetParameterLabel(parameter.Name)" AriaLabel="@GetParameterLabel(parameter.Name)" Value="@uiState.NumericValue" ValueChanged="@(value => OnNumericChanged(parameter, value))" ValidationMessage="@uiState.ValidationMessage" />
                                break;
                            case EditorKind.Boolean:
                                <AgtSwitch Label="@GetParameterLabel(parameter.Name)" AriaLabel="@GetParameterLabel(parameter.Name)" Value="@(uiState.BoolValue ?? false)" ValueChanged="@(value => OnBoolChanged(parameter, value))" />
                                break;
                            case EditorKind.Enum:
                                @if (string.Equals(parameter.Name, "ButtonStyle", StringComparison.Ordinal))
                                {
                                    <DesignerButtonStylePicker Value="@uiState.TextValue" ValueChanged="@(value => OnEnumChanged(parameter, value))" />
                                }
                                else if (string.Equals(parameter.Name, "Intent", StringComparison.Ordinal))
                                {
                                    <DesignerIntentPicker Value="@uiState.TextValue" ValueChanged="@(value => OnEnumChanged(parameter, value))" />
                                }
                                else
                                {
                                    <AgtDropdown TValue="string" Label="@GetParameterLabel(parameter.Name)" AriaLabel="@GetParameterLabel(parameter.Name)" Data="GetEnumOptions(parameter)" Value="@uiState.TextValue" ValueChanged="@(value => OnEnumChanged(parameter, value))" TextProperty="Label" ValueProperty="Value" ValidationMessage="@uiState.ValidationMessage" />
                                }
                                break;
                            case EditorKind.DateTime:
                                <AgtDatePicker Label="@GetParameterLabel(parameter.Name)" AriaLabel="@GetParameterLabel(parameter.Name)" Value="@uiState.DateValue" ValueChanged="@(value => OnDateChanged(parameter, value))" ValidationMessage="@uiState.ValidationMessage" />
                                break;
                            case EditorKind.ColorToken:
                                <div class="designer-properties__color-grid">
                                    <AgtDropdown TValue="string" Label="@($"{GetParameterLabel(parameter.Name)} token")" AriaLabel="@($"{GetParameterLabel(parameter.Name)} token")" Data="ColorTokenOptions" Value="@uiState.TextValue" ValueChanged="@(value => OnStringChanged(parameter, value))" TextProperty="Label" ValueProperty="Value" />
                                    <AgtTextField Label="@($"{GetParameterLabel(parameter.Name)} vrije waarde")" AriaLabel="@($"{GetParameterLabel(parameter.Name)} vrije waarde")" Value="@uiState.TextValue" ValueChanged="@(value => OnStringChanged(parameter, value))" ValidationMessage="@uiState.ValidationMessage" />
                                </div>
                                <div class="designer-properties__hint">Vrije hex-waarden kunnen token-bleed veroorzaken bij export.</div>
                                break;
                            case EditorKind.EventCallback:
                                <div class="designer-properties__readonly">Logica in geexporteerde code (v1-scope).</div>
                                break;
                            case EditorKind.ReadOnly:
                                <div class="designer-properties__readonly">@uiState.JsonValue</div>
                                break;
                        }
                    </div>
                }
            </section>
        }
    </section>
}

@code {
    [Parameter, EditorRequired]
    public DesignPage Page { get; set; } = default!;

    [Parameter, EditorRequired]
    public string CanvasTheme { get; set; } = "plum-dark";

    [Parameter]
    public bool HasDuplicateRoute { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<string> ThemeOptions { get; set; } = [];

    [Parameter, EditorRequired]
    public DesignDataModel DataModel { get; set; } = default!;

    [Parameter]
    public DesignNode? SelectedNode { get; set; }

    [Parameter]
    public DesignerComponentDescriptor? SelectedDescriptor { get; set; }

    [Parameter]
    public EventCallback<string?> SetPageRoute { get; set; }

    [Parameter]
    public EventCallback<string?> SetPageTitle { get; set; }

    [Parameter]
    public EventCallback<string> SetCanvasTheme { get; set; }

    [Parameter]
    public EventCallback<(ComponentParameterDescriptor Parameter, DesignParameterValue? Value)> SetNodeParameter { get; set; }

    [Parameter]
    public EventCallback<DesignLayoutSlot> SetNodeLayoutSlot { get; set; }

    [Parameter]
    public EventCallback AddColumnNode { get; set; }

    [Parameter]
    public EventCallback<string> RemoveColumnNode { get; set; }

    [Parameter]
    public EventCallback SplitColumnNode { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<DataGridColumnConfig>> UpsertColumnNodes { get; set; }

    [Parameter]
    public EventCallback<DataGridPagingConfig> SetDataGridPaging { get; set; }

    private const string CategoryGeneral = "Algemeen";
    private const string CategoryLayout = "Layout";
    private const string CategoryData = "Data";
    private const string CategoryAccessibility = "Toegankelijkheid";
    private const string CategoryOther = "Overig";

    private string? _pageRouteValidation;
    private string? _pageTitleValidation;
    private bool _simpleMode = true;
    private InspectorSection _activeSection = InspectorSection.Content;
    private bool _showAdvancedContent;
    private bool _showAdvancedInteraction;
    private bool _showAdvancedAppearance;
    private string? _activeSubcomponentFilter;
    private IReadOnlyList<string> _missingAccessibilityParameters = [];
    private readonly HashSet<string> _manualBindingParameters = new(StringComparer.Ordinal);
    private List<DataGridColumnConfig> DataGridColumns { get; set; } = [];
    private DataGridPagingConfig PagingConfig { get; set; } = new();

    private string? RouteValidationMessage => _pageRouteValidation ?? (HasDuplicateRoute ? "Route moet uniek zijn." : null);

    private IReadOnlyDictionary<string, IReadOnlyList<ComponentParameterDescriptor>> GroupedParameters => SelectedDescriptor is null
        ? new Dictionary<string, IReadOnlyList<ComponentParameterDescriptor>>(StringComparer.Ordinal)
        : SelectedDescriptor.Parameters
            .Where(static parameter => !parameter.IsRenderFragment)
            .Where(static parameter => !parameter.IsEventCallback)
            .Where(parameter => Classify(parameter) == _activeSection)
            .Where(parameter => MatchesSubcomponentFilter(parameter))
            .Where(parameter => !_simpleMode || IsSimpleParameter(parameter.Name))
            .Where(parameter => !_simpleMode || GetSectionAdvancedState() || IsPrimaryParameter(parameter))
            .OrderBy(static parameter => parameter.Name, StringComparer.Ordinal)
            .ToArray()
            .GroupBy(ResolveCategory, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => (IReadOnlyList<ComponentParameterDescriptor>)group.ToArray(), StringComparer.Ordinal);

    private IReadOnlyList<string> ContentSubcomponentPills => SelectedDescriptor?.Parameters
        .Where(static parameter => !parameter.IsRenderFragment && !parameter.IsEventCallback)
        .Where(parameter => Classify(parameter) == InspectorSection.Content)
        .Select(static parameter => InferSubcomponentGroup(parameter.Name))
        .Distinct(StringComparer.Ordinal)
        .OrderBy(static pill => pill, StringComparer.Ordinal)
        .ToArray()
        ?? [];
    private bool MatchesSubcomponentFilter(ComponentParameterDescriptor parameter)
    {
        if (string.IsNullOrWhiteSpace(_activeSubcomponentFilter))
        {
            return true;
        }

        return string.Equals(InferSubcomponentGroup(parameter.Name), _activeSubcomponentFilter, StringComparison.Ordinal);
    }

    private static string InferSubcomponentGroup(string parameterName)
    {
        if (parameterName.Contains("Label", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Placeholder", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Text", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Title", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Description", StringComparison.OrdinalIgnoreCase))
        {
            return "Label";
        }

        if (parameterName.Contains("Icon", StringComparison.OrdinalIgnoreCase))
        {
            return "Icon";
        }

        if (parameterName.Contains("Tooltip", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Hint", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Help", StringComparison.OrdinalIgnoreCase)
            || parameterName.Contains("Aria", StringComparison.OrdinalIgnoreCase))
        {
            return "Tooltip";
        }

        return "Overig";
    }

    private void ToggleSubcomponentFilter(string pill)
    {
        _activeSubcomponentFilter = string.Equals(_activeSubcomponentFilter, pill, StringComparison.Ordinal) ? null : pill;
    }

    private int LayoutRow => SelectedNode?.LayoutSlot?.Row ?? 1;
    private int LayoutColumn => SelectedNode?.LayoutSlot?.Column ?? 1;
    private int LayoutRowSpan => SelectedNode?.LayoutSlot?.RowSpan ?? 1;
    private int LayoutColumnSpan => SelectedNode?.LayoutSlot?.ColumnSpan ?? 1;
    private bool SupportsColumnsSlot => SelectedDescriptor?.Slots.Contains("Columns", StringComparer.Ordinal) == true;
    private bool IsDataGridNode
        => string.Equals(SelectedNode?.ComponentType, "RadzenDataGrid", StringComparison.Ordinal)
            || string.Equals(SelectedNode?.ComponentType, "AgtDataGrid", StringComparison.Ordinal);
    private IReadOnlyList<DesignNode> ColumnNodes => SelectedNode?.Children.TryGetValue("Columns", out var columns) == true ? columns : [];
    private bool IsRadzenColumnNode => string.Equals(SelectedNode?.ComponentType, "RadzenColumn", StringComparison.Ordinal);

    private DesignEntity? BoundGridEntity
    {
        get
        {
            if (!IsDataGridNode || SelectedNode is null)
            {
                return null;
            }

            var expression = GetExpressionValue("Data");
            if (string.IsNullOrWhiteSpace(expression))
            {
                return null;
            }

            var entityName = ParseEntityNameFromExpression(expression);
            return string.IsNullOrWhiteSpace(entityName)
                ? null
                : DataModel.Entities.FirstOrDefault(entity => string.Equals(entity.Name, entityName, StringComparison.OrdinalIgnoreCase));
        }
    }

    private IReadOnlyList<OptionItem> ColorTokenOptions =>
    [
        new OptionItem("Primair 500", "var(--agt-color-primary-500)"),
        new OptionItem("Accent", "var(--agt-color-accent)"),
        new OptionItem("Text body", "var(--agt-text-body)"),
        new OptionItem("Text heading", "var(--agt-text-heading)"),
        new OptionItem("Surface 0", "var(--agt-surface-0)"),
        new OptionItem("Surface 1", "var(--agt-surface-1)"),
        new OptionItem("Border", "var(--agt-input-border)"),
        new OptionItem("Danger", "var(--agt-color-danger-500)")
    ];

    private IReadOnlyList<OptionItem> ThemeOptionItems => ThemeOptions.OrderBy(static item => item, StringComparer.Ordinal).Select(static item => new OptionItem(item, item)).ToArray();

    private IReadOnlyList<OptionItem> BindableEntities => DataModel.Entities.OrderBy(static entity => entity.Name, StringComparer.Ordinal).Select(static entity => new OptionItem(entity.Name, entity.Name)).ToArray();

    private IReadOnlyList<OptionItem> ColumnFormatOptions =>
    [
        new OptionItem("Tekst", "text"),
        new OptionItem("Numeriek", "numeric"),
        new OptionItem("Datum", "date"),
        new OptionItem("Boolean", "boolean")
    ];

    private IReadOnlyList<PageSizeOption> PageSizeOptions =>
    [
        new PageSizeOption("10", 10),
        new PageSizeOption("25", 25),
        new PageSizeOption("50", 50),
        new PageSizeOption("100", 100)
    ];

    protected override void OnParametersSet()
    {
        _pageRouteValidation = null;
        _pageTitleValidation = null;
        _missingAccessibilityParameters = SelectedNode is null || SelectedDescriptor is null
            ? []
            : SelectedDescriptor.Parameters.Where(IsAccessibilityParameter).Select(static parameter => parameter.Name).Where(name => string.IsNullOrWhiteSpace(GetCurrentTextValue(name))).ToArray();

        if (SelectedDescriptor is not null && !HasParametersForSection(_activeSection))
        {
            if (HasParametersForSection(InspectorSection.Content))
            {
                _activeSection = InspectorSection.Content;
            }
            else if (HasParametersForSection(InspectorSection.Interaction))
            {
                _activeSection = InspectorSection.Interaction;
            }
            else
            {
                _activeSection = InspectorSection.Appearance;
            }
        }

        BuildGridColumnState();
    }

    private void BuildGridColumnState()
    {
        if (!IsDataGridNode || SelectedNode is null || BoundGridEntity is null)
        {
            DataGridColumns = [];
            PagingConfig = new DataGridPagingConfig();
            return;
        }

        var configuredColumns = SelectedNode.Children.TryGetValue("Columns", out var nodes)
            ? nodes
            : [];

        var state = new List<DataGridColumnConfig>();
        var configuredByField = configuredColumns
            .Select((node, index) => new { Node = node, Index = index })
            .Where(static item => item.Node.Parameters.TryGetValue("Property", out _))
            .ToDictionary(
                static item => item.Node.Parameters["Property"].Literal?.GetValue<string>() ?? string.Empty,
                static item => item,
                StringComparer.OrdinalIgnoreCase);

        var order = 0;
        foreach (var field in BoundGridEntity.Fields)
        {
            if (configuredByField.TryGetValue(field.Name, out var configured))
            {
                var title = configured.Node.Parameters.TryGetValue("Title", out var titleValue)
                    ? titleValue.Literal?.GetValue<string>() ?? field.DisplayLabel ?? field.Name
                    : field.DisplayLabel ?? field.Name;

                state.Add(new DataGridColumnConfig
                {
                    FieldName = field.Name,
                    IsEnabled = true,
                    Title = title,
                    Format = GuessFormat(field),
                    Sortable = configured.Node.Parameters.TryGetValue("Sortable", out var sortable) ? sortable.Literal?.GetValue<bool>() ?? true : true,
                    Filterable = configured.Node.Parameters.TryGetValue("Filterable", out var filterable) ? filterable.Literal?.GetValue<bool>() ?? true : true,
                    Width = configured.Node.Parameters.TryGetValue("Width", out var width) ? width.Literal?.GetValue<string>() ?? "auto" : "auto",
                    Order = order++
                });
            }
            else
            {
                state.Add(new DataGridColumnConfig
                {
                    FieldName = field.Name,
                    IsEnabled = false,
                    Title = field.DisplayLabel ?? field.Name,
                    Format = GuessFormat(field),
                    Sortable = true,
                    Filterable = true,
                    Width = "auto",
                    Order = order++
                });
            }
        }

        DataGridColumns = state;

        PagingConfig = new DataGridPagingConfig
        {
            AllowPaging = SelectedNode.Parameters.TryGetValue("AllowPaging", out var allowPaging) ? allowPaging.Literal?.GetValue<bool>() ?? true : true,
            PageSize = SelectedNode.Parameters.TryGetValue("PageSize", out var pageSize) ? Math.Max(10, pageSize.Literal?.GetValue<int>() ?? 10) : 10
        };
    }

    private async Task OnRouteChanged(string? route)
    {
        var normalized = (route ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized))
        {
            _pageRouteValidation = "Route is verplicht.";
            return;
        }

        _pageRouteValidation = null;
        await SetPageRoute.InvokeAsync(normalized);
    }

    private async Task OnTitleChanged(string? title)
    {
        var normalized = title?.Trim();
        if (string.IsNullOrWhiteSpace(normalized))
        {
            _pageTitleValidation = "Titel is verplicht.";
            return;
        }

        _pageTitleValidation = null;
        await SetPageTitle.InvokeAsync(normalized);
    }

