    private EditorKind GetEditorKind(ComponentParameterDescriptor parameter)
    {
        if (parameter.ParameterType == typeof(string) && parameter.Name.Contains("Color", StringComparison.OrdinalIgnoreCase))
        {
            return EditorKind.ColorToken;
        }

        if (parameter.IsEventCallback)
        {
            return EditorKind.EventCallback;
        }

        return parameter.ParameterType == typeof(string)
            ? EditorKind.String
            : parameter.ParameterType == typeof(bool) || parameter.ParameterType == typeof(bool?)
                ? EditorKind.Boolean
                : parameter.ParameterType.IsEnum
                    ? EditorKind.Enum
                    : parameter.ParameterType == typeof(DateTime) || parameter.ParameterType == typeof(DateTime?)
                        ? EditorKind.DateTime
                        : parameter.ParameterType == typeof(decimal) || parameter.ParameterType == typeof(decimal?) || parameter.ParameterType == typeof(int) || parameter.ParameterType == typeof(int?) || parameter.ParameterType == typeof(double) || parameter.ParameterType == typeof(double?)
                            ? EditorKind.Numeric
                            : EditorKind.ReadOnly;
    }

