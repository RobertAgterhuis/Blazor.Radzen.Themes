    private bool IsCollectionBinding(ComponentParameterDescriptor parameter)
    {
        if (parameter.Name.Contains("Data", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var type = parameter.ParameterType;
        return type != typeof(string) && typeof(System.Collections.IEnumerable).IsAssignableFrom(type);
    }

    private bool IsManualBindingMode(ComponentParameterDescriptor parameter)
        => _manualBindingParameters.Contains(parameter.Name);

    private void ToggleManualMode(ComponentParameterDescriptor parameter, bool manual)
    {
        if (manual)
        {
