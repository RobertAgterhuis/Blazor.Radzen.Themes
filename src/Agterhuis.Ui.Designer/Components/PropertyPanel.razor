            return;
        }

        _manualBindingParameters.Remove(parameter.Name);
    }

    private string? GetBindingEntity(ComponentParameterDescriptor parameter)
    {
        var expression = GetExpressionValue(parameter.Name);
        if (string.IsNullOrWhiteSpace(expression))
        {
            return null;
        }

        return ParseEntityNameFromExpression(expression);
    }

    private string? GetBindingField(ComponentParameterDescriptor parameter)
    {
        var expression = GetExpressionValue(parameter.Name);
        if (string.IsNullOrWhiteSpace(expression))
        {
            return null;
        }

        var marker = ".Select(";
        var markerIndex = expression.IndexOf(marker, StringComparison.Ordinal);
        if (markerIndex < 0)
        {
            return null;
        }

        var lambdaBody = expression[(markerIndex + marker.Length)..].TrimEnd(')');
        var fieldMarker = ".";
        var dotIndex = lambdaBody.LastIndexOf(fieldMarker, StringComparison.Ordinal);
        if (dotIndex < 0 || dotIndex + 1 >= lambdaBody.Length)
        {
            return null;
        }

        return lambdaBody[(dotIndex + 1)..].Trim();
    }

    private IReadOnlyList<OptionItem> GetBindableFields(ComponentParameterDescriptor parameter)
    {
        var entityName = GetBindingEntity(parameter);
        var entity = DataModel.Entities.FirstOrDefault(candidate => string.Equals(candidate.Name, entityName, StringComparison.OrdinalIgnoreCase));
        if (entity is null)
        {
            return [];
        }

        return entity.Fields
            .Where(field => IsFieldCompatibleWithParameter(field, parameter))
            .OrderBy(static field => field.Name, StringComparer.Ordinal)
            .Select(field => new OptionItem(field.DisplayLabel ?? field.Name, field.Name))
            .ToArray();
    }

    private async Task OnBindingEntityChanged(ComponentParameterDescriptor parameter, string? entityName)
    {
        if (string.IsNullOrWhiteSpace(entityName))
        {
            await SetNodeParameter.InvokeAsync((parameter, null));
            return;
        }

        if (IsCollectionBinding(parameter))
        {
            await SetNodeParameter.InvokeAsync((parameter, new DesignParameterValue { Expression = $"@entities.{entityName}" }));
            return;
        }

        var firstField = DataModel.Entities
            .FirstOrDefault(entity => string.Equals(entity.Name, entityName, StringComparison.OrdinalIgnoreCase))
            ?.Fields
            .FirstOrDefault(field => IsFieldCompatibleWithParameter(field, parameter));

        var expression = firstField is null
            ? $"@entities.{entityName}"
            : $"@entities.{entityName}.Select(item => item.{firstField.Name})";

        await SetNodeParameter.InvokeAsync((parameter, new DesignParameterValue { Expression = expression }));
    }

    private async Task OnBindingFieldChanged(ComponentParameterDescriptor parameter, string? fieldName)
    {
        var entity = GetBindingEntity(parameter);
        if (string.IsNullOrWhiteSpace(entity) || string.IsNullOrWhiteSpace(fieldName))
        {
            return;
        }

        var expression = $"@entities.{entity}.Select(item => item.{fieldName})";
        await SetNodeParameter.InvokeAsync((parameter, new DesignParameterValue { Expression = expression }));
    }

    private static bool IsFieldCompatibleWithParameter(DesignField field, ComponentParameterDescriptor parameter)
    {
        var parameterType = Nullable.GetUnderlyingType(parameter.ParameterType) ?? parameter.ParameterType;
        return field.Type switch
        {
            DesignFieldType.String or DesignFieldType.Enum => parameterType == typeof(string) || parameterType == typeof(object),
            DesignFieldType.Int => parameterType == typeof(int) || parameterType == typeof(decimal) || parameterType == typeof(double) || parameterType == typeof(object),
            DesignFieldType.Decimal => parameterType == typeof(decimal) || parameterType == typeof(double) || parameterType == typeof(int) || parameterType == typeof(object),
            DesignFieldType.Bool => parameterType == typeof(bool) || parameterType == typeof(object),
            DesignFieldType.DateTime => parameterType == typeof(DateTime) || parameterType == typeof(object),
            _ => true
        };
    }

    private string? GetExpressionValue(string parameterName)
    {
        if (SelectedNode?.Parameters.TryGetValue(parameterName, out var value) != true || value is null)
        {
            return null;
        }

        return value.Expression;
    }

    private static string? ParseEntityNameFromExpression(string expression)
    {
        var trimmed = expression.Trim();
        if (!trimmed.StartsWith("@entities.", StringComparison.Ordinal))
        {
            return null;
        }

        var rest = trimmed["@entities.".Length..];
        var separators = new[] { '.', '(', ' ' };
        var index = rest.IndexOfAny(separators);
        return index < 0 ? rest : rest[..index];
    }

    private async Task SelectAllColumnsAsync()
    {
        foreach (var column in DataGridColumns)
        {
            column.IsEnabled = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearColumnsAsync()
    {
        foreach (var column in DataGridColumns)
        {
            column.IsEnabled = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void MoveColumn(string fieldName, int delta)
    {
        var index = DataGridColumns.FindIndex(column => string.Equals(column.FieldName, fieldName, StringComparison.OrdinalIgnoreCase));
        if (index < 0)
        {
            return;
        }

        var targetIndex = index + delta;
        if (targetIndex < 0 || targetIndex >= DataGridColumns.Count)
        {
            return;
        }

        (DataGridColumns[index], DataGridColumns[targetIndex]) = (DataGridColumns[targetIndex], DataGridColumns[index]);
        for (var i = 0; i < DataGridColumns.Count; i++)
        {
            DataGridColumns[i].Order = i;
        }
    }

    private Task OnPageSizeChanged(int pageSize)
    {
        PagingConfig.PageSize = pageSize;
        return Task.CompletedTask;
    }

    private async Task ApplyColumnsAsync()
    {
        await UpsertColumnNodes.InvokeAsync(DataGridColumns);
        await SetDataGridPaging.InvokeAsync(PagingConfig);
    }

    private static string GuessFormat(DesignField field)
    {
        return field.Type switch
        {
            DesignFieldType.Int or DesignFieldType.Decimal => "numeric",
            DesignFieldType.DateTime => "date",
            DesignFieldType.Bool => "boolean",
            _ => "text"
        };
    }

