    {
        return _activeSection switch
        {
            InspectorSection.Content => _showAdvancedContent,
            InspectorSection.Interaction => _showAdvancedInteraction,
            _ => _showAdvancedAppearance
        };
    }

    private Task OnSectionAdvancedChanged(bool value)
    {
        switch (_activeSection)
        {
            case InspectorSection.Content:
                _showAdvancedContent = value;
                break;
            case InspectorSection.Interaction:
                _showAdvancedInteraction = value;
