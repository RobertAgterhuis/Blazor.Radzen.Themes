        return SelectedDescriptor.Parameters
            .Where(static parameter => !parameter.IsRenderFragment)
            .Where(static parameter => !parameter.IsEventCallback)
            .Where(parameter => !_simpleMode || IsSimpleParameter(parameter.Name))
            .Any(parameter => Classify(parameter) == section);
    }

