@using System.Reflection
@using System.Text.Json.Nodes
@using Agterhuis.Ui.Designer.Model
@using Agterhuis.Ui.Designer.Registry
@using Agterhuis.Ui.Designer.Rendering
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.Web

<div class="designer-canvas-node @(IsSelected ? "designer-canvas-node--selected" : string.Empty) @(IsHovered && !IsSelected ? "designer-canvas-node--hover" : string.Empty)"
     data-agt-design-node-id="@Node.Id"
     data-agt-design-component="@Node.ComponentType"
     @onmouseenter="OnMouseEnter"
     @onmouseleave="OnMouseLeave"
     @onmouseenter:stopPropagation="true"
     @onmouseleave:stopPropagation="true">
    <div class="designer-canvas-node__label">@DescriptorLabel</div>

    @if (IsSelected)
    {
        <div class="designer-floating-toolbar" @onclick:stopPropagation="true">
            <button type="button" title="Omhoog verplaatsen" @onclick="OnMoveUp">
                <RadzenIcon Icon="arrow_upward" />
            </button>
            <button type="button" title="Omlaag verplaatsen" @onclick="OnMoveDown">
                <RadzenIcon Icon="arrow_downward" />
            </button>
            <button type="button" title="Dupliceren" @onclick="OnDuplicate">
                <RadzenIcon Icon="content_copy" />
            </button>
            <button type="button" title="Verwijderen" @onclick="OnDelete">
                <RadzenIcon Icon="delete_outline" />
            </button>
        </div>

        @if (CanResizeColumn)
        {
            <div class="designer-resize-handles" @onclick:stopPropagation="true">
                <button type="button" class="designer-resize-handle designer-resize-handle--left" title="Kolombreedte verkleinen" @onclick="OnResizeColumnDown">◀</button>
                <button type="button" class="designer-resize-handle designer-resize-handle--right" title="Kolombreedte vergroten" @onclick="OnResizeColumnUp">▶</button>
            </div>
        }
    }

    <div class="designer-canvas-node__bar">
        <button type="button"
                class="designer-canvas-node__select"
                draggable="true"
                @ondragstart="OnDragStart"
                @ondragend="OnDragEnd"
                @onclick="OnSelectClicked"
                aria-current="@(IsSelected ? "true" : "false")">
            <RadzenIcon Icon="@DescriptorIcon" />
            <span>@DescriptorLabel</span>
        </button>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="designer-canvas-node__error">@_errorMessage</div>
    }
    else if (_descriptor is not null)
    {
        <div class="designer-canvas-node__preview" @ondblclick="OnDoubleClick">
            <ErrorBoundary>
                <ChildContent>
                    <DynamicComponent Type="@_descriptor.ClrType" Parameters="@_parameters" />
                </ChildContent>
                <ErrorContent Context="exception">
                    <div class="designer-canvas-node__error">@exception.Message</div>
                </ErrorContent>
            </ErrorBoundary>

            @if (_inlineEditParam is not null)
            {
                <div class="designer-inline-edit" @onclick:stopPropagation="true">
                    <input type="text"
                           value="@_inlineEditValue"
                           @oninput="OnInlineEditChanged"
                           @onblur="CommitInlineEdit"
                           @onkeydown="OnInlineEditKeyDown"
                           autofocus />
                </div>
            }
        </div>
    }
</div>

@code {
    private static readonly MethodInfo TemplatedSlotMethod = typeof(DesignerCanvasNode)
        .GetMethod(nameof(CreateTemplatedSlotCore), BindingFlags.Instance | BindingFlags.NonPublic)
        ?? throw new InvalidOperationException("Templated slot factory not found.");

    [Parameter, EditorRequired]
    public DesignNode Node { get; set; } = default!;

    [Parameter, EditorRequired]
    public DesignerComponentRegistry Registry { get; set; } = default!;

    [Parameter]
    public string? SelectedNodeId { get; set; }

    [Parameter]
    public EventCallback<string> SelectNode { get; set; }

    [Parameter]
    public EventCallback<DesignerDropTarget> DropNode { get; set; }

    [Parameter]
    public EventCallback<DesignerDragPayload> StartDrag { get; set; }

    [Parameter]
    public EventCallback EndDrag { get; set; }

    [Parameter]
    public bool IsDragActive { get; set; }

    [Parameter]
    public string? HoverDropzoneId { get; set; }

    [Parameter]
    public EventCallback<string> DropzoneDragEnter { get; set; }

    [Parameter]
    public EventCallback<string> DropzoneDragLeave { get; set; }

    [Parameter]
    public EventCallback<(string ParentNodeId, string SlotName, string ComponentType)> AddNodeRequested { get; set; }

    [Parameter]
    public EventCallback<string> MoveNodeUp { get; set; }

    [Parameter]
    public EventCallback<string> MoveNodeDown { get; set; }

    [Parameter]
    public EventCallback<string> DuplicateNode { get; set; }

    [Parameter]
    public EventCallback<string> DeleteNode { get; set; }

    [Parameter]
    public EventCallback<(string ParameterName, string Value)> InlineEditCommitted { get; set; }

    [Parameter]
    public EventCallback<(string ParameterName, string Value)> NodeQuickParameterChanged { get; set; }

    [Parameter]
    public string? HoveredNodeId { get; set; }

    [Parameter]
    public EventCallback<string?> HoverNodeChanged { get; set; }

    private DesignerComponentDescriptor? _descriptor;
    private Dictionary<string, object?> _parameters = [];
    private string? _errorMessage;
    private bool _isHovering;
    private string? _inlineEditParam;
    private string _inlineEditValue = string.Empty;
    private readonly Dictionary<string, bool> _slotPickerVisible = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _slotPickerSelection = new(StringComparer.Ordinal);
    private static readonly HashSet<string> InlineEditableNames = new(StringComparer.OrdinalIgnoreCase)
    {
        "Label",
        "Text",
        "Title",
        "Description",
        "Placeholder"
    };

    private bool IsSelected => string.Equals(Node.Id, SelectedNodeId, StringComparison.Ordinal);

    private bool CanResizeColumn => string.Equals(Node.ComponentType, "RadzenColumn", StringComparison.Ordinal);

    private bool IsHovered => _isHovering || string.Equals(Node.Id, HoveredNodeId, StringComparison.Ordinal);

    private string DescriptorLabel => _descriptor?.DisplayName ?? Node.ComponentType;

    private string DescriptorIcon => _descriptor?.Icon ?? "widgets";

    protected override void OnParametersSet()
    {
        _parameters = [];
        _descriptor = null;
        _errorMessage = null;

        if (!Registry.TryGetDescriptor(Node.ComponentType, out var descriptor))
        {
            _errorMessage = $"Onbekend componenttype '{Node.ComponentType}'.";
            return;
        }

        _descriptor = descriptor;

        try
        {
            _parameters = BuildParameterDictionary(descriptor);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task OnSelectClicked() => await SelectNode.InvokeAsync(Node.Id);

    private void OnMouseEnter()
    {
        _isHovering = true;
        _ = HoverNodeChanged.InvokeAsync(Node.Id);
    }

    private void OnMouseLeave()
    {
        _isHovering = false;
        _ = HoverNodeChanged.InvokeAsync(null);
    }

    private Task OnDragStart() => StartDrag.InvokeAsync(DesignerDragPayload.Node(Node.Id));

    private Task OnDragEnd() => EndDrag.InvokeAsync();

    private Task OnMoveUp() => MoveNodeUp.InvokeAsync(Node.Id);

    private Task OnMoveDown() => MoveNodeDown.InvokeAsync(Node.Id);

    private Task OnDuplicate() => DuplicateNode.InvokeAsync(Node.Id);

    private Task OnDelete() => DeleteNode.InvokeAsync(Node.Id);

    private Task OnResizeColumnDown() => ApplyColumnSizeDelta(-1);

    private Task OnResizeColumnUp() => ApplyColumnSizeDelta(1);

    private Task ApplyColumnSizeDelta(int delta)
    {
        var currentSize = 6;
        if (Node.Parameters.TryGetValue("Size", out var value)
            && value?.Literal is JsonValue jsonValue
            && jsonValue.TryGetValue<int>(out var parsed))
        {
            currentSize = parsed;
        }

        var next = Math.Clamp(currentSize + delta, 1, 12).ToString();
        return NodeQuickParameterChanged.InvokeAsync(("Size", next));
    }

    private void OnDoubleClick()
    {
        var parameter = _descriptor?.Parameters.FirstOrDefault(static parameter => InlineEditableNames.Contains(parameter.Name));
        if (parameter is null)
        {
            return;
        }

        _inlineEditParam = parameter.Name;
        _inlineEditValue = GetParamValue(parameter.Name);
    }

    private void OnInlineEditChanged(ChangeEventArgs args)
    {
        _inlineEditValue = args.Value?.ToString() ?? string.Empty;
    }

    private async Task OnInlineEditKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            CancelInlineEdit();
            return;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            await CommitInlineEdit();
        }
    }

    private async Task CommitInlineEdit()
    {
        if (_inlineEditParam is not null)
        {
            await InlineEditCommitted.InvokeAsync((_inlineEditParam, _inlineEditValue));
        }

        _inlineEditParam = null;
        _inlineEditValue = string.Empty;
    }

    private void CancelInlineEdit()
    {
        _inlineEditParam = null;
        _inlineEditValue = string.Empty;
    }

    private string GetParamValue(string parameterName)
    {
        if (Node.Parameters.TryGetValue(parameterName, out var value) && value?.Literal is not null)
        {
            return value.Literal.GetValue<string?>() ?? string.Empty;
        }

        return string.Empty;
    }

    private Dictionary<string, object?> BuildParameterDictionary(DesignerComponentDescriptor descriptor)
    {
        var parameters = new Dictionary<string, object?>(StringComparer.Ordinal);

        foreach (var parameter in descriptor.Parameters)
        {
            if (parameter.IsRenderFragment)
            {
                Node.Children.TryGetValue(parameter.Name, out var children);
                children ??= [];
                Node.Children[parameter.Name] = children;
                parameters[parameter.Name] = CreateSlotValue(parameter.ParameterType, parameter.Name, children);
                continue;
            }

            if (Node.Parameters.TryGetValue(parameter.Name, out var value))
            {
                parameters[parameter.Name] = DesignParameterBinder.Bind(value, parameter.ParameterType, this);
            }
        }

        return parameters;
    }

    private object CreateSlotValue(Type slotType, string slotName, IReadOnlyList<DesignNode> children)
    {
        if (slotType == typeof(RenderFragment))
        {
            return CreateSlot(slotName, children);
        }

        if (slotType.IsGenericType && slotType.GetGenericTypeDefinition() == typeof(RenderFragment<>))
        {
            return TemplatedSlotMethod.MakeGenericMethod(slotType.GetGenericArguments()[0]).Invoke(this, [slotName, children])
                ?? throw new InvalidOperationException($"Unable to create templated slot '{slotName}' for '{Node.ComponentType}'.");
        }

        throw new InvalidOperationException($"Unsupported slot type '{slotType.Name}' for '{Node.ComponentType}'.");
    }

    private RenderFragment CreateSlot(string slotName, IReadOnlyList<DesignNode> children)
    {
        return builder => RenderSlot(builder, slotName, children);
    }

    private RenderFragment<TContext> CreateTemplatedSlotCore<TContext>(string slotName, IReadOnlyList<DesignNode> children)
    {
        return _ => builder => RenderSlot(builder, slotName, children);
    }

    private void RenderSlot(RenderTreeBuilder builder, string slotName, IReadOnlyList<DesignNode> children)
    {
        var sequence = 0;
        var firstDropzoneId = BuildDropzoneId(slotName, 0);

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "designer-slot");
        builder.AddAttribute(sequence++, "data-slot-name", slotName);

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "designer-slot__hint");
        builder.AddContent(sequence++, slotName);
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", GetDropzoneClass(firstDropzoneId));
        builder.AddAttribute(sequence++, "title", "Drop hier om in te voegen");
        builder.AddAttribute(sequence++, "ondragenter", EventCallback.Factory.Create(this, () => DropzoneDragEnter.InvokeAsync(firstDropzoneId)));
        builder.AddAttribute(sequence++, "ondragleave", EventCallback.Factory.Create(this, () => DropzoneDragLeave.InvokeAsync(firstDropzoneId)));
        builder.AddAttribute(sequence++, "ondragover", EventCallback.Factory.Create<DragEventArgs>(this, _ => { }));
        builder.AddEventPreventDefaultAttribute(sequence++, "ondragover", true);
        builder.AddAttribute(sequence++, "ondrop", EventCallback.Factory.Create<DragEventArgs>(this, () => DropNode.InvokeAsync(new DesignerDropTarget(new Agterhuis.Ui.Designer.Commands.DesignNodeLocation(Node.Id, slotName, 0)))));
        builder.AddEventPreventDefaultAttribute(sequence++, "ondrop", true);
        builder.CloseElement();

        if (children.Count == 0)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", IsDragActive ? "designer-slot__empty designer-slot__empty--ready" : "designer-slot__empty");

            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, "Leeg slot");
            builder.CloseElement();

            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "designer-slot__add");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ToggleSlotPicker(slotName)));
            builder.AddContent(sequence++, "+");
            builder.CloseElement();

            if (IsSlotPickerVisible(slotName))
            {
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "designer-slot__picker");

                var options = GetSlotPaletteOptions();
                builder.OpenElement(sequence++, "select");
                builder.AddAttribute(sequence++, "class", "designer-slot__picker-select");
                builder.AddAttribute(sequence++, "value", GetSlotPickerSelection(slotName, options));
                builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => OnSlotSelectionChanged(slotName, args.Value?.ToString())));

                foreach (var option in options)
                {
                    builder.OpenElement(sequence++, "option");
                    builder.AddAttribute(sequence++, "value", option.ComponentType);
                    builder.AddContent(sequence++, option.DisplayName);
                    builder.CloseElement();
                }

                builder.CloseElement();

                builder.OpenElement(sequence++, "button");
                builder.AddAttribute(sequence++, "type", "button");
                builder.AddAttribute(sequence++, "class", "designer-slot__picker-add");
                builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => AddSlotSelection(slotName)));
                builder.AddContent(sequence++, "Toevoegen");
                builder.CloseElement();

                builder.CloseElement();
            }

            builder.CloseElement();
        }

        for (var index = 0; index < children.Count; index++)
        {
            var child = children[index];

            builder.OpenComponent<DesignerCanvasNode>(sequence++);
            builder.AddAttribute(sequence++, nameof(Node), child);
            builder.AddAttribute(sequence++, nameof(Registry), Registry);
            builder.AddAttribute(sequence++, nameof(SelectedNodeId), SelectedNodeId);
            builder.AddAttribute(sequence++, nameof(SelectNode), SelectNode);
            builder.AddAttribute(sequence++, nameof(DropNode), DropNode);
            builder.AddAttribute(sequence++, nameof(StartDrag), StartDrag);
            builder.AddAttribute(sequence++, nameof(EndDrag), EndDrag);
            builder.AddAttribute(sequence++, nameof(MoveNodeUp), MoveNodeUp);
            builder.AddAttribute(sequence++, nameof(MoveNodeDown), MoveNodeDown);
            builder.AddAttribute(sequence++, nameof(DuplicateNode), DuplicateNode);
            builder.AddAttribute(sequence++, nameof(DeleteNode), DeleteNode);
            builder.AddAttribute(sequence++, nameof(InlineEditCommitted), InlineEditCommitted);
            builder.AddAttribute(sequence++, nameof(NodeQuickParameterChanged), NodeQuickParameterChanged);
            builder.AddAttribute(sequence++, nameof(HoveredNodeId), HoveredNodeId);
            builder.AddAttribute(sequence++, nameof(HoverNodeChanged), HoverNodeChanged);
            builder.AddAttribute(sequence++, nameof(IsDragActive), IsDragActive);
            builder.AddAttribute(sequence++, nameof(HoverDropzoneId), HoverDropzoneId);
            builder.AddAttribute(sequence++, nameof(DropzoneDragEnter), DropzoneDragEnter);
            builder.AddAttribute(sequence++, nameof(DropzoneDragLeave), DropzoneDragLeave);
            builder.AddAttribute(sequence++, nameof(AddNodeRequested), AddNodeRequested);
            builder.CloseComponent();

            var targetIndex = index + 1;
            var dropzoneId = BuildDropzoneId(slotName, targetIndex);
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", GetDropzoneClass(dropzoneId));
            builder.AddAttribute(sequence++, "title", "Drop hier om in te voegen");
            builder.AddAttribute(sequence++, "ondragenter", EventCallback.Factory.Create(this, () => DropzoneDragEnter.InvokeAsync(dropzoneId)));
            builder.AddAttribute(sequence++, "ondragleave", EventCallback.Factory.Create(this, () => DropzoneDragLeave.InvokeAsync(dropzoneId)));
            builder.AddAttribute(sequence++, "ondragover", EventCallback.Factory.Create<DragEventArgs>(this, _ => { }));
            builder.AddEventPreventDefaultAttribute(sequence++, "ondragover", true);
            builder.AddAttribute(sequence++, "ondrop", EventCallback.Factory.Create<DragEventArgs>(this, () => DropNode.InvokeAsync(new DesignerDropTarget(new Agterhuis.Ui.Designer.Commands.DesignNodeLocation(Node.Id, slotName, targetIndex)))));
            builder.AddEventPreventDefaultAttribute(sequence++, "ondrop", true);
            builder.CloseElement();
        }

        builder.CloseElement();
    }

    private string GetDropzoneClass(string dropzoneId)
    {
        var classes = "designer-dropzone";
        if (IsDragActive)
        {
            classes += " designer-dropzone--ready";
        }

        if (string.Equals(HoverDropzoneId, dropzoneId, StringComparison.Ordinal))
        {
            classes += " designer-dropzone--hover";
        }

        return classes;
    }

    private string BuildDropzoneId(string slotName, int index)
        => $"{Node.Id}:{slotName}:{index}";

    private IReadOnlyList<DesignerComponentDescriptor> GetSlotPaletteOptions()
        => Registry.Components
            .Where(static descriptor => descriptor.AllowedInPalette)
            .OrderBy(static descriptor => descriptor.DisplayName, StringComparer.Ordinal)
            .ToArray();

    private bool IsSlotPickerVisible(string slotName)
        => _slotPickerVisible.TryGetValue(slotName, out var isVisible) && isVisible;

    private void ToggleSlotPicker(string slotName)
    {
        _slotPickerVisible.TryGetValue(slotName, out var isVisible);
        _slotPickerVisible[slotName] = !isVisible;
    }

    private string GetSlotPickerSelection(string slotName, IReadOnlyList<DesignerComponentDescriptor> options)
    {
        if (_slotPickerSelection.TryGetValue(slotName, out var value) && !string.IsNullOrWhiteSpace(value))
        {
            return value;
        }

        var fallback = options.FirstOrDefault()?.ComponentType ?? string.Empty;
        _slotPickerSelection[slotName] = fallback;
        return fallback;
    }

    private void OnSlotSelectionChanged(string slotName, string? componentType)
    {
        if (string.IsNullOrWhiteSpace(componentType))
        {
            return;
        }

        _slotPickerSelection[slotName] = componentType;
    }

    private Task AddSlotSelection(string slotName)
    {
        if (!_slotPickerSelection.TryGetValue(slotName, out var componentType)
            || string.IsNullOrWhiteSpace(componentType))
        {
            return Task.CompletedTask;
        }

        _slotPickerVisible[slotName] = false;
        return AddNodeRequested.InvokeAsync((Node.Id, slotName, componentType));
    }
}