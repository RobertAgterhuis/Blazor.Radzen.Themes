@using System.Text.Json
@using Agterhuis.Ui.Designer.Model
@using Agterhuis.Ui.Designer.CodeGen
@using Agterhuis.Ui.Designer.Registry
@using Agterhuis.Ui.Designer.Serialization
@using Agterhuis.Ui.Designer.Validation
@using Microsoft.JSInterop
@using System.Globalization
@using System.Net
@using System.Text.Json.Nodes
@using System.Text.RegularExpressions
@namespace Agterhuis.Ui.Designer.Components

<div class="agt-designer-code-panel">
    <div class="agt-code-tabs">
        <button 
            class="agt-code-tab @(CurrentTab == "code" ? "active" : "")"
            @onclick="@(() => CurrentTab = "code")">
            Razor (preview)
        </button>
        <button 
            class="agt-code-tab @(CurrentTab == "model" ? "active" : "")"
            @onclick="@(() => CurrentTab = "model")">
            Model (JSON)
        </button>
    </div>

    <div class="agt-code-content">
        @if (CurrentTab == "code")
        {
            <div class="agt-code-preview">
                <p class="agt-code-preview__hint">Razor editor is bewerkbaar. Wijzigingen worden als JSON-apply verwerkt.</p>
                @if (CodeDiagnostics.Count > 0)
                {
                    <ul class="agt-validation-error" role="status" aria-live="polite">
                        @foreach (var diagnostic in CodeDiagnostics)
                        {
                            <li>Lijn @diagnostic.Line: @diagnostic.Message</li>
                        }
                    </ul>
                }
                <div class="agt-code-monaco-host" @ref="_codeHost" hidden="@(!_monacoCodeReady)"></div>
                @if (!_monacoCodeReady)
                {
                    <pre><code>
@foreach (var line in PreviewLines)
{
<span class="@(line.IsHighlighted ? "agt-code-line agt-code-line--highlight" : "agt-code-line")">@line.Text</span>
}
</code></pre>
                }
            </div>
        }
        else
        {
            <div class="agt-model-editor">
                <div class="agt-code-monaco-host" @ref="_modelHost" hidden="@(!_monacoModelReady)"></div>
                @if (!_monacoModelReady)
                {
                    <textarea 
                        class="agt-model-textarea"
                        value="@ModelJsonWithActiveMarker"
                        @oninput="OnModelJsonInput"
                        rows="20">
                    </textarea>
                }
                @if (!string.IsNullOrEmpty(ModelValidationError))
                {
                    <div class="agt-validation-error">
                        @ModelValidationError
                    </div>
                }
                <button 
                    class="agt-model-apply-btn"
                    @onclick="ApplyModelAsync">
                    Apply
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public DesignPage? CurrentPage { get; set; }

    [Parameter]
    public DesignDocument? Document { get; set; }

    [Parameter]
    public int ActivePageIndex { get; set; }

    [Parameter]
    public EventCallback<DesignDocument> OnDocumentChanged { get; set; }

    [Parameter]
    public string InitialTab { get; set; } = "code";

    [Parameter]
    public string? InitialModelJson { get; set; }

    [Parameter]
    public string? SelectedNodeId { get; set; }

    [Parameter]
    public bool EnableMonaco { get; set; } = true;

    [Parameter]
    public DesignerComponentRegistry Registry { get; set; } = DesignerComponentRegistry.Instance;

    [Inject]
    public IJSRuntime JS { get; set; } = default!;

    private string CurrentTab { get; set; } = "code";
    private string GeneratedCode { get; set; } = string.Empty;
    private string ModelJson { get; set; } = string.Empty;
    private string ModelJsonWithActiveMarker { get; set; } = string.Empty;
    private string? ModelValidationError { get; set; }
    private DesignDocument? _lastValidDocument;
    private RazorCodeGenerator? _codeGenerator;
    private bool _tabInitialized;
    private string? _lastDocumentSnapshot;
    private IReadOnlyList<PreviewLine> PreviewLines { get; set; } = [];
    private ElementReference _codeHost;
    private ElementReference _modelHost;
    private bool _monacoCodeReady;
    private bool _monacoModelReady;
    private DotNetObjectReference<DesignerCodePanel>? _componentRef;
    private IReadOnlyList<CodeDiagnostic> CodeDiagnostics { get; set; } = [];

    protected override void OnInitialized()
    {
        _codeGenerator = new RazorCodeGenerator();
        RefreshGeneratedCode();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !EnableMonaco)
        {
            return;
        }

        try
        {
            _componentRef = DotNetObjectReference.Create(this);
            
            // Use setupCodeEditors for proper two-way sync with debouncing
            await JS.InvokeVoidAsync("designerInterop.setupCodeEditors", _componentRef, _codeHost, _modelHost);
            
            // Update editors with current content
            await JS.InvokeVoidAsync("designerInterop.updateCodeEditor", GeneratedCode);
            await JS.InvokeVoidAsync("designerInterop.updateJsonEditor", ModelJson);
            
            _monacoCodeReady = true;
            _monacoModelReady = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Monaco initialization error: {ex.Message}");
            _monacoCodeReady = false;
            _monacoModelReady = false;
        }
    }

    protected override void OnParametersSet()
    {
        if (!_tabInitialized)
        {
            CurrentTab = string.Equals(InitialTab, "model", StringComparison.OrdinalIgnoreCase) ? "model" : "code";
            _tabInitialized = true;
        }

        RefreshGeneratedCode();
    }

    private void RefreshGeneratedCode()
    {
        if (CurrentPage is not null && Document is not null && _codeGenerator is not null)
        {
            GeneratedCode = _codeGenerator.GeneratePageCode(CurrentPage, Document);
            PreviewLines = BuildPreviewLines(GeneratedCode, SelectedNodeId);
        }

        if (Document is not null)
        {
            var options = new System.Text.Json.JsonSerializerOptions(DesignJsonOptions.Default)
            {
                WriteIndented = true
            };
            var documentJson = InitialModelJson ?? JsonSerializer.Serialize(Document, options);
            if (!string.Equals(_lastDocumentSnapshot, documentJson, StringComparison.Ordinal))
            {
                ModelJson = documentJson;
                ModelJsonWithActiveMarker = BuildModelJsonWithActiveMarker(documentJson, ActivePageIndex);
                _lastDocumentSnapshot = documentJson;
            }

            _lastValidDocument = DesignDocumentMigrator.Migrate(JsonSerializer.Deserialize<DesignDocument>(JsonSerializer.Serialize(Document, DesignJsonOptions.Default), DesignJsonOptions.Default) ?? Document);
        }
    }

    public Task ApplyModelAsync()
    {
        ModelValidationError = null;

        try
        {
            var options = new System.Text.Json.JsonSerializerOptions(DesignJsonOptions.Default)
            {
                PropertyNameCaseInsensitive = true,
                WriteIndented = true
            };

            var newDocument = JsonSerializer.Deserialize<DesignDocument>(ModelJson, options);
            if (newDocument is null)
            {
                ModelValidationError = "Model JSON kon niet worden gelezen.";
                StateHasChanged();
                return Task.CompletedTask;
            }

            newDocument = DesignDocumentMigrator.Migrate(newDocument);

            var validationErrors = DesignDocumentValidator.Validate(newDocument);
            if (validationErrors.Count > 0)
            {
                ModelValidationError = string.Join("; ", validationErrors.Select(error => $"{error.Path}: {error.Message}"));
                if (_lastValidDocument is not null)
                {
                    ModelJson = JsonSerializer.Serialize(_lastValidDocument, new System.Text.Json.JsonSerializerOptions(DesignJsonOptions.Default)
                    {
                        WriteIndented = true
                    });
                    ModelJsonWithActiveMarker = BuildModelJsonWithActiveMarker(ModelJson, ActivePageIndex);
                    _lastDocumentSnapshot = ModelJson;
                }

                StateHasChanged();
                return Task.CompletedTask;
            }

            _lastValidDocument = newDocument;
            _lastDocumentSnapshot = JsonSerializer.Serialize(newDocument, new System.Text.Json.JsonSerializerOptions(DesignJsonOptions.Default)
            {
                WriteIndented = true
            });

            // Apply the changes
            StateHasChanged();
            return OnDocumentChanged.InvokeAsync(newDocument);
        }
        catch (JsonException ex)
        {
            ModelValidationError = $"JSON-fout: {ex.Message}";
            StateHasChanged();
            return Task.CompletedTask;
        }
        catch (Exception ex)
        {
            ModelValidationError = $"Model-fout: {ex.Message}";
            StateHasChanged();
            return Task.CompletedTask;
        }
    }

    private void OnModelJsonInput(ChangeEventArgs args)
    {
        var input = args.Value?.ToString() ?? string.Empty;
        ModelJsonWithActiveMarker = input;
        ModelJson = StripActiveMarker(input);
    }

    private static string BuildModelJsonWithActiveMarker(string json, int activePageIndex)
    {
        var marker = $"\"Pages\": [ // <- active page index: {activePageIndex}";
        var token = "\"Pages\": [";
        var markerIndex = json.IndexOf(token, StringComparison.Ordinal);
        return markerIndex < 0 ? json : json.Replace(token, marker, StringComparison.Ordinal);
    }

    private static string StripActiveMarker(string json)
    {
        const string markerPrefix = "\"Pages\": [ // <- active page index:";
        var markerIndex = json.IndexOf(markerPrefix, StringComparison.Ordinal);
        if (markerIndex < 0)
        {
            return json;
        }

        var lineEnd = json.IndexOf('\n', markerIndex);
        if (lineEnd < 0)
        {
            return json.Replace(markerPrefix, "\"Pages\": [", StringComparison.Ordinal);
        }

        var line = json.Substring(markerIndex, lineEnd - markerIndex);
        return json.Replace(line, "\"Pages\": [", StringComparison.Ordinal);
    }

    private static IReadOnlyList<PreviewLine> BuildPreviewLines(string code, string? selectedNodeId)
    {
        var lines = code.Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);
        var highlightedIndexes = new HashSet<int>();

        if (!string.IsNullOrWhiteSpace(selectedNodeId))
        {
            for (var index = 0; index < lines.Length; index++)
            {
                if (!lines[index].Contains($"agt-node:{selectedNodeId}", StringComparison.Ordinal))
                {
                    continue;
                }

                highlightedIndexes.Add(index);
                for (var next = index + 1; next < lines.Length; next++)
                {
                    if (lines[next].Contains("@* agt-node:", StringComparison.Ordinal))
                    {
                        break;
                    }

                    highlightedIndexes.Add(next);
                }

                break;
            }
        }

        return lines
            .Select((line, index) => new PreviewLine(line + Environment.NewLine, highlightedIndexes.Contains(index)))
            .ToArray();
    }

    private sealed record PreviewLine(string Text, bool IsHighlighted);

    /// <summary>
    /// Monaco code editor callback. Applies edits by mapping code text to model JSON.
    /// </summary>
    [JSInvokable]
    public async Task OnCodeEditorChanged(string code)
    {
        if (string.IsNullOrWhiteSpace(code) || string.Equals(code, GeneratedCode, StringComparison.Ordinal))
        {
            return;
        }

        if (Document is null)
        {
            return;
        }

        var parseResult = ParseNodeAttributes(code);
        CodeDiagnostics = parseResult.Diagnostics;
        await JS.InvokeVoidAsync("designerInterop.setCodeDiagnostics", parseResult.Diagnostics.Select(ToMonacoDiagnosticPayload).ToArray());

        if (parseResult.NodeAttributes.Count == 0)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cloned = CloneDocument(Document);
        if (cloned is null || ActivePageIndex < 0 || ActivePageIndex >= cloned.Pages.Count)
        {
            return;
        }

        var changed = ApplyParsedAttributesToPage(cloned.Pages[ActivePageIndex], parseResult.NodeAttributes);
        if (!changed)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        cloned = DesignDocumentMigrator.Migrate(cloned);
        var validationErrors = DesignDocumentValidator.Validate(cloned);
        if (validationErrors.Count > 0)
        {
            ModelValidationError = string.Join("; ", validationErrors.Select(error => $"{error.Path}: {error.Message}"));
            await InvokeAsync(StateHasChanged);
            return;
        }

        ModelValidationError = null;
        GeneratedCode = code;
        await OnDocumentChanged.InvokeAsync(cloned);
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Called by JavaScript when user edits JSON in Monaco (debounced 500ms).
    /// Applies the JSON changes to the design document.
    /// </summary>
    [JSInvokable]
    public async Task OnJsonEditorChanged(string json)
    {
        if (string.Equals(ModelJson, json, StringComparison.Ordinal))
        {
            return; // No actual change
        }

        ModelJson = json;
        await ApplyModelAsync();
    }

    public void Dispose()
    {
        _componentRef?.Dispose();
    }

    private static DesignDocument? CloneDocument(DesignDocument source)
    {
        var serialized = JsonSerializer.Serialize(source, DesignJsonOptions.Default);
        return JsonSerializer.Deserialize<DesignDocument>(serialized, DesignJsonOptions.Default);
    }

    private static ParseResult ParseNodeAttributes(string code)
    {
        var result = new Dictionary<string, Dictionary<string, string>>(StringComparer.Ordinal);
        var diagnostics = new List<CodeDiagnostic>();
        var lines = code.Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);
        var markerRegex = new Regex("@\\*\\s*agt-node:(?<id>[A-Za-z0-9_-]+)\\s*\\*@", RegexOptions.Compiled);
        var attrRegex = new Regex("@(?<name>[A-Za-z_][A-Za-z0-9_]*)=\"(?<value>(?:[^\"]|\"\")*)\"", RegexOptions.Compiled);
        var slotStartRegex = new Regex("^\\s*<(?<slot>[A-Za-z_][A-Za-z0-9_]*)>\\s*$", RegexOptions.Compiled);
        var slotEndRegex = new Regex("^\\s*</(?<slot>[A-Za-z_][A-Za-z0-9_]*)>\\s*$", RegexOptions.Compiled);

        var slotStack = new Stack<(string Slot, int Line)>();

        for (var index = 0; index < lines.Length; index++)
        {
            var slotStart = slotStartRegex.Match(lines[index]);
            if (slotStart.Success)
            {
                slotStack.Push((slotStart.Groups["slot"].Value, index + 1));
            }

            var slotEnd = slotEndRegex.Match(lines[index]);
            if (slotEnd.Success)
            {
                var endingSlot = slotEnd.Groups["slot"].Value;
                if (slotStack.Count == 0)
                {
                    diagnostics.Add(new CodeDiagnostic(index + 1, $"Onverwachte slot-sluiting </{endingSlot}> zonder opening."));
                }
                else
                {
                    var opened = slotStack.Pop();
                    if (!string.Equals(opened.Slot, endingSlot, StringComparison.Ordinal))
                    {
                        diagnostics.Add(new CodeDiagnostic(index + 1, $"Slot-sluiting </{endingSlot}> matcht niet met <{opened.Slot}> op lijn {opened.Line}."));
                    }
                }
            }

            if (lines[index].Contains("@code", StringComparison.Ordinal)
                || lines[index].Contains("@if", StringComparison.Ordinal)
                || lines[index].Contains("@foreach", StringComparison.Ordinal))
            {
                diagnostics.Add(new CodeDiagnostic(index + 1, "Deze Razor-constructie is niet roundtrippable naar het designmodel."));
            }

            var markerMatch = markerRegex.Match(lines[index]);
            if (!markerMatch.Success)
            {
                continue;
            }

            var nodeId = markerMatch.Groups["id"].Value;
            var tagStart = -1;
            for (var lookahead = index + 1; lookahead < lines.Length; lookahead++)
            {
                var trimmed = lines[lookahead].TrimStart();
                if (trimmed.StartsWith("<", StringComparison.Ordinal) && !trimmed.StartsWith("</", StringComparison.Ordinal))
                {
                    tagStart = lookahead;
                    break;
                }
            }

            if (tagStart < 0)
            {
                diagnostics.Add(new CodeDiagnostic(index + 1, "Node marker zonder volgende component-tag gevonden."));
                continue;
            }

            var openingTagBuilder = new System.Text.StringBuilder();
            var tagEnd = tagStart;
            for (; tagEnd < lines.Length; tagEnd++)
            {
                openingTagBuilder.AppendLine(lines[tagEnd]);
                if (lines[tagEnd].Contains('>'))
                {
                    break;
                }
            }

            var openingTag = openingTagBuilder.ToString();
            var attributes = new Dictionary<string, string>(StringComparer.Ordinal);
            foreach (Match attrMatch in attrRegex.Matches(openingTag))
            {
                var name = attrMatch.Groups["name"].Value;
                var rawValue = attrMatch.Groups["value"].Value;
                attributes[name] = WebUtility.HtmlDecode(rawValue);
            }

            if (attributes.Count > 0)
            {
                result[nodeId] = attributes;
            }
            else
            {
                diagnostics.Add(new CodeDiagnostic(tagStart + 1, $"Geen parsebare parameters gevonden voor node '{nodeId}'."));
            }

            index = tagEnd;
        }

        foreach (var unclosed in slotStack)
        {
            diagnostics.Add(new CodeDiagnostic(unclosed.Line, $"Niet-gesloten slot <{unclosed.Slot}>."));
        }

        return new ParseResult(result, diagnostics.OrderBy(static item => item.Line).ToArray());
    }

    private bool ApplyParsedAttributesToPage(DesignPage page, IReadOnlyDictionary<string, Dictionary<string, string>> parsedNodeAttributes)
    {
        var changed = false;
        foreach (var root in page.Nodes)
        {
            changed |= ApplyParsedAttributesToNodeRecursive(root, parsedNodeAttributes);
        }

        return changed;
    }

    private bool ApplyParsedAttributesToNodeRecursive(DesignNode node, IReadOnlyDictionary<string, Dictionary<string, string>> parsedNodeAttributes)
    {
        var changed = false;
        if (parsedNodeAttributes.TryGetValue(node.Id, out var attributes)
            && Registry.TryGetDescriptor(node.ComponentType, out var descriptor))
        {
            foreach (var parameter in descriptor.Parameters)
            {
                if (!attributes.TryGetValue(parameter.Name, out var parsedText))
                {
                    continue;
                }

                var oldValue = node.Parameters.TryGetValue(parameter.Name, out var existingValue)
                    ? existingValue?.Literal?.ToJsonString() ?? existingValue?.Expression
                    : null;

                var nextValue = ConvertParsedTextToParameterValue(parsedText, parameter.ParameterType, existingValue);
                var nextSerialized = nextValue.Literal?.ToJsonString() ?? nextValue.Expression;

                if (!string.Equals(oldValue, nextSerialized, StringComparison.Ordinal))
                {
                    node.Parameters[parameter.Name] = nextValue;
                    changed = true;
                }
            }
        }

        foreach (var children in node.Children.Values)
        {
            foreach (var child in children)
            {
                changed |= ApplyParsedAttributesToNodeRecursive(child, parsedNodeAttributes);
            }
        }

        return changed;
    }

    private static DesignParameterValue ConvertParsedTextToParameterValue(string parsedText, Type parameterType, DesignParameterValue? existing)
    {
        if (parameterType == typeof(bool))
        {
            return DesignParameterValue.FromValue(string.Equals(parsedText, "true", StringComparison.OrdinalIgnoreCase));
        }

        if (parameterType == typeof(int) && int.TryParse(parsedText, out var intValue))
        {
            return DesignParameterValue.FromValue(intValue);
        }

        if (parameterType == typeof(decimal) && decimal.TryParse(parsedText, NumberStyles.Any, CultureInfo.InvariantCulture, out var decimalValue))
        {
            return DesignParameterValue.FromValue(decimalValue);
        }

        if (parameterType == typeof(double) && double.TryParse(parsedText, NumberStyles.Any, CultureInfo.InvariantCulture, out var doubleValue))
        {
            return DesignParameterValue.FromValue(doubleValue);
        }

        if (existing?.Literal is JsonValue existingLiteral)
        {
            if (existingLiteral.TryGetValue<bool>(out _))
            {
                return DesignParameterValue.FromValue(string.Equals(parsedText, "true", StringComparison.OrdinalIgnoreCase));
            }

            if (existingLiteral.TryGetValue<int>(out _) && int.TryParse(parsedText, out var parsedInt))
            {
                return DesignParameterValue.FromValue(parsedInt);
            }

            if (existingLiteral.TryGetValue<decimal>(out _) && decimal.TryParse(parsedText, NumberStyles.Any, CultureInfo.InvariantCulture, out var parsedDecimal))
            {
                return DesignParameterValue.FromValue(parsedDecimal);
            }
        }

        return DesignParameterValue.FromValue(parsedText);
    }

    private static object ToMonacoDiagnosticPayload(CodeDiagnostic diagnostic)
    {
        return new
        {
            line = diagnostic.Line,
            message = diagnostic.Message,
            severity = 2
        };
    }

    private sealed record ParseResult(IReadOnlyDictionary<string, Dictionary<string, string>> NodeAttributes, IReadOnlyList<CodeDiagnostic> Diagnostics);

    private sealed record CodeDiagnostic(int Line, string Message);
}
