{
  "name": "agterhuis-ui-a11y",
  "private": true,
  "type": "module",
  "scripts": {
    "a11y:install": "playwright install --with-deps chromium",
    "a11y:test": "playwright test tests/a11y",
    "a11y:journey": "playwright test tests/a11y/blog-journey.spec.mjs",
    "contrast:sweep": "node eng/contrast-sweep/contrast-sweep.mjs",
    "contrast:sweep:blog-volt": "node eng/contrast-sweep/contrast-sweep.mjs --themes=volt --variants=light,dark --routes=/blog,/blog/projecten,/blog/projecten/1,/blog/agents,/blog/prompts,/blog/skills,/blog/artikel/1,/blog/over --checkpoint=eng/contrast-sweep/blog-volt.checkpoint.json --checkpoint-every=2",
    "contrast:sweep:resume": "node eng/contrast-sweep/contrast-sweep.mjs --resume=true",
    "contrast:sweep:fast": "node eng/contrast-sweep/contrast-sweep.mjs --max-themes=2 --max-routes=10 --checkpoint-every=2",
    "contrast:sweep:loop": "node eng/contrast-sweep/contrast-sweep-loop.mjs",
    "screenshots": "node eng/screenshots/capture.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.54.2",
    "sharp": "^0.34.4"
  }
}
