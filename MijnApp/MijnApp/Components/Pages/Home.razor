@page "/"

<PageTitle>Agterhuis.Ui starter</PageTitle>

<div class="agt-page agt-stack">
    <AgtPageHeader Kicker="Starter" Title="Agterhuis.Ui" Description="Blazor Web App met theming, layout en kernpatronen klaar om uit te breiden." />

    <div class="starter-card-grid">
        <AgtCard>
            <Header>Wat zit erin</Header>
            <ChildContent>
                <ul>
                    <li>Thema- en density-switch in de sidebar shell.</li>
                    <li>Formulierpagina met gelabelde invoer en actiebar.</li>
                    <li>Lijstpagina met filterveld en data-grid.</li>
                </ul>
            </ChildContent>
        </AgtCard>

        <AgtCard>
            <Header>Volgende stap</Header>
            <ChildContent>
                <p>Vervang de voorbeeldpagina's door domeinspecifieke flows en laat de tokens de visuele laag blijven sturen.</p>
            </ChildContent>
        </AgtCard>
    </div>
</div>