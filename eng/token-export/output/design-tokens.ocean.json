          "ocean-light": "0 3px 8px rgb(18 41 41 / 19%), 0 18px 34px rgb(19 66 66 / 16%)",
          "ocean-dark": "0 6px 14px rgb(0 0 0 / 36%), 0 24px 42px rgb(13 74 74 / 28%)"
        }
      },
      "sm": {
        "$type": "color",
        "$value": {
          "ocean-light": "0 1px 2px rgb(18 41 41 / 17%), 0 10px 20px rgb(19 66 66 / 12%)",
          "ocean-dark": "0 2px 4px rgb(0 0 0 / 32%), 0 14px 26px rgb(13 74 74 / 22%)"
        }
      }
    },
    "surface": {
      "0": {
        "$type": "color",
        "$value": {
          "ocean-light": "#f6fbfb",
          "ocean-dark": "#071818"
        }
      },
      "1": {
        "$type": "color",
        "$value": {
          "ocean-light": "#ffffff",
          "ocean-dark": "#0b1e1e"
        }
      },
      "2": {
        "$type": "color",
        "$value": {
          "ocean-light": "#f3f8f8",
          "ocean-dark": "#102626"
        }
      },
      "3": {
        "$type": "color",
        "$value": {
          "ocean-light": "#e8f1f1",
          "ocean-dark": "#153434"
        }
      }
    },
    "text": {
      "body": {
        "$type": "color",
        "$value": {
          "ocean-light": "#1e3737",
          "ocean-dark": "#e9f5f5"
        }
      },
      "disabled": {
        "$type": "color",
        "$value": {
          "ocean-light": "#6b8383",
          "ocean-dark": "#85a2a2"
        }
      },
      "heading": {
        "$type": "color",
        "$value": {
          "ocean-light": "#123535",
          "ocean-dark": "#e9f5f5"
        }
      },
      "muted": {
        "$type": "color",
        "$value": {
          "ocean-light": "var(--agt-nav-item-text)",
          "ocean-dark": "var(--agt-nav-item-text)"
        }
      }
    },
    "tooltip": {
      "text": {
        "$type": "color",
        "$value": {
          "ocean-light": "#1e3737",
          "ocean-dark": "#e9f5f5"
        }
      }
    },
    "topbar": {
      "brand": {
        "accent": {
          "$type": "color",
          "$value": {
            "ocean-light": "var(--agt-color-accent-400)",
            "ocean-dark": "var(--agt-color-accent-400)"
          }
        },
        "color": {
          "$type": "color",
          "$value": {
            "ocean-light": "#123535",
            "ocean-dark": "#e9f5f5"
          }
        }
      },
      "icon": {
        "color": {
          "$type": "color",
          "$value": {
            "ocean-light": "#557171",
            "ocean-dark": "#c6dfdf"
          }
        },
        "hover": {
          "color": {
            "$type": "color",
            "$value": {
              "ocean-light": "#095c5d",
              "ocean-dark": "#e8a13d"
            }
          }
        }
      }
    }
  }
}