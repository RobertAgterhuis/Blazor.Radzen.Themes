        }
      }
    },
    "selection": {
      "tint": {
        "$type": "color",
        "$value": {
          "volt-light": "#ece8d8",
          "volt-dark": "#2a2a24"
        }
      }
    },
    "shadow": {
      "md": {
        "$type": "color",
        "$value": {
          "volt-light": "0 2px 4px rgb(34 33 29 / 14%)",
          "volt-dark": "0 2px 5px rgb(0 0 0 / 42%)"
        }
      },
      "sm": {
        "$type": "color",
        "$value": {
          "volt-light": "0 1px 1px rgb(34 33 29 / 10%)",
          "volt-dark": "0 1px 1px rgb(0 0 0 / 34%)"
        }
      }
    },
    "surface": {
      "0": {
        "$type": "color",
        "$value": {
          "volt-light": "#faf8f2",
          "volt-dark": "#141412"
        }
      },
      "1": {
        "$type": "color",
        "$value": {
          "volt-light": "#fffdf8",
          "volt-dark": "#1a1a17"
        }
      },
      "2": {
        "$type": "color",
        "$value": {
          "volt-light": "#f3efe4",
          "volt-dark": "#212120"
        }
      },
      "3": {
        "$type": "color",
        "$value": {
          "volt-light": "#e7e1d1",
          "volt-dark": "#2c2c28"
        }
      }
    },
    "text": {
      "body": {
        "$type": "color",
        "$value": {
          "volt-light": "#26241e",
          "volt-dark": "#f4f3ee"
        }
      },
      "disabled": {
        "$type": "color",
        "$value": {
          "volt-light": "#8f8a7d",
          "volt-dark": "#6f6d63"
        }
      },
      "heading": {
        "$type": "color",
        "$value": {
          "volt-light": "#1c1c18",
          "volt-dark": "#f4f3ee"
        }
      },
      "muted": {
        "$type": "color",
        "$value": {
          "volt-light": "var(--agt-nav-item-text)",
          "volt-dark": "var(--agt-nav-item-text)"
        }
      }
    },
    "tooltip": {
      "text": {
        "$type": "color",
        "$value": {
          "volt-light": "#1c1c18",
          "volt-dark": "#f4f3ee"
        }
      }
    },
    "topbar": {
      "brand": {
        "accent": {
          "$type": "color",
          "$value": {
            "volt-light": "var(--agt-color-accent-500)",
            "volt-dark": "var(--agt-color-accent-400)"
          }
        },
        "color": {
          "$type": "color",
          "$value": {
            "volt-light": "#1c1c18",
            "volt-dark": "#f4f3ee"
          }
        }
      },
      "icon": {
        "color": {
          "$type": "color",
          "$value": {
            "volt-light": "#5d594d",
            "volt-dark": "#c9c7bd"
          }
        },
        "hover": {
          "color": {
            "$type": "color",
            "$value": {
              "volt-light": "#5a7016",
              "volt-dark": "#c8f542"
            }
          }
        }
      }
    }
  }
}