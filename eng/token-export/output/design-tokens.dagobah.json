          "dagobah-light": "var(--agt-on-accent)",
          "dagobah-dark": "var(--agt-on-accent)"
        }
      },
      "success": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#ffffff"
        }
      },
      "warning": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#2e2718"
        }
      }
    },
    "press": {
      "scale": {
        "$type": "string",
        "$value": {
          "dagobah-light": "0.985",
          "dagobah-dark": "0.985"
        }
      }
    },
    "radius": {
      "scale": {
        "$type": "dimension",
        "$value": {
          "dagobah-light": "1.25",
          "dagobah-dark": "1.18"
        }
      }
    },
    "selection": {
      "tint": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#e5f2dc",
          "dagobah-dark": "#26301f"
        }
      }
    },
    "shadow": {
      "md": {
        "$type": "color",
        "$value": {
          "dagobah-light": "0 3px 8px rgb(24 36 17 / 20%), 0 20px 34px rgb(66 95 48 / 17%)",
          "dagobah-dark": "0 6px 14px rgb(0 0 0 / 38%), 0 24px 42px rgb(47 69 35 / 30%)"
        }
      },
      "sm": {
        "$type": "color",
        "$value": {
          "dagobah-light": "0 1px 2px rgb(24 36 17 / 16%), 0 10px 20px rgb(66 95 48 / 13%)",
          "dagobah-dark": "0 2px 4px rgb(0 0 0 / 34%), 0 14px 26px rgb(47 69 35 / 24%)"
        }
      }
    },
    "surface": {
      "0": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#f7f9f3",
          "dagobah-dark": "#0e120c"
        }
      },
      "1": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#ffffff",
          "dagobah-dark": "#131810"
        }
      },
      "2": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#fbfcf8",
          "dagobah-dark": "#171d14"
        }
      },
      "3": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#eaf1df",
          "dagobah-dark": "#222b1c"
        }
      }
    },
    "text": {
      "body": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#2f3f25",
          "dagobah-dark": "#eef2e8"
        }
      },
      "disabled": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#7f8d74",
          "dagobah-dark": "#8a977c"
        }
      },
      "heading": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#2c4020",
          "dagobah-dark": "#eef2e8"
        }
      },
      "muted": {
        "$type": "color",
        "$value": {
          "dagobah-light": "var(--agt-nav-item-text)",
          "dagobah-dark": "var(--agt-nav-item-text)"
        }
      }
    },
    "tooltip": {
      "text": {
        "$type": "color",
        "$value": {
          "dagobah-light": "#2f3f25",
          "dagobah-dark": "#eef2e8"
        }
      }
    },
    "topbar": {
      "brand": {
        "accent": {
          "$type": "color",
          "$value": {
            "dagobah-light": "var(--agt-color-accent-500)",
            "dagobah-dark": "var(--agt-color-accent-400)"
          }
        },
        "color": {
          "$type": "color",
          "$value": {
            "dagobah-light": "#2c4020",
            "dagobah-dark": "#eef2e8"
          }
        }
      },
      "icon": {
        "color": {
          "$type": "color",
          "$value": {
            "dagobah-light": "#66775b",
            "dagobah-dark": "#c4cfb6"
          }
        },
        "hover": {
          "color": {
            "$type": "color",
            "$value": {
              "dagobah-light": "#3f5d2e",
              "dagobah-dark": "#7cfc5a"
            }
          }
        }
      }
    }
  }
}